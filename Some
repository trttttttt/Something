                PlaceholderText=cfg2.PlaceholderText or "Type here...",
                PlaceholderColor3=T2.Placeholder,Text=tostring(val),
                TextColor3=T2.Text,Font=Enum.Font.Gotham,TextSize=11,
                ClearTextOnFocus=false,TextXAlignment=Enum.TextXAlignment.Left,Parent=IBg,
            })
            TB.Focused:Connect(function() Tween(IStroke,{Color=T2.InputStrokeFocus},0.15) end)
            TB.FocusLost:Connect(function(enter)
                Tween(IStroke,{Color=T2.InputStroke},0.15)
                if cfg2.Flag then Flags[cfg2.Flag] = TB.Text end
                if (cfg2.OnEnter and enter) or not cfg2.OnEnter then
                    if cfg2.Callback then pcall(cfg2.Callback, TB.Text) end
                    self._window:SaveConfig()
                end
            end)
            RegisterElement(cfg2.Name or "Input", f)
            return {SetValue=function(v) TB.Text=tostring(v) end, GetValue=function() return TB.Text end}
        end

        -- ── DROPDOWN ───────────────────────────────────────
        function TabObj:CreateDropdown(cfg2)
            local opts    = cfg2.Options or {}
            local current = self._window:LoadConfigValue(cfg2.Flag, cfg2.CurrentOption or opts[1] or "")
            local isOpen  = false
            local trackConn = nil
            if cfg2.Flag then Flags[cfg2.Flag] = current end

            local f = BaseFrame(0)
            f.ClipsDescendants = false
            New("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,10),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=f})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),Parent=f})

            -- Label row
            local TopRow3 = New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=f})
            New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Padding=UDim.new(0,6),Parent=TopRow3})
            if cfg2.Icon then
                New("ImageLabel",{Size=UDim2.fromOffset(14,14),BackgroundTransparency=1,Image=GetIcon(cfg2.Icon),ImageColor3=T2.TextDim,Parent=TopRow3})
            end
            New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=cfg2.Name or "Dropdown",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=TopRow3})

            -- Dropdown button (taller, more visible)
            local DropBtn = New("TextButton",{
                Size=UDim2.new(1,0,0,36),BackgroundColor3=T2.InputBg,BorderSizePixel=0,
                Text="",AutoButtonColor=false,LayoutOrder=2,Parent=f,
            })
            New("UICorner",{CornerRadius=UDim.new(0,8),Parent=DropBtn})
            New("UIStroke",{Color=T2.InputStroke,Thickness=1,Parent=DropBtn})
            New("UIPadding",{PaddingLeft=UDim.new(0,11),PaddingRight=UDim.new(0,8),Parent=DropBtn})
            New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=DropBtn})
            local CurLabel = New("TextLabel",{
                Size=UDim2.new(1,-26,1,0),BackgroundTransparency=1,
                Text=tostring(current),TextColor3=T2.Text,
                Font=Enum.Font.GothamSemibold,TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left,Parent=DropBtn,
            })
            local Arrow = New("TextLabel",{
                Size=UDim2.fromOffset(22,22),BackgroundTransparency=1,
                Text="⌄",TextColor3=T2.Accent,
                Font=Enum.Font.GothamBold,TextSize=16,Parent=DropBtn,
            })

            -- ListBg parented to ScreenGui to escape ALL clipping
            local ITEM_H  = 34
            local MAX_VIS = 7  -- max visible without scroll
            local PAD     = 8  -- top+bottom padding inside list

            local ListBg = New("Frame",{
                Size=UDim2.fromOffset(0,0),
                BackgroundColor3=T2.SecondaryBg,BorderSizePixel=0,
                ClipsDescendants=true,Visible=false,ZIndex=9998,
                Parent=self._window._screenGui,
            })
            New("UICorner",{CornerRadius=UDim.new(0,10),Parent=ListBg})
            New("UIStroke",{Color=T2.Accent,Thickness=1,Transparency=0.5,Parent=ListBg})
            -- Drop shadow
            New("ImageLabel",{
                AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,4),
                Size=UDim2.new(1,20,1,20),BackgroundTransparency=1,
                Image="rbxassetid://6014261993",ImageColor3=Color3.new(0,0,0),
                ImageTransparency=0.55,ScaleType=Enum.ScaleType.Slice,
                SliceCenter=Rect.new(49,49,450,450),ZIndex=9997,Parent=ListBg,
            })

            local ListScroll = New("ScrollingFrame",{
                Size=UDim2.fromScale(1,1),BackgroundTransparency=1,BorderSizePixel=0,
                ScrollBarThickness=3,ScrollBarImageColor3=T2.Accent,
                CanvasSize=UDim2.fromOffset(0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
                ZIndex=9999,Parent=ListBg,
            })
            New("UIPadding",{PaddingTop=UDim.new(0,PAD/2),PaddingBottom=UDim.new(0,PAD/2),PaddingLeft=UDim.new(0,5),PaddingRight=UDim.new(0,5),Parent=ListScroll})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,3),Parent=ListScroll})

            local function GetListPos()
                local abs = DropBtn.AbsolutePosition
                local sz  = DropBtn.AbsoluteSize
                local visCount = math.min(#opts, MAX_VIS)
                local listH = visCount * ITEM_H + PAD
                local listW = math.max(sz.X, 120)
                local screenH = workspace.CurrentCamera.ViewportSize.Y
                local posY = abs.Y + sz.Y + 6
                if posY + listH > screenH - 16 then
                    posY = abs.Y - listH - 6
                end
                return abs.X, posY, listW, listH
            end

            local function UpdateListPos()
                if not isOpen then return end
                local x, y, w, h = GetListPos()
                ListBg.Position = UDim2.fromOffset(x, y)
            end

            local function CloseList()
                isOpen = false
                if trackConn then trackConn:Disconnect(); trackConn = nil end
                Tween(ListBg,{Size=UDim2.fromOffset(ListBg.AbsoluteSize.X, 0)},0.15)
                Tween(Arrow,{TextColor3=T2.Accent,Rotation=0},0.15)
                task.delay(0.17, function() if not isOpen then ListBg.Visible = false end end)
            end

            local function BuildList()
                for _, c in ipairs(ListScroll:GetChildren()) do
                    if c:IsA("TextButton") then c:Destroy() end
                end
                for i, opt in ipairs(opts) do
                    local isCurrent = opt == current
                    local item = New("TextButton",{
                        Size=UDim2.new(1,0,0,ITEM_H - 3),
                        BackgroundColor3=isCurrent and T2.Accent or T2.ElementBg,
                        BorderSizePixel=0,Text=opt,
                        TextColor3=isCurrent and T2.AccentText or T2.Text,
                        Font=isCurrent and Enum.Font.GothamBold or Enum.Font.Gotham,
                        TextSize=12,AutoButtonColor=false,ZIndex=10000,Parent=ListScroll,
                    })
                    New("UICorner",{CornerRadius=UDim.new(0,7),Parent=item})
                    New("UIPadding",{PaddingLeft=UDim.new(0,12),Parent=item})
                    item.TextXAlignment = Enum.TextXAlignment.Left
                    if not isCurrent then
                        item.MouseEnter:Connect(function()
                            Tween(item,{BackgroundColor3=T2.ElementBgHover},0.1)
                        end)
                        item.MouseLeave:Connect(function()
                            Tween(item,{BackgroundColor3=T2.ElementBg},0.1)
                        end)
                    end
                    item.MouseButton1Click:Connect(function()
                        current = opt
                        CurLabel.Text = opt
                        if cfg2.Flag then Flags[cfg2.Flag] = opt end
                        CloseList()
                        task.defer(BuildList)
                        if cfg2.Callback then pcall(cfg2.Callback, opt) end
                        self._window:SaveConfig()
                    end)
                end
            end
            BuildList()

            DropBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    BuildList()
                    local x, y, w, h = GetListPos()
                    ListBg.Position = UDim2.fromOffset(x, y)
                    ListBg.Size = UDim2.fromOffset(w, 0)
                    ListBg.Visible = true
                    Tween(ListBg,{Size=UDim2.fromOffset(w, h)},0.2)
                    Tween(Arrow,{Rotation=180},0.2)

                    -- Track scroll/drag movement to reposition list in real-time
                    trackConn = RunService.RenderStepped:Connect(UpdateListPos)
                else
                    CloseList()
                end
            end)

            -- Close on click outside
            local closeConn = UIS.InputBegan:Connect(function(i, gp)
                if gp then return end
                if isOpen and (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) then
                    task.defer(function()
                        if isOpen then CloseList() end
                    end)
                end
            end)
            table.insert(self._window._connections, closeConn)

            -- ── SUBTAB SYSTEM ──────────────────────────────────
            -- (Subtabs live inside a parent TabObj's content area)
            function TabObj:CreateSubTabs(subTabDefs)
                -- subTabDefs: { {Name="Name", Icon="icon"}, ... }
                local subTabs   = {}
                local activeSubTab = nil

                -- SubTab bar at top of content
                local SubBar = New("Frame",{
                    Size=UDim2.new(1,0,0,36),
                    BackgroundColor3=T2.SecondaryBg,BorderSizePixel=0,
                    Parent=TabContent,
                })
                New("UICorner",{CornerRadius=UDim.new(0,9),Parent=SubBar})
                New("UIStroke",{Color=T2.ElementStroke,Thickness=1,Parent=SubBar})
                New("UIPadding",{PaddingLeft=UDim.new(0,4),PaddingRight=UDim.new(0,4),PaddingTop=UDim.new(0,4),PaddingBottom=UDim.new(0,4),Parent=SubBar})
                local SubBarLayout = New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Padding=UDim.new(0,4),Parent=SubBar})

                for _, def in ipairs(subTabDefs) do
                    -- Content frame for this subtab
                    local SubContent = New("Frame",{
                        Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                        BackgroundTransparency=1,BorderSizePixel=0,
                        Visible=false,Parent=TabContent,
                    })
                    New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),Parent=SubContent})

                    -- SubTab button
                    local btnW = 1/#subTabDefs
                    local SubBtn = New("TextButton",{
                        Size=UDim2.new(btnW,-(4*(#subTabDefs-1)/#subTabDefs),1,0),
                        BackgroundColor3=T2.TabBg,BackgroundTransparency=1,
                        BorderSizePixel=0,Text="",AutoButtonColor=false,
                        Parent=SubBar,
                    })
                    New("UICorner",{CornerRadius=UDim.new(0,6),Parent=SubBtn})
                    New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Padding=UDim.new(0,5),Parent=SubBtn})
                    New("UIPadding",{PaddingLeft=UDim.new(0,8),Parent=SubBtn})

                    if def.Icon then
                        New("ImageLabel",{Size=UDim2.fromOffset(13,13),BackgroundTransparency=1,Image=GetIcon(def.Icon),ImageColor3=T2.TabText,Parent=SubBtn})
                    end
                    local SubLabel = New("TextLabel",{
                        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                        Text=def.Name,TextColor3=T2.TabText,
                        Font=Enum.Font.GothamSemibold,TextSize=11,
                        TextXAlignment=Enum.TextXAlignment.Left,Parent=SubBtn,
                    })

                    local subEntry = {
                        _btn=SubBtn, _label=SubLabel, _content=SubContent,
                        _name=def.Name,
                    }
                    table.insert(subTabs, subEntry)

                    -- SubTab API mirrors TabObj API
                    local subAPI = {_content=SubContent,_theme=T2,_window=self._window}
                    -- Copy all element creators into subAPI targeting SubContent instead
                    local function SubBaseFrame(h)
                        local sf = New("Frame",{
                            Size=UDim2.new(1,0,0,h or 44),
                            BackgroundColor3=T2.ElementBg,BorderSizePixel=0,
                            AutomaticSize=(h==0) and Enum.AutomaticSize.Y or Enum.AutomaticSize.None,
                            Parent=SubContent,
                        })
                        New("UICorner",{CornerRadius=UDim.new(0,8),Parent=sf})
                        New("UIStroke",{Color=T2.ElementStroke,Thickness=1,Parent=sf})
                        sf.MouseEnter:Connect(function() Tween(sf,{BackgroundColor3=T2.ElementBgHover},0.15) end)
                        sf.MouseLeave:Connect(function() Tween(sf,{BackgroundColor3=T2.ElementBg},0.15) end)
                        return sf
                    end

                    function subAPI:CreateSection(text)
                        local sf = New("Frame",{Size=UDim2.new(1,0,0,22),BackgroundTransparency=1,Parent=SubContent})
                        New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Padding=UDim.new(0,8),Parent=sf})
                        New("Frame",{Size=UDim2.fromOffset(10,1),BackgroundColor3=T2.SectionLine,BorderSizePixel=0,Parent=sf})
                        New("TextLabel",{Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,BackgroundTransparency=1,Text=text:upper(),TextColor3=T2.SectionText,Font=Enum.Font.GothamBold,TextSize=9,Parent=sf})
                        New("Frame",{Size=UDim2.new(1,0,0,1),BackgroundColor3=T2.SectionLine,BorderSizePixel=0,Parent=sf})
                    end

                    function subAPI:CreateToggle(c2)
                        local v2 = c2.CurrentValue or false
                        if c2.Flag then Flags[c2.Flag] = v2 end
                        local sf = SubBaseFrame(44)
                        local Inner2 = New("Frame",{Size=UDim2.new(1,-24,1,0),Position=UDim2.fromOffset(12,0),BackgroundTransparency=1,Parent=sf})
                        New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Padding=UDim.new(0,8),Parent=Inner2})
                        local IC2 = New("Frame",{Size=UDim2.new(1,-50,1,0),BackgroundTransparency=1,Parent=Inner2})
