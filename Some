local function readShopList(shopListFolder)
    local items={}
    pcall(function()
        for _,item in ipairs(shopListFolder:GetChildren()) do
            local name=item.Name
            if name=="" or name=="Template" or name=="UIListLayout" or name=="UIPadding" or name=="UIGridLayout" then continue end
            local stockTxt,priceTxt="?","?"
            pcall(function() stockTxt=item.Button.Stock.Text end)
            pcall(function() priceTxt=item.Button.Price.Amount.Text end)
            local stockNum=tostring(stockTxt):match("%d+") or "?"
            local label=name.."  |  Stock: "..stockNum.."  |  Price: "..priceTxt
            table.insert(items,{name=name,stockText=stockTxt,priceText=priceTxt,label=label})
        end
    end)
    table.sort(items,function(a,b) return a.name<b.name end)
    return items
end

local function getLiveShopInfo(shopListFolder,itemName)
    local s,p="?","?"
    pcall(function() s=shopListFolder[itemName].Button.Stock.Text end)
