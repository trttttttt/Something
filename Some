                    function subAPI:CreateSlider(c2)
                        local rng=c2.Range or {0,100}; local inc2=c2.Increment or 1
                        local suf=c2.Suffix or ""; local sv=math.clamp(c2.CurrentValue or rng[1],rng[1],rng[2])
                        if c2.Flag then Flags[c2.Flag]=sv end
                        local sf=SubBaseFrame(0)
                        New("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,11),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=sf})
                        New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,7),Parent=sf})
                        local TR=New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=sf})
                        New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=TR})
                        New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=c2.Name or "Slider",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=TR})
                        local VL=New("TextLabel",{Size=UDim2.fromOffset(55,18),BackgroundTransparency=1,Text=tostring(sv)..suf,TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=11,TextXAlignment=Enum.TextXAlignment.Right,Parent=TR})
                        local TBG=New("Frame",{Size=UDim2.new(1,0,0,5),BackgroundColor3=T2.SliderBg,BorderSizePixel=0,LayoutOrder=2,Parent=sf})
                        New("UICorner",{CornerRadius=UDim.new(0,3),Parent=TBG})
                        local pct2=(sv-rng[1])/(rng[2]-rng[1])
                        local Fil=New("Frame",{Size=UDim2.fromScale(pct2,1),BackgroundColor3=T2.SliderFill,BorderSizePixel=0,Parent=TBG})
                        New("UICorner",{CornerRadius=UDim.new(0,3),Parent=Fil})
                        local Kn=New("Frame",{Size=UDim2.fromOffset(15,15),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(pct2,0,0.5,0),BackgroundColor3=T2.SliderKnob,BorderSizePixel=0,Parent=TBG})
                        New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Kn})
                        local sl3=false
                        local function US(mx)
                            local p=math.clamp((mx-TBG.AbsolutePosition.X)/TBG.AbsoluteSize.X,0,1)
                            local raw=rng[1]+p*(rng[2]-rng[1])
                            local rd=math.clamp(math.floor(raw/inc2+0.5)*inc2,rng[1],rng[2])
                            sv=rd; local fp=(rd-rng[1])/(rng[2]-rng[1])
                            Fil.Size=UDim2.fromScale(fp,1); Kn.Position=UDim2.new(fp,0,0.5,0)
                            VL.Text=tostring(rd)..suf; if c2.Flag then Flags[c2.Flag]=rd end
                            if c2.Callback then pcall(c2.Callback,rd) end
                        end
                        TBG.InputBegan:Connect(function(i2) if i2.UserInputType==Enum.UserInputType.MouseButton1 then sl3=true; US(i2.Position.X) end end)
                        local sc1=UIS.InputChanged:Connect(function(i2) if sl3 and i2.UserInputType==Enum.UserInputType.MouseMovement then US(i2.Position.X) end end)
                        local sc2=UIS.InputEnded:Connect(function(i2) if i2.UserInputType==Enum.UserInputType.MouseButton1 then sl3=false end end)
                        table.insert(self._window._connections,sc1); table.insert(self._window._connections,sc2)
                    end

                    function subAPI:CreateLabel(text)
                        New("TextLabel",{Size=UDim2.new(1,0,0,28),BackgroundTransparency=1,Text=text,TextColor3=T2.TextDim,Font=Enum.Font.GothamBold,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,Parent=SubContent})
                    end

                    subEntry._api = subAPI

                    local function ActivateSub(entry)
                        for _, se in ipairs(subTabs) do
                            Tween(se._btn,{BackgroundColor3=T2.TabBg,BackgroundTransparency=1},0.15)
                            se._label.TextColor3 = T2.TabText
                            se._content.Visible = false
                        end
                        Tween(entry._btn,{BackgroundColor3=T2.Accent,BackgroundTransparency=0},0.15)
                        entry._label.TextColor3 = T2.AccentText
                        entry._content.Visible = true
                        activeSubTab = entry._name
                    end

                    SubBtn.MouseButton1Click:Connect(function() ActivateSub(subEntry) end)
                end

                -- Activate first subtab by default
                if #subTabs > 0 then
                    task.defer(function() 
                        local first = subTabs[1]
                        Tween(first._btn,{BackgroundColor3=T2.Accent,BackgroundTransparency=0},0.15)
                        first._label.TextColor3 = T2.AccentText
                        first._content.Visible = true
                        activeSubTab = first._name
                    end)
                end

                -- Return array of subAPIs in order
                local apis = {}
                for _, se in ipairs(subTabs) do
                    table.insert(apis, se._api)
                end
                return table.unpack(apis)
            end

            RegisterElement(cfg2.Name or "Dropdown", f)
            return {
                Refresh = function(newOpts, newCurrent)
                    opts = newOpts
                    if newCurrent then current = newCurrent; CurLabel.Text = newCurrent end
                    BuildList()
                end,
                GetValue = function() return current end,
            }
        end

        -- ── KEYBIND ────────────────────────────────────────
        function TabObj:CreateKeybind(cfg2)
            local key = self._window:LoadConfigValue(cfg2.Flag, cfg2.CurrentKeybind or "F")
            if cfg2.Flag then Flags[cfg2.Flag] = key end
            local listening = false

            local f = BaseFrame(44)
            local row = HRow(f)
            RowPad(f,12)
            local left = LeftInfo(row, cfg2.Name or "Keybind", cfg2.Description, cfg2.Icon)
            left.Size = UDim2.new(1,-72,1,0)  -- leave room for keybind button

            local KBtn = New("TextButton",{
                Size=UDim2.fromOffset(56,24),BackgroundColor3=T2.InputBg,BorderSizePixel=0,
                Text="["..tostring(key).."]",TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=10,
                AutoButtonColor=false,Parent=row,
            })
            New("UICorner",{CornerRadius=UDim.new(0,6),Parent=KBtn})
            New("UIStroke",{Color=T2.InputStroke,Thickness=1,Parent=KBtn})

            if cfg2.Flag then Flags[cfg2.Flag] = key end

            KBtn.MouseButton1Click:Connect(function()
                listening = true
                KBtn.Text = "[...]"
                KBtn.TextColor3 = T2.TextMuted
            end)

            local kconn = UIS.InputBegan:Connect(function(i, gp)
                if gp then return end
                if listening then
                    listening = false
                    key = i.KeyCode.Name
                    KBtn.Text = "["..key.."]"
                    KBtn.TextColor3 = T2.Accent
                    if cfg2.Flag then Flags[cfg2.Flag] = key end
                    self._window:SaveConfig()
                elseif i.KeyCode.Name == key then
                    if cfg2.Callback then pcall(cfg2.Callback) end
                end
            end)
            table.insert(self._window._connections, kconn)

            RegisterElement(cfg2.Name or "Keybind", f)
            return {
                SetValue = function(v)
                    key = v; KBtn.Text = "["..v.."]"
                    if cfg2.Flag then Flags[cfg2.Flag] = v end
                end,
                GetValue = function() return key end,
            }
        end

        -- ── COLOR PICKER ───────────────────────────────────
        function TabObj:CreateColorPicker(cfg2)
            local saved = self._window:LoadConfigValue(cfg2.Flag, nil)
            local color = saved or cfg2.Color or Color3.new(1,1,1)
            if cfg2.Flag then Flags[cfg2.Flag] = color end

            local f = BaseFrame(0)
            New("UIPadding",{PaddingTop=UDim.new(0,9),PaddingBottom=UDim.new(0,10),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=f})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,7),Parent=f})

            local TopRowC = New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=f})
            New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=TopRowC})
            if cfg2.Icon then New("ImageLabel",{Size=UDim2.fromOffset(13,13),BackgroundTransparency=1,Image=GetIcon(cfg2.Icon),ImageColor3=T2.TextDim,Parent=TopRowC}) end
            New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=cfg2.Name or "Color",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=TopRowC})
            local Preview = New("Frame",{Size=UDim2.fromOffset(22,22),BackgroundColor3=color,BorderSizePixel=0,Parent=TopRowC})
            New("UICorner",{CornerRadius=UDim.new(0,5),Parent=Preview})
            New("UIStroke",{Color=T2.ElementStroke,Thickness=1,Parent=Preview})

            local r, g, b = color.R, color.G, color.B

            local function UpdateColor()
                color = Color3.new(r, g, b)
                Preview.BackgroundColor3 = color
                if cfg2.Flag then Flags[cfg2.Flag] = color end
                if cfg2.Callback then pcall(cfg2.Callback, color) end
            end

            local function MakeChannel(lbl, getF, setF, lo)
                local row2 = New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=lo,Parent=f})
                New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Padding=UDim.new(0,6),Parent=row2})
                local lel = New("TextLabel",{Size=UDim2.fromOffset(10,18),BackgroundTransparency=1,Text=lbl,TextColor3=T2.TextDim,Font=Enum.Font.GothamBold,TextSize=10,Parent=row2})
                local bg2 = New("Frame",{Size=UDim2.new(1,-54,0,5),BackgroundColor3=T2.SliderBg,BorderSizePixel=0,Parent=row2})
                New("UICorner",{CornerRadius=UDim.new(0,3),Parent=bg2})
                local fill2 = New("Frame",{Size=UDim2.fromScale(getF(),1),BackgroundColor3=T2.SliderFill,BorderSizePixel=0,Parent=bg2})
                New("UICorner",{CornerRadius=UDim.new(0,3),Parent=fill2})
                local vlab = New("TextLabel",{Size=UDim2.fromOffset(30,18),BackgroundTransparency=1,Text=tostring(math.floor(getF()*255)),TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=10,TextXAlignment=Enum.TextXAlignment.Right,Parent=row2})
                local sl2 = false
                bg2.InputBegan:Connect(function(i2)
                    if i2.UserInputType==Enum.UserInputType.MouseButton1 or i2.UserInputType==Enum.UserInputType.Touch then
                        sl2=true
                        local p=math.clamp((i2.Position.X-bg2.AbsolutePosition.X)/bg2.AbsoluteSize.X,0,1)
                        fill2.Size=UDim2.fromScale(p,1); vlab.Text=tostring(math.floor(p*255))
                        setF(p); UpdateColor()
                    end
                end)
                local slconn = UIS.InputChanged:Connect(function(i2)
                    if sl2 and (i2.UserInputType==Enum.UserInputType.MouseMovement or i2.UserInputType==Enum.UserInputType.Touch) then
                        local p=math.clamp((i2.Position.X-bg2.AbsolutePosition.X)/bg2.AbsoluteSize.X,0,1)
                        fill2.Size=UDim2.fromScale(p,1); vlab.Text=tostring(math.floor(p*255))
                        setF(p); UpdateColor()
                    end
                end)
                local endconn = UIS.InputEnded:Connect(function(i2)
                    if i2.UserInputType==Enum.UserInputType.MouseButton1 or i2.UserInputType==Enum.UserInputType.Touch then
                        if sl2 then sl2=false; self._window:SaveConfig() end
                    end
                end)
                table.insert(self._window._connections, slconn)
                table.insert(self._window._connections, endconn)
            end

            MakeChannel("R", function() return r end, function(v) r=v end, 2)
            MakeChannel("G", function() return g end, function(v) g=v end, 3)
            MakeChannel("B", function() return b end, function(v) b=v end, 4)

            RegisterElement(cfg2.Name or "ColorPicker", f)
            return {
                SetValue = function(c)
                    color=c; r=c.R; g=c.G; b=c.B
                    Preview.BackgroundColor3=c
                    if cfg2.Flag then Flags[cfg2.Flag]=c end
                end,
                GetValue = function() return color end,
            }
        end

        return TabObj
    end -- CreateTab

