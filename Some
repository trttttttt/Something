local function getHRP()
    local c = lp.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function parseNumber(val)
    local s = tostring(val):gsub(",",""):lower()
    local num, suffix = s:match("^([%d%.]+)([kmb]?)$")
    if not num then return 0 end
    num = tonumber(num) or 0
    if suffix=="k" then num=num*1000
    elseif suffix=="m" then num=num*1000000
    elseif suffix=="b" then num=num*1000000000 end
    return math.floor(num)
end

local function getPlayerGems()
    local ls = lp:FindFirstChild("leaderstats")
    if ls then
        local gems = ls:FindFirstChild("Gems")
        if gems then return parseNumber(gems.Value) end
    end
    return 0
end

local function getEggCost(starName)
    local ok, val = pcall(function()
        return workspace.Stars[starName].Star.Primary.StarGui.Gems.Amount.Text
    end)
    if ok and val then return parseNumber(val) end
    return 0
end

local function teleportToStar(starName)
    local hrp = getHRP()
    local ok, cube = pcall(function() return workspace.Stars[starName].Cube end)
    if hrp and ok and cube then hrp.CFrame = CFrame.new(cube.Position) * CFrame.new(5,0,0) end
end

local function isNearStar(starName)
    local hrp = getHRP()
    local ok, cube = pcall(function() return workspace.Stars[starName].Cube end)
    if hrp and ok and cube then return (hrp.Position-cube.Position).Magnitude<=10 end
    return false
end

local function teleportToMob(mob)
    local hrp = getHRP()
    local mobHRP = mob:FindFirstChild("HumanoidRootPart")
    if hrp and mobHRP then hrp.CFrame = mobHRP.CFrame * CFrame.new(5,0,0) end
end

local function getService(name)
    return ReplicatedStorage.Packages._Index
        :FindFirstChild("sleitnick_knit@1.5.1").knit.Services[name]
end

local function getBalanceModule()
    return ReplicatedStorage.Packages._Index
        :FindFirstChild("sleitnick_knit@1.5.1").knit.Library.Balance
end

local function spamClickKill(mob, hum, activeRef)
    local dead = false
    local c1,c2,c3
    local function markDead() dead=true end
    c1=hum.Died:Connect(markDead)
    c2=hum:GetPropertyChangedSignal("Health"):Connect(function()
        if hum.Health<=0 then markDead() end
    end)
    c3=mob.AncestryChanged:Connect(function(_,p)
        if not p then markDead() end
    end)
    while not dead do
        if not activeRef() then break end
        local hrp=getHRP()
        local mobHRP=mob:FindFirstChild("HumanoidRootPart")
        if hrp and mobHRP and (hrp.Position-mobHRP.Position).Magnitude>8 then
            hrp.CFrame=mobHRP.CFrame*CFrame.new(3,0,0)
        end
        pcall(function() getService("ClickService").RF.Click:InvokeServer() end)
        task.wait(0.05)
    end
    pcall(function() c1:Disconnect() c2:Disconnect() c3:Disconnect() end)
end

local function findNearestMob(nameFilter)
    local hrp=getHRP()
    if not hrp then return nil,nil end
    local bestMob,bestHum,bestDist=nil,nil,math.huge
    local filterSet=nil
    if nameFilter and #nameFilter>0 then
        filterSet={}
        for _,n in ipairs(nameFilter) do filterSet[n]=true end
    end
    local function checkFolder(folder)
        if not folder then return end
        for _,mob in ipairs(folder:GetChildren()) do
            local hum=mob:FindFirstChildOfClass("Humanoid")
            local mobHRP=mob:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health>0 and mobHRP then
                if filterSet then
                    local ok,txt=pcall(function()
                        return mob.HumanoidRootPart.EnemyOverhead.Enemy.Text
                    end)
                    local stripped=ok and txt and txt:gsub("^Defeat%s+","") or ""
                    if not (filterSet[txt] or filterSet[stripped]) then continue end
                end
                local dist=(hrp.Position-mobHRP.Position).Magnitude
                if dist<bestDist then bestDist=dist bestMob=mob bestHum=hum end
            end
        end
    end
    checkFolder(workspace:FindFirstChild("Mobs"))
    local area=lp:GetAttribute("Area")
    if area then
        local maps=workspace:FindFirstChild("Maps")
        if maps then
            local af=maps:FindFirstChild(area)
            if af then checkFolder(af:FindFirstChild("Mobs")) checkFolder(af:FindFirstChild("Enemies")) end
        end
        local gm=ReplicatedStorage:FindFirstChild("Gamemodes")
        if gm then
            for _,gmf in ipairs(gm:GetChildren()) do
                local inst=gmf:FindFirstChild(area)
                if inst then checkFolder(inst:FindFirstChild("Mobs")) checkFolder(inst:FindFirstChild("Enemies")) end
            end
        end
    end
    return bestMob,bestHum
end

