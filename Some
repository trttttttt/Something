    -- ── SAVE CONFIG ──────────────────────────────────────────
    function Window:SaveConfig()
        if not self._cfgFolderOk then return end
        local data = {}
        for flag, val in pairs(Flags) do
            -- Only save serializable types
            local t = type(val)
            if t == "boolean" or t == "number" or t == "string" then
                data[flag] = val
            elseif t == "userdata" and typeof(val) == "Color3" then
                data[flag] = {r=val.R, g=val.G, b=val.B}
            end
        end
        local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
        if ok then
            pcall(function()
                if not FolderExists(self._cfgFolder) then MakeFolder(self._cfgFolder) end
                WriteFile(self._cfgPath, encoded)
            end)
        end
    end

    function Window:LoadConfigValue(flag, default)
        if self._savedCfg and self._savedCfg[flag] ~= nil then
            local v = self._savedCfg[flag]
            if type(v) == "table" and v.r ~= nil then
                return Color3.new(v.r, v.g, v.b)
            end
            return v
        end
        return default
    end

