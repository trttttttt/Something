  QUICK START:
  ─────────────────────────────────────────────────
  local Nexus = loadstring(game:HttpGet("RAW_URL"))()

  local Win = Nexus:CreateWindow({
      Title        = "My Hub",
      SubTitle     = "Universal",
      Theme        = "Cyan",          -- see Themes below
      ConfigFolder = "MyHubConfigs",  -- folder name to save configs
      Icon         = "zap",           -- icon name OR asset ID number
      Size         = UDim2.fromOffset(600, 480),
      DisableRayfieldPrompts = false,
  })

  local Tab = Win:CreateTab("Combat", "sword")

  Tab:CreateSection("Aimbot")

  Tab:CreateToggle({
      Name = "Silent Aim", CurrentValue = false,
      Flag = "SilentAim",
      Callback = function(v) print(v) end,
  })

  Tab:CreateSlider({
      Name = "FOV", Range = {1, 360}, Increment = 1,
      CurrentValue = 90, Suffix = "°",
      Flag = "FOV",
      Callback = function(v) end,
  })

  Tab:CreateButton({
      Name = "Kill All", Icon = "skull",
      Callback = function() end,
  })

  Tab:CreateDropdown({
      Name = "Hit Part", Icon = "crosshair",
      Options = {"Head","Torso","HumanoidRootPart"},
      CurrentOption = "Head",
      Flag = "HitPart",
      Callback = function(v) end,
  })

  Tab:CreateInput({
      Name = "Target Name", PlaceholderText = "Player...",
      Flag = "TargetName",
      Callback = function(v) end,
  })

  Tab:CreateKeybind({
      Name = "Toggle Aim", CurrentKeybind = "F",
      Flag = "AimKey",
      Callback = function() end,
  })

  Tab:CreateColorPicker({
      Name = "ESP Color",
      Color = Color3.fromRGB(255, 0, 0),
      Flag = "ESPColor",
      Callback = function(c) end,
  })

  Win:Notify({
      Title = "Loaded!", Content = "Hub is ready.",
      Duration = 4, Icon = "check",
  })

