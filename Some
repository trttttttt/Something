            New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=cfg2.Name or "Input",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=TopRow2})

            local IBg = New("Frame",{Size=UDim2.new(1,0,0,28),BackgroundColor3=T2.InputBg,BorderSizePixel=0,LayoutOrder=2,Parent=f})
