                        if not area2:find("DemonDefense_") then
                            pcall(function() getService("DemonDefenseService").RF.StartDefense:InvokeServer(selectedDefDiff,defMaxWave) end)
                        end
                    end
                    task.wait(3)
                end
            end)
        else
            defAutoJoinActive=false
            if defAutoJoinThread then task.cancel(defAutoJoinThread) defAutoJoinThread=nil end
        end
    end,
})
