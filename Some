                New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=cfg2.Name or "Toggle",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=tr})
            else
                New("TextLabel",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Text=cfg2.Name or "Toggle",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=1,Parent=InfoCol})
            end
            if cfg2.Description and cfg2.Description ~= "" then
                New("TextLabel",{Size=UDim2.new(1,0,0,13),BackgroundTransparency=1,Text=cfg2.Description,TextColor3=T2.TextMuted,Font=Enum.Font.Gotham,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=2,Parent=InfoCol})
            end

            -- Track (always 42px wide, fixed)
            local Track = New("Frame",{Size=UDim2.fromOffset(42,22),BackgroundColor3=val and T2.ToggleOn or T2.ToggleBg,BorderSizePixel=0,Parent=Inner})
            New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Track})
            local TStroke = New("UIStroke",{Color=val and T2.ToggleOn or T2.ElementStroke,Thickness=1,Parent=Track})
            local Knob = New("Frame",{
                Size=UDim2.fromOffset(16,16),
                Position=val and UDim2.fromOffset(23,3) or UDim2.fromOffset(3,3),
                BackgroundColor3=val and T2.ToggleKnobOn or T2.ToggleKnobOff,
                BorderSizePixel=0,Parent=Track,
            })
            New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Knob})

            local function SetVal(v, save)
                val = v
                if cfg2.Flag then Flags[cfg2.Flag] = v end
                Tween(Track, {BackgroundColor3 = v and T2.ToggleOn or T2.ToggleBg}, 0.22)
                Tween(Knob, {
                    Position = v and UDim2.fromOffset(23,3) or UDim2.fromOffset(3,3),
                    BackgroundColor3 = v and T2.ToggleKnobOn or T2.ToggleKnobOff,
                }, 0.22, Enum.EasingStyle.Back)
                TStroke.Color = v and T2.ToggleOn or T2.ElementStroke
                if cfg2.Callback then pcall(cfg2.Callback, v) end
                if save ~= false then self._window:SaveConfig() end
            end

            -- Invisible TextButton overlay — ONLY way to reliably capture clicks inside ScrollingFrame
            local ClickBtn = New("TextButton",{
                Size=UDim2.fromScale(1,1),BackgroundTransparency=1,
                Text="",ZIndex=5,Parent=f,
            })
            ClickBtn.MouseButton1Click:Connect(function() SetVal(not val) end)
            -- Hover effect
            ClickBtn.MouseEnter:Connect(function() Tween(f,{BackgroundColor3=T2.ElementBgHover},0.15) end)
            ClickBtn.MouseLeave:Connect(function() Tween(f,{BackgroundColor3=T2.ElementBg},0.15) end)

            RegisterElement(cfg2.Name or "Toggle", f)
            return {SetValue=SetVal, GetValue=function() return val end}
        end

        -- ── SLIDER ─────────────────────────────────────────
        function TabObj:CreateSlider(cfg2)
            local range   = cfg2.Range or {0, 100}
            local inc     = cfg2.Increment or 1
            local suffix  = cfg2.Suffix or ""
            local val     = self._window:LoadConfigValue(cfg2.Flag, cfg2.CurrentValue or range[1])
            val = math.clamp(val, range[1], range[2])
            if cfg2.Flag then Flags[cfg2.Flag] = val end

            local f = BaseFrame(0)
            New("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,11),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=f})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,7),Parent=f})

            -- Top row
            local TopRow = New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=f})
            New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=TopRow})
            if cfg2.Icon then
                New("ImageLabel",{Size=UDim2.fromOffset(14,14),BackgroundTransparency=1,Image=GetIcon(cfg2.Icon),ImageColor3=T2.TextDim,Parent=TopRow})
            end
            New("TextLabel",{Size=UDim2.new(1,-65,1,0),BackgroundTransparency=1,Text=cfg2.Name or "Slider",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=TopRow})
            local ValLabel = New("TextLabel",{Size=UDim2.fromOffset(62,18),BackgroundTransparency=1,Text=tostring(val)..suffix,TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=11,TextXAlignment=Enum.TextXAlignment.Right,Parent=TopRow})

            if cfg2.Description then
                New("TextLabel",{Size=UDim2.new(1,0,0,13),BackgroundTransparency=1,Text=cfg2.Description,TextColor3=T2.TextMuted,Font=Enum.Font.Gotham,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=2,Parent=f})
            end

            -- Track
            local TrackBG = New("Frame",{Size=UDim2.new(1,0,0,5),BackgroundColor3=T2.SliderBg,BorderSizePixel=0,LayoutOrder=cfg2.Description and 3 or 2,Parent=f})
            New("UICorner",{CornerRadius=UDim.new(0,3),Parent=TrackBG})
            local pct = (val - range[1]) / (range[2] - range[1])
            local Fill = New("Frame",{Size=UDim2.fromScale(pct,1),BackgroundColor3=T2.SliderFill,BorderSizePixel=0,Parent=TrackBG})
            New("UICorner",{CornerRadius=UDim.new(0,3),Parent=Fill})
            New("UIGradient",{Color=ColorSequence.new{ColorSequenceKeypoint.new(0,T2.SliderFill),ColorSequenceKeypoint.new(1,T2.SliderBg)},Rotation=90,Transparency=NumberSequence.new{NumberSequenceKeypoint.new(0,0.5),NumberSequenceKeypoint.new(1,0)},Parent=Fill})
            local Knob = New("Frame",{
                Size=UDim2.fromOffset(15,15),AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new(pct,0,0.5,0),
                BackgroundColor3=T2.SliderKnob,BorderSizePixel=0,Parent=TrackBG,
            })
            New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Knob})
            New("UIStroke",{Color=Color3.new(0,0,0),Thickness=1.5,Transparency=0.6,Parent=Knob})

            if cfg2.Flag then Flags[cfg2.Flag] = val end

            local sliding = false
            local function UpdateSlider(mx)
                local abs = TrackBG.AbsolutePosition
                local sz  = TrackBG.AbsoluteSize
                local p   = math.clamp((mx - abs.X) / sz.X, 0, 1)
                local raw = range[1] + p * (range[2] - range[1])
                -- Round to increment
                local rounded = math.floor(raw / inc + 0.5) * inc
                rounded = math.clamp(rounded, range[1], range[2])
                val = rounded
                local fp = (rounded - range[1]) / (range[2] - range[1])
                Fill.Size = UDim2.fromScale(fp, 1)
                Knob.Position = UDim2.new(fp, 0, 0.5, 0)
                ValLabel.Text = tostring(rounded)..suffix
                if cfg2.Flag then Flags[cfg2.Flag] = rounded end
                if cfg2.Callback then pcall(cfg2.Callback, rounded) end
            end

            TrackBG.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    sliding = true; UpdateSlider(i.Position.X)
                end
            end)
            local uis_conn = UIS.InputChanged:Connect(function(i)
                if sliding and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider(i.Position.X)
                end
            end)
            local uis_end = UIS.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    if sliding then
                        sliding = false
                        self._window:SaveConfig()
                    end
                end
            end)
            table.insert(self._window._connections, uis_conn)
            table.insert(self._window._connections, uis_end)

            RegisterElement(cfg2.Name or "Slider", f)
            return {
                SetValue = function(v)
                    val = math.clamp(v, range[1], range[2])
                    local fp2 = (val-range[1])/(range[2]-range[1])
                    Fill.Size=UDim2.fromScale(fp2,1)
                    Knob.Position=UDim2.new(fp2,0,0.5,0)
                    ValLabel.Text=tostring(val)..suffix
                    if cfg2.Flag then Flags[cfg2.Flag]=val end
                end,
                GetValue = function() return val end,
            }
        end

        -- ── INPUT ──────────────────────────────────────────
        function TabObj:CreateInput(cfg2)
