    New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,7),Parent=bgOpacityF})
    local bgTopRow = New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=bgOpacityF})
    New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=bgTopRow})
    New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="Background Opacity",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=bgTopRow})
    local bgValLabel = New("TextLabel",{Size=UDim2.fromOffset(40,18),BackgroundTransparency=1,Text="100%",TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=11,TextXAlignment=Enum.TextXAlignment.Right,Parent=bgTopRow})
    local bgTrack = New("Frame",{Size=UDim2.new(1,0,0,5),BackgroundColor3=T2.SliderBg,BorderSizePixel=0,LayoutOrder=2,Parent=bgOpacityF})
    New("UICorner",{CornerRadius=UDim.new(0,3),Parent=bgTrack})
    local bgFill = New("Frame",{Size=UDim2.fromScale(1,1),BackgroundColor3=T2.SliderFill,BorderSizePixel=0,Parent=bgTrack})
    New("UICorner",{CornerRadius=UDim.new(0,3),Parent=bgFill})
    local bgKnob = New("Frame",{Size=UDim2.fromOffset(15,15),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(1,0,0.5,0),BackgroundColor3=T2.SliderKnob,BorderSizePixel=0,Parent=bgTrack})
    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=bgKnob})
    New("UIStroke",{Color=Color3.new(0,0,0),Thickness=1.5,Transparency=0.6,Parent=bgKnob})
    local bgSliding = false
    local function UpdateBgOpacity(mx)
        local abs = bgTrack.AbsolutePosition
        local sz  = bgTrack.AbsoluteSize
        local p   = math.clamp((mx - abs.X)/sz.X, 0, 1)
        bgFill.Size = UDim2.fromScale(p,1)
        bgKnob.Position = UDim2.new(p,0,0.5,0)
        bgValLabel.Text = tostring(math.floor(p*100)).."%"
        local transp = 1 - p
        Tween(Main,{BackgroundTransparency=transp},0.1)
        -- Also tween all direct bg frames
        pcall(function()
            for _, v in ipairs(Main:GetChildren()) do
                if v:IsA("Frame") and v.Name ~= "Shadow" then
                    Tween(v,{BackgroundTransparency=transp},0.1)
                end
            end
        end)
    end
    bgTrack.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            bgSliding = true; UpdateBgOpacity(i.Position.X)
        end
    end)
    local bgConn1 = UIS.InputChanged:Connect(function(i)
        if bgSliding and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            UpdateBgOpacity(i.Position.X)
        end
    end)
    local bgConn2 = UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            bgSliding = false
        end
    end)
    table.insert(Window._connections, bgConn1)
    table.insert(Window._connections, bgConn2)

    -- Background Blur Toggle + Amount
    local blurEnabled = false
    local blurEffect = nil
    pcall(function()
        local Lighting = game:GetService("Lighting")
        blurEffect = Lighting:FindFirstChildOfClass("BlurEffect")
        if not blurEffect then
            blurEffect = Instance.new("BlurEffect")
            blurEffect.Size = 0
            blurEffect.Parent = Lighting
        end
    end)

    SToggle("Background Blur", false, function(v)
        blurEnabled = v
        pcall(function()
            if blurEffect then
                Tween(blurEffect, {Size = v and 10 or 0}, 0.3)
            end
        end)
    end)

    -- Blur Intensity Slider
    local blurF = SBaseFrame(0)
    New("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,11),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=blurF})
    New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,7),Parent=blurF})
    local blurTopRow = New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=blurF})
    New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=blurTopRow})
    New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="Blur Intensity",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=blurTopRow})
    local blurValLabel = New("TextLabel",{Size=UDim2.fromOffset(30,18),BackgroundTransparency=1,Text="10",TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=11,TextXAlignment=Enum.TextXAlignment.Right,Parent=blurTopRow})
    local blurTrack = New("Frame",{Size=UDim2.new(1,0,0,5),BackgroundColor3=T2.SliderBg,BorderSizePixel=0,LayoutOrder=2,Parent=blurF})
    New("UICorner",{CornerRadius=UDim.new(0,3),Parent=blurTrack})
    local blurFill = New("Frame",{Size=UDim2.fromScale(0.2,1),BackgroundColor3=T2.SliderFill,BorderSizePixel=0,Parent=blurTrack})
    New("UICorner",{CornerRadius=UDim.new(0,3),Parent=blurFill})
    local blurKnob = New("Frame",{Size=UDim2.fromOffset(15,15),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.2,0,0.5,0),BackgroundColor3=T2.SliderKnob,BorderSizePixel=0,Parent=blurTrack})
    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=blurKnob})
    New("UIStroke",{Color=Color3.new(0,0,0),Thickness=1.5,Transparency=0.6,Parent=blurKnob})
    local blurSliding = false
    local function UpdateBlur(mx)
        local abs = blurTrack.AbsolutePosition
        local sz  = blurTrack.AbsoluteSize
        local p   = math.clamp((mx - abs.X)/sz.X, 0, 1)
        blurFill.Size = UDim2.fromScale(p,1)
        blurKnob.Position = UDim2.new(p,0,0.5,0)
        local blurAmt = math.floor(p * 56)
        blurValLabel.Text = tostring(blurAmt)
        pcall(function()
            if blurEffect and blurEnabled then
                blurEffect.Size = blurAmt
            end
        end)
    end
    blurTrack.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            blurSliding = true; UpdateBlur(i.Position.X)
        end
    end)
    local blurConn1 = UIS.InputChanged:Connect(function(i)
        if blurSliding and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            UpdateBlur(i.Position.X)
        end
    end)
    local blurConn2 = UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            blurSliding = false
        end
    end)
    table.insert(Window._connections, blurConn1)
    table.insert(Window._connections, blurConn2)

    SSection("Game")

    -- Anti AFK
    local afkConn
    SToggle("Anti AFK", false, function(v)
        if afkConn then afkConn:Disconnect(); afkConn=nil end
        if v then
            pcall(function()
                local VU = game:GetService("VirtualUser")
                afkConn = LocalPlayer.Idled:Connect(function()
                    VU:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                    task.wait(1)
                    VU:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                end)
            end)
        end
    end)

    -- Live theme apply helper — retweens all accent/background colours
    local function ApplyTheme(newThemeName)
        local NT = Themes[newThemeName]
        if not NT then return end
        ThemeName = newThemeName
        T2 = NT -- update local T2 reference

        -- Structural frames
        Tween(Main,         {BackgroundColor3=NT.Background}, 0.25)
        Tween(Topbar,       {BackgroundColor3=NT.Topbar},     0.25)
        Tween(Sidebar,      {BackgroundColor3=NT.Topbar},     0.25)
        Tween(ContentHost,  {BackgroundColor3=NT.Background}, 0.25)

        -- Topbar gradient
        pcall(function()
            local g = Topbar:FindFirstChildOfClass("UIGradient")
            if g then g.Color = ColorSequence.new{ColorSequenceKeypoint.new(0,NT.Accent),ColorSequenceKeypoint.new(1,NT.AccentDark)} end
        end)

        -- All tab buttons
        for _, tb in ipairs(Window._tabs) do
            local isActive = Window._activeTab == tb._name
            Tween(tb._btn, {BackgroundColor3=NT.TabBg}, 0.2)
            tb._label.TextColor3 = isActive and NT.Accent or NT.TabText
            if tb._ico then tb._ico.ImageColor3 = isActive and NT.Accent or NT.TabText end
            tb._bar.BackgroundColor3 = NT.Accent
        end

        -- All element frames — retween bg colour
        for _, el in ipairs(Window._allElements) do
            if el.frame and el.frame.Parent then
                pcall(function()
                    if el.frame:IsA("Frame") then
                        Tween(el.frame, {BackgroundColor3=NT.ElementBg}, 0.2)
                    end
                end)
            end
        end

        -- Scrollbars
        pcall(function()
            for _, sf in ipairs({TabScroll, SettingsContent}) do
                if sf then sf.ScrollBarImageColor3 = NT.ScrollBar end
            end
        end)

        Window:Notify({Title="Theme: "..newThemeName, Content="Applied instantly!", Duration=3, Icon="sun"})
    end

    SSection("Theme")

    -- Theme selector
    local themeNames = {}
    for k in pairs(Themes) do table.insert(themeNames, k) end
    table.sort(themeNames)

    local TF = SBaseFrame(0)
    New("UIPadding",{PaddingTop=UDim.new(0,9),PaddingBottom=UDim.new(0,10),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=TF})
    New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,8),Parent=TF})
    New("TextLabel",{Size=UDim2.new(1,0,0,16),BackgroundTransparency=1,Text="Select Theme (Live Apply)",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=1,Parent=TF})
    local ThemeGrid = New("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,LayoutOrder=2,Parent=TF})
    New("UIGridLayout",{CellSize=UDim2.fromOffset(28,28),CellPadding=UDim2.fromOffset(6,6),SortOrder=Enum.SortOrder.LayoutOrder,Parent=ThemeGrid})
    local themeColors = {Cyan=Color3.fromRGB(0,224,255),Neon=Color3.fromRGB(57,255,20),Cobalt=Color3.fromRGB(0,120,255),Amethyst=Color3.fromRGB(168,85,247),Crimson=Color3.fromRGB(220,38,70),Carbon=Color3.fromRGB(200,200,200),Sakura=Color3.fromRGB(255,105,180),Gold=Color3.fromRGB(255,200,0),Forest=Color3.fromRGB(34,197,94),Arctic=Color3.fromRGB(147,210,255)}
    local themeSwatches = {}
    for _, tn in ipairs(themeNames) do
        local sw = New("TextButton",{Size=UDim2.fromOffset(28,28),BackgroundColor3=themeColors[tn] or Color3.new(1,1,1),BorderSizePixel=0,Text="",AutoButtonColor=false,Parent=ThemeGrid})
        New("UICorner",{CornerRadius=UDim.new(1,0),Parent=sw})
        local swStroke = New("UIStroke",{Color=Color3.new(1,1,1),Thickness=tn==ThemeName and 2.5 or 0,Parent=sw})
        themeSwatches[tn] = swStroke
        -- Tooltip label
        local tip = New("TextLabel",{
            Size=UDim2.fromOffset(70,18),AnchorPoint=Vector2.new(0.5,1),
            Position=UDim2.new(0.5,0,0,-4),BackgroundColor3=Color3.fromRGB(20,20,20),
            BorderSizePixel=0,Text=tn,TextColor3=Color3.new(1,1,1),
            Font=Enum.Font.Gotham,TextSize=9,Visible=false,ZIndex=99,Parent=sw,
        })
        New("UICorner",{CornerRadius=UDim.new(0,4),Parent=tip})
        sw.MouseEnter:Connect(function() tip.Visible = true; Tween(sw,{Size=UDim2.fromOffset(32,32)},0.1) end)
        sw.MouseLeave:Connect(function() tip.Visible = false; Tween(sw,{Size=UDim2.fromOffset(28,28)},0.1) end)
        sw.MouseButton1Click:Connect(function()
            -- Clear all stroke outlines
            for _, ts in pairs(themeSwatches) do ts.Thickness = 0 end
            swStroke.Thickness = 2.5
            ApplyTheme(tn)
        end)
    end

    SSection("Config")

    -- Save config button
    local SaveF = SBaseFrame(44)
    New("UIPadding",{PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=SaveF})
    New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=SaveF})
    New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="Save Config",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=SaveF})
    local SBtn = New("TextButton",{Size=UDim2.fromOffset(70,26),BackgroundColor3=T2.Accent,BorderSizePixel=0,Text="Save",TextColor3=T2.AccentText,Font=Enum.Font.GothamBold,TextSize=11,AutoButtonColor=false,Parent=SaveF})
    New("UICorner",{CornerRadius=UDim.new(0,6),Parent=SBtn})
    SBtn.MouseButton1Click:Connect(function()
        Window:SaveConfig()
        Window:Notify({Title="Config Saved",Content="Saved to "..cfgPath,Duration=3,Icon="save"})
    end)

    -- Version info
    local VF = SBaseFrame(36)
    New("UIPadding",{PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=VF})
    New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=VF})
    New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="NexusLib Version",TextColor3=T2.TextDim,Font=Enum.Font.Gotham,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,Parent=VF})
    New("TextLabel",{Size=UDim2.fromOffset(80,36),BackgroundTransparency=1,Text="v"..VERSION,TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=11,TextXAlignment=Enum.TextXAlignment.Right,Parent=VF})

    -- Destroy
    local DF = SBaseFrame(44)
    New("UIPadding",{PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=DF})
    New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=DF})
    New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="Destroy UI",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=DF})
    local DBtn = New("TextButton",{Size=UDim2.fromOffset(70,26),BackgroundColor3=Color3.fromRGB(180,30,30),BorderSizePixel=0,Text="Destroy",TextColor3=Color3.new(1,1,1),Font=Enum.Font.GothamBold,TextSize=11,AutoButtonColor=false,Parent=DF})
    New("UICorner",{CornerRadius=UDim.new(0,6),Parent=DBtn})
    DBtn.MouseButton1Click:Connect(function()
        Window:Destroy()
    end)

    -- ── WINDOW DESTROY ──────────────────────────────────────
    function Window:Destroy()
        for _, c in ipairs(self._connections) do pcall(function() c:Disconnect() end) end
        if afkConn then pcall(function() afkConn:Disconnect() end) end
        TweenService:Create(self._main, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size=UDim2.fromOffset(0,0)}):Play()
        task.delay(0.35, function() pcall(function() self._screenGui:Destroy() end) end)
    end

    -- Initial notification
    task.delay(1.8, function()
        Window:Notify({
            Title = Title.." Loaded",
            Content = "NexusLib v"..VERSION.." ready. "..tostring(#Window._tabs).." tab(s).",
            Duration = 4,
            Icon = "check",
        })
    end)

    return Window
end

return NexusLib
