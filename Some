local MobTab = Win:CreateTab("Mob Farm", "sword")
local selectedMob = ""   -- single mob name (string)
local farmActive=false
local farmThread=nil
local eggActive=false

local function getMobNames()
    local result,seen={},{}
    local folder=workspace:FindFirstChild("Mobs")
    if not folder then return {"No Mobs Found"} end
    for _,mob in ipairs(folder:GetChildren()) do
        local ok,name=pcall(function() return mob.HumanoidRootPart.EnemyOverhead.Enemy.Text end)
        if ok and name and name~="" and not seen[name] then
            seen[name]=true
            table.insert(result,name)
        end
    end
    return #result>0 and result or {"No Mobs Found"}
end

local function startFarmThread()
    if farmThread then task.cancel(farmThread) farmThread=nil end
    farmThread=task.spawn(function()
        while farmActive do
            if selectedMob=="" or selectedMob=="No Mobs Found" then task.wait(0.5) continue end
            local mob,hum=findNearestMob({selectedMob})
            if mob and hum then
                teleportToMob(mob)
                spamClickKill(mob,hum,function() return farmActive and selectedMob~="" and not eggActive end)
                task.wait(0.2)
            else task.wait(0.2) end
        end
    end)
end

local function stopFarm()
    farmActive=false
    if farmThread then task.cancel(farmThread) farmThread=nil end
end

local MobDropdown
