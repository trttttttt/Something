        local ClickBtn2 = New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",ZIndex=5,Parent=f})
        ClickBtn2.MouseButton1Click:Connect(function() Set(not v) end)
        ClickBtn2.MouseEnter:Connect(function() Tween(f,{BackgroundColor3=T2.ElementBgHover},0.15) end)
        ClickBtn2.MouseLeave:Connect(function() Tween(f,{BackgroundColor3=T2.ElementBg},0.15) end)
        return Set
    end
    local function SKeybind(name, defKey, cb)
        local key = defKey
        local listening2 = false
        local f = SBaseFrame(44)
        New("UIPadding",{PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=f})
        New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=f})
        New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=name,TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
        local KB = New("TextButton",{Size=UDim2.fromOffset(56,24),BackgroundColor3=T2.InputBg,BorderSizePixel=0,Text="["..key.."]",TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=10,AutoButtonColor=false,Parent=f})
        New("UICorner",{CornerRadius=UDim.new(0,6),Parent=KB})
        New("UIStroke",{Color=T2.InputStroke,Thickness=1,Parent=KB})
        KB.MouseButton1Click:Connect(function() listening2=true; KB.Text="[...]"; KB.TextColor3=T2.TextMuted end)
        local kc2 = UIS.InputBegan:Connect(function(i,gp)
            if gp then return end
            if listening2 then
                listening2=false; key=i.KeyCode.Name; KB.Text="["..key.."]"; KB.TextColor3=T2.Accent
            elseif i.KeyCode.Name==key then
                if cb then pcall(cb) end
            end
        end)
        table.insert(Window._connections, kc2)
        return function() return key end
    end

    -- ── SETTINGS CONTENT BUILDER ──────────────────────────
    SSection("UI Controls")

    -- Toggle UI keybind
    SKeybind("Toggle UI Keybind", "RightShift", function()
        Main.Visible = not Main.Visible
        if Main.Visible and Main.Size == UDim2.fromOffset(0,0) then
            TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size=Size}):Play()
