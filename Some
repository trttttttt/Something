local function Tween(obj, props, t, style, dir)
    if not obj or not obj.Parent then return end
    return TweenService:Create(
        obj,
        TweenInfo.new(t or 0.22, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
        props
    ):Play()
end

local function New(class, props, children)
    local obj = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then
            local ok, err = pcall(function() obj[k] = v end)
            if not ok then warn("NexusLib | Property error "..k..": "..tostring(err)) end
        end
    end
    for _, child in ipairs(children or {}) do
        child.Parent = obj
    end
    if props and props.Parent then obj.Parent = props.Parent end
    return obj
end

local function MakeDraggable(handle, frame, onlyPosition)
    local dragging, rel = false, nil
    local inset = Vector2.zero
    pcall(function()
        if GuiService then inset = GuiService:GetGuiInset() end
    end)
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            rel = frame.AbsolutePosition + frame.AbsoluteSize * frame.AnchorPoint - UIS:GetMouseLocation()
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            local mp = UIS:GetMouseLocation() + inset
            frame.Position = UDim2.fromOffset(
                math.clamp((mp + rel).X, 0, workspace.CurrentCamera.ViewportSize.X - frame.AbsoluteSize.X),
                math.clamp((mp + rel).Y, 0, workspace.CurrentCamera.ViewportSize.Y - frame.AbsoluteSize.Y)
            )
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

-- Filesystem helpers
local function SafeCall(fn, ...)
    if fn then
        local ok, r = pcall(fn, ...)
        return ok and r or nil
    end
end
local function FolderExists(p) return SafeCall(isfolder, p) end
local function FileExists(p)   return SafeCall(isfile, p) end
local function MakeFolder(p)   SafeCall(makefolder, p) end
local function ReadFile(p)     return SafeCall(readfile, p) end
local function WriteFile(p,d)  SafeCall(writefile, p, d) end

