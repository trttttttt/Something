-- Combined Farm Loop (Ocean priority over Mob Farm)
local function FindOceanTarget()
    local oceanFolder = workspace:FindFirstChild("Mobs")
                    and workspace.Mobs:FindFirstChild("Ocean")
    if not oceanFolder then return nil end
    for _, mob in ipairs(oceanFolder:GetChildren()) do
        if not mob.Name:lower():find("tree") then
            local mHRP = mob:FindFirstChild("HumanoidRootPart")
            local hum  = mob:FindFirstChildOfClass("Humanoid")
            if mHRP and hum and hum.Health > 0 then
                return mob, mHRP
            end
        end
    end
    return nil
end

task.spawn(function()
    while true do
        task.wait(0.05)
        local hrp = GetHRP()
        if not hrp then task.wait(1) continue end

        local targetMob, targetHRP, isOcean = nil, nil, false

        -- Ocean Farm priority
        if State.OceanFarm then
            targetMob, targetHRP = FindOceanTarget()
            if targetHRP then isOcean = true end
        end

        -- Fallback to Mob Farm if no ocean target or ocean farm off
        if not targetHRP and State.MobFarm and #State.SelectedMobs > 0 then
            for _, name in ipairs(State.SelectedMobs) do
                targetMob, targetHRP = FindAliveMob(name)
                if targetHRP then break end
            end
        end

        if not targetHRP then continue end

        local targetPos = targetHRP.Position
        local myPos     = hrp.Position

        if isOcean then
            -- Ocean: spam teleport, lock position, no Skill A
            local tpPos = Vector3.new(targetPos.X, targetPos.Y, targetPos.Z + OceanDistance)
            hrp.CFrame      = CFrame.new(tpPos, targetPos)
            hrp.Velocity    = Vector3.zero
            hrp.RotVelocity = Vector3.zero
        else
            -- Mob Farm: raycast to ground, fire Skill A
            local dist = (myPos - targetPos).Magnitude
            if dist > MobFarmDistance then
                local tpPos = targetPos + Vector3.new(0, 0, MobFarmDistance)
                local ray   = workspace:Raycast(
                    Vector3.new(tpPos.X, tpPos.Y + 10, tpPos.Z),
                    Vector3.new(0, -20, 0),
