-- Raid Farm loop
task.spawn(function()
    while true do
        task.wait(0.05)
        if not RState.RaidFarm then continue end
        local hrp = RGetHRP()
        if not hrp then task.wait(1) continue end

        if RState.AutoEquip and RState.SelectedWeapon then
            REquipWeapon(RState.SelectedWeapon)
        end

        local raidFolder = workspace:FindFirstChild("Mobs") and workspace.Mobs:FindFirstChild("Raid")
        if not raidFolder then task.wait(1) continue end

        -- Get base position
        local basePos = nil
        pcall(function()
            local base = workspace.Raid.Base
            local basePart = base:IsA("BasePart") and base or base:FindFirstChildWhichIsA("BasePart")
            if basePart then basePos = basePart.Position end
        end)

        -- Find mob closest to Base
        local targetHRP, closestDist = nil, math.huge
        for _, mob in ipairs(raidFolder:GetChildren()) do
            local mHRP = mob:FindFirstChild("HumanoidRootPart")
            local hum  = mob:FindFirstChildOfClass("Humanoid")
            if mHRP and hum and hum.Health > 0 then
                if basePos then
                    local d = (mHRP.Position - basePos).Magnitude
                    if d < closestDist then
                        closestDist = d
                        targetHRP   = mHRP
                    end
                else
                    targetHRP = mHRP
                    break
                end
            end
        end

        if not targetHRP then task.wait(0.5) continue end

        local mobPos = targetHRP.Position
        local myPos  = hrp.Position
        local dist   = (myPos - mobPos).Magnitude
        if dist > 8 then
            local tpPos = mobPos + Vector3.new(0, 0, 8)
            local ray   = workspace:Raycast(
                Vector3.new(tpPos.X, tpPos.Y + 10, tpPos.Z),
                Vector3.new(0, -20, 0), RaycastParams.new()
            )
            local groundY = ray and (ray.Position.Y + 3) or tpPos.Y
            hrp.CFrame = CFrame.new(Vector3.new(tpPos.X, groundY, tpPos.Z), mobPos)
        else
            hrp.CFrame = CFrame.new(myPos, Vector3.new(mobPos.X, myPos.Y, mobPos.Z))
        end
        hrp.Velocity    = Vector3.zero
        hrp.RotVelocity = Vector3.zero

        local cf = targetHRP.CFrame
        pcall(function()
            ReplicatedStorage.BridgeNet2.dataRemoteEvent:FireServer(unpack({
                [1] = { [1] = { [1]="Skill", [2]="A", [3]=cf }, [2]="\4" }
            }))
        end)
    end
end)

