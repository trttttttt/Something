local function FireSkill(key, targetCF)
    local hrp = GetHRP()
    if not hrp then return end
    local cf = targetCF or (hrp.CFrame * CFrame.new(0, 0, -15))
    local args = {
        [1] = {
            [1] = { [1] = "Skill", [2] = key, [3] = cf },
            [2] = "\4"
        }
    }
    pcall(function()
        ReplicatedStorage.BridgeNet2.dataRemoteEvent:FireServer(unpack(args))
    end)
end

local function FireUpgrade(stat)
    pcall(function()
        ReplicatedStorage.System.UpgradeStats:FireServer(stat, "100")
    end)
end

-- Build blacklist dari ReplicatedStorage.Items sekali masa load
local RSItemsBlacklist = {}
pcall(function()
    local folder = ReplicatedStorage:FindFirstChild("Items")
    if folder then
        for _, item in ipairs(folder:GetChildren()) do
            RSItemsBlacklist[item.Name:lower()] = true
        end
    end
end)

local function GetBackpackItems()
    local items, seen = {}, {}
    local bp   = LocalPlayer:FindFirstChild("Backpack")
    local char = GetChar()
    local function isStored(name)
        if RSItemsBlacklist[name:lower()] then return true end
        for k in pairs(StorageItems) do
            if k:lower() == name:lower() then return true end
        end
        return false
    end
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and not seen[t.Name] and not isStored(t.Name) then
                seen[t.Name] = true
                table.insert(items, t.Name)
            end
        end
    end
    if char then
        for _, t in ipairs(char:GetChildren()) do
            if t:IsA("Tool") and not seen[t.Name] and not isStored(t.Name) then
                seen[t.Name] = true
                table.insert(items, t.Name)
            end
        end
    end
    return #items > 0 and items or {"Empty"}
end

local function GetMobList()
    local names, seen = {}, {}
    local mobsFolder = workspace:FindFirstChild("Mobs")
    if mobsFolder then
        for _, folder in ipairs(mobsFolder:GetChildren()) do
            for _, mob in ipairs(folder:GetChildren()) do
                if not seen[mob.Name] then
                    seen[mob.Name] = true
                    table.insert(names, mob.Name)
                end
            end
        end
    end
    return #names > 0 and names or {"No Mobs Found"}
end

local function FindAliveMob(name)
    local mobsFolder = workspace:FindFirstChild("Mobs")
    if not mobsFolder then return nil end
    for _, folder in ipairs(mobsFolder:GetChildren()) do
        for _, mob in ipairs(folder:GetChildren()) do
            if mob.Name == name then
                local hrp = mob:FindFirstChild("HumanoidRootPart")
                local hum = mob:FindFirstChildOfClass("Humanoid")
                if hrp and hum and hum.Health > 0 then
                    return mob, hrp
                end
            end
        end
    end
    return nil
end

local function TpTo(cf)
    local hrp = GetHRP()
    if hrp then hrp.CFrame = cf end
end

local function EquipWeapon(weaponName)
    local char = GetChar()
    local bp   = LocalPlayer:FindFirstChild("Backpack")
    if not char or not bp or not weaponName then return end
    if char:FindFirstChild(weaponName) then return end
    local tool = bp:FindFirstChild(weaponName)
    if not tool then return end
    pcall(function()
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum:EquipTool(tool) end
    end)
    if not char:FindFirstChild(weaponName) then
        pcall(function() tool.Parent = char end)
    end
end

