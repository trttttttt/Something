local function RFireSkill(key)
    local hrp = RGetHRP()
    if not hrp then return end
    local cf = hrp.CFrame * CFrame.new(0, 0, -15)
    -- Aim at raid mob if farm active
    if RState.RaidFarm then
        local raidFolder = workspace:FindFirstChild("Mobs") and workspace.Mobs:FindFirstChild("Raid")
        if raidFolder then
            for _, mob in ipairs(raidFolder:GetChildren()) do
                local mHRP = mob:FindFirstChild("HumanoidRootPart")
                local hum  = mob:FindFirstChildOfClass("Humanoid")
                if mHRP and hum and hum.Health > 0 then cf = mHRP.CFrame break end
            end
        end
    end
    pcall(function()
        ReplicatedStorage.BridgeNet2.dataRemoteEvent:FireServer(unpack({
            [1] = { [1] = { [1]="Skill", [2]=key, [3]=cf }, [2]="\4" }
        }))
    end)
end

