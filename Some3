local function FarmBossLoop(stateKey, getTargetFn, summonFn)
    task.spawn(function()
        while State[stateKey] do
            task.wait(0.05)
            local hrp = GetHRP()
            if not hrp then task.wait(1) continue end

            local _, targetHRP = getTargetFn()
            if not targetHRP then
