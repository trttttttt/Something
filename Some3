local function MakeMineLoop(stateName, npcName, weaponName, oreName)
    return function(v)
        State[stateName] = v
        if not v then return end
        task.spawn(function()
            -- Step 1: teleport to NPC and fire ClickDetector
            pcall(function()
                local npc = workspace.NPC[npcName]
                local npcHRP = npc:FindFirstChild("HumanoidRootPart")
                local cd = npc:FindFirstChildOfClass("ClickDetector")
                        or (npcHRP and npcHRP:FindFirstChildOfClass("ClickDetector"))
                -- Search all descendants if still not found
                if not cd then
                    for _, v in ipairs(npc:GetDescendants()) do
                        if v:IsA("ClickDetector") then cd = v break end
                    end
                end
                local hrp = GetHRP()
                if hrp and npcHRP then
                    hrp.CFrame = npcHRP.CFrame * CFrame.new(4, 0, 0)
                end
                task.wait(0.3)
                if cd then fireclickdetector(cd) end
            end)

            task.wait(0.5)

            local function EquipTool(name)
                local char = GetChar()
                local bp   = LocalPlayer:FindFirstChild("Backpack")
                if not char or not bp then return end
                if char:FindFirstChild(name) then return end
                local tool = bp:FindFirstChild(name)
                if not tool then return end
                pcall(function()
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then hum:EquipTool(tool) end
                end)
                if not char:FindFirstChild(name) then
                    pcall(function() tool.Parent = char end)
                end
            end

            local function GetOres()
                local list = {}
                local cave = workspace:FindFirstChild("Mobs")
                         and workspace.Mobs:FindFirstChild("Cave Island")
                if not cave then return list end
                -- oreName can be a string or a function returning list of names
                local names = type(oreName) == "function" and oreName() or {oreName}
                for _, mob in ipairs(cave:GetChildren()) do
                    for _, n in ipairs(names) do
                        if mob.Name == n then
                            local hrp = mob:FindFirstChild("HumanoidRootPart")
                            local hum = mob:FindFirstChildOfClass("Humanoid")
                            if hrp and hum and hum.Health > 0 then
                                table.insert(list, mob)
                            end
                            break
                        end
                    end
                end
                return list
            end

            while State[stateName] do
                task.wait(0.05)

                -- Always re-equip if unequipped
                EquipTool(weaponName)

                local ores = GetOres()
                if #ores == 0 then
                    task.wait(1)
                else
                    for _, ore in ipairs(ores) do
                        if not State[stateName] then break end
                        local oreHRP = ore:FindFirstChild("HumanoidRootPart")
                        local hum    = ore:FindFirstChildOfClass("Humanoid")
                        if oreHRP and hum and hum.Health > 0 then
                            while State[stateName] do
                                task.wait(0.05)
                                local hrp = GetHRP()
                                if not hrp then task.wait(1) continue end
                                if not ore.Parent or hum.Health <= 0 then break end
                                EquipTool(weaponName)
                                local orePos = oreHRP.Position
                                local myPos  = hrp.Position
                                local dist   = (myPos - orePos).Magnitude
                                if dist > 10 then
                                    hrp.CFrame = CFrame.new(
                                        Vector3.new(orePos.X, orePos.Y, orePos.Z + 5),
                                        orePos
                                    )
                                else
                                    hrp.CFrame = CFrame.new(myPos, Vector3.new(orePos.X, myPos.Y, orePos.Z))
                                end
                                FireSkill("A", oreHRP.CFrame)
                            end
                        end
                    end
                end
            end
        end)
    end
end

