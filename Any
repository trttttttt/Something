local function getProgressBar()
    local gui=Player.PlayerGui
    local hp=gui:FindFirstChild("harvestPrompt")
    if hp then local pb=hp:FindFirstChild("ProgressBar"); if pb then local p=pb:FindFirstChild("Progress"); return p or pb end end
    for _, v in pairs(gui:GetDescendants()) do
        if v.Name=="Progress" and v.Parent and v.Parent.Name=="ProgressBar" then return v end
    end
    return nil
end

local function promptVisible()
    local hp = Player.PlayerGui:FindFirstChild("harvestPrompt")
    return hp and hp.Enabled == true
end

local function waitForHarvestComplete(activeCheck)
    -- Wait for prompt to appear (1.5s max)
    local t0 = tick()
    while tick() - t0 < 1.5 and activeCheck() do
        if promptVisible() then break end
        task.wait(0.02)
    end
    if not promptVisible() then return "timeout" end

    -- Prompt visible — check progress bar is actually moving within 1s
    local bar = getProgressBar()
    if bar then
        local s0 = 0; pcall(function() s0 = bar.Size.X.Scale end)
        local tMove = tick()
        local moved = false
        while tick() - tMove < 1 and activeCheck() do
            if not promptVisible() then return "complete" end
            local s1 = 0; pcall(function() s1 = bar.Size.X.Scale end)
            if math.abs(s1 - s0) > 0.02 then moved = true; break end
            task.wait(0.02)
        end
        if not moved then return "stuck" end
    end

    -- Wait for prompt to disappear — prompt gone = done
    while activeCheck() do
        if not promptVisible() then return "complete" end
        task.wait(0.02)
    end
    return "stop"
end

local function getHerbFolder(name)
    local herbs=workspace:FindFirstChild("Herbs"); if not herbs then return nil end
    local node=herbs:FindFirstChild(name); if not node then return nil end
    return node:FindFirstChild("Folder") or node
end

-- ============================================================
-- HERB FARMING
-- ============================================================
local herbZoneIndices = {}  -- per-herb zone index for interleaved round robin

local function doOneHerb(extraCheck)
    local function isActive()
        if not herbActive then return false end
        if extraCheck and not extraCheck() then return false end
        return true
    end

    local list = type(selectedHerb) == "table" and selectedHerb or (selectedHerb and {selectedHerb} or {})
    if not list or #list == 0 then return false end

    -- Advance herb round robin — ONE herb per call only, no fallback loop
    if herbRoundRobinIndex > #list then herbRoundRobinIndex = 1 end
    local herbName = list[herbRoundRobinIndex]
    herbRoundRobinIndex = (herbRoundRobinIndex % #list) + 1

    -- Collect all zones for this herb
    local folder = getHerbFolder(herbName)
    if not folder then return false end

    local allZones = {}
    for _, child in ipairs(folder:GetChildren()) do
        local z = child:FindFirstChild("HerbZone", true)
        if z and z:IsA("BasePart") and z.Parent then
            table.insert(allZones, z)
        end
    end
    if #allZones == 0 then return false end

    -- Advance zone index for this herb
    if not herbZoneIndices[herbName] or herbZoneIndices[herbName] > #allZones then
        herbZoneIndices[herbName] = 1
    end
    local zone = allZones[herbZoneIndices[herbName]]
    herbZoneIndices[herbName] = (herbZoneIndices[herbName] % #allZones) + 1

    if not zone or not zone.Parent then return false end

    local targetCF = getCF(zone)
    if not targetCF then return false end
    local zonePos = targetCF.Position
    local safePos = Vector3.new(zonePos.X, zonePos.Y + 1.5, zonePos.Z)

    local reached = flyTo(safePos, isActive)
    if not isActive() then return false end
    setNoclip(true)

    if not reached then
        local zCF = getCF(zone)
        if zCF and HRP and HRP.Parent then
            HRP.CFrame = CFrame.new(zCF.Position.X, zCF.Position.Y + 1.5, zCF.Position.Z)
            HRP.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.1)
        end
    end

    local attempt = 0
    while not isPlayerInZone(zone) and attempt < 20 and isActive() do
        attempt += 1
        local zCF = getCF(zone)
        if zCF then
            HRP.CFrame = CFrame.new(zCF.Position.X, zCF.Position.Y + 1.5, zCF.Position.Z)
            HRP.AssemblyLinearVelocity = Vector3.zero
        end
        task.wait(0.05)
    end
    if not isPlayerInZone(zone) or not isActive() then return false end

    task.wait(0.2)
    if not isPlayerInZone(zone) or not isActive() then return false end

    if HRP then HRP.Anchored = true end
    setNoclip(true)
    pcall(function() ReplicatedStorage.RemoteEvents.Harvest:FireServer() end)

    local result = waitForHarvestComplete(isActive)
    if HRP then
        HRP.Anchored = false
        HRP.AssemblyLinearVelocity = Vector3.zero
    end

    if result == "complete" then
        herbCollectCount += 1
        return true
    end
    -- timeout / stuck / stop — skip and move on
    task.wait(0.2)
    return false
end

