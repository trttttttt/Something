local Tab5 = Window:CreateTab(" Quest", 4483362458)

local selectedSlayingQuest    = nil
local selectedHarvestingQuest = nil

local function questPathWarning(questName)
    local info = QUEST_DATA[questName]
    if info and info.Path then
        local msg = info.Path == "Demon"
            and "Warning: This quest is for Demon path only!"
            or  "Warning: This quest is for " .. info.Path .. " path only!"
        Rayfield:Notify({Title="Quest Warning",Content=msg,Duration=6,Image=4483362458})
    end
end

local function runHarvestingCycle(progLbl)
    local activeName, activeProg, activePEnd = getActiveQuestOfType("Harvesting")
    if activeName and activeName ~= selectedHarvestingQuest then
        local aInfo = QUEST_DATA[activeName]
        if aInfo then
            progLbl:Set(activeProg .. " / " .. activePEnd)
            farmQuestHarvesting(activeName, aInfo.Target, progLbl)
        end
        if not harvestingActive then return end
    end
    if not selectedHarvestingQuest then return end
    local info = QUEST_DATA[selectedHarvestingQuest]
    if not info then return end
    local prog, pEnd = getProgressFromServer(selectedHarvestingQuest)
    if not prog then
        acceptQuest(selectedHarvestingQuest); task.wait(1)
        prog, pEnd = getProgressFromServer(selectedHarvestingQuest)
    end
    if not prog then return end
    if prog >= pEnd then return end
    progLbl:Set(prog .. " / " .. pEnd)
    farmQuestHarvesting(selectedHarvestingQuest, info.Target, progLbl)
end

local function runSlayingCycle(progLbl)
    local activeName, activeProg, activePEnd = getActiveQuestOfType("Slaying")
    if activeName and activeName ~= selectedSlayingQuest then
        local aInfo = QUEST_DATA[activeName]
        if aInfo then
            progLbl:Set(activeProg .. " / " .. activePEnd)
            farmQuestSlaying(activeName, aInfo.Target, progLbl)
        end
        if not slayingActive then return end
    end
    if not selectedSlayingQuest then return end
    local info = QUEST_DATA[selectedSlayingQuest]
    if not info then return end
    local prog, pEnd = getProgressFromServer(selectedSlayingQuest)
    if not prog then
        acceptQuest(selectedSlayingQuest); task.wait(1)
        prog, pEnd = getProgressFromServer(selectedSlayingQuest)
    end
    if not prog then return end
    if prog >= pEnd then return end
    progLbl:Set(prog .. " / " .. pEnd)
    farmQuestSlaying(selectedSlayingQuest, info.Target, progLbl)
end

