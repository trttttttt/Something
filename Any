        if qd and qd:FindFirstChild("NpcName") and qd.NpcName.Value==npcName then
            if qd:FindFirstChild("Progress") and qd:FindFirstChild("ProgressEnd") then
                return qd.Progress.Value,qd.ProgressEnd.Value
            end
