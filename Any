local function createPlayerESP(plr)
    if plr == Player then return end
    local char = plr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local hl = Instance.new("Highlight")
    hl.FillColor=Color3.fromRGB(255,50,50); hl.OutlineColor=Color3.fromRGB(255,255,255)
    hl.FillTransparency=0.4; hl.OutlineTransparency=0.1
    hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Adornee=char; hl.Parent=char
    local bb = Instance.new("BillboardGui")
    bb.Adornee=hrp; bb.Size=UDim2.new(0,120,0,30); bb.StudsOffset=Vector3.new(0,3,0)
    bb.AlwaysOnTop=true; bb.Parent=hrp
    local lbl = Instance.new("TextLabel")
    lbl.Size=UDim2.new(1,0,1,0); lbl.BackgroundTransparency=1
    lbl.TextColor3=Color3.fromRGB(255,80,80); lbl.TextStrokeTransparency=0
    lbl.TextStrokeColor3=Color3.fromRGB(0,0,0); lbl.TextScaled=true
    lbl.Font=Enum.Font.GothamBold; lbl.Text=plr.Name; lbl.Parent=bb
    playerESPObjects[plr] = {highlight=hl, billboard=bb}
end

local function removePlayerESP(plr)
    local obj = playerESPObjects[plr]
    if obj then
        pcall(function() obj.highlight:Destroy() end)
        pcall(function() obj.billboard:Destroy() end)
        playerESPObjects[plr] = nil
    end
end

local function clearAllPlayerESP()
    for plr in pairs(playerESPObjects) do removePlayerESP(plr) end
end

local function refreshPlayerESP()
    clearAllPlayerESP()
    if not playerESPEnabled then return end
    for _, plr in pairs(Players:GetPlayers()) do createPlayerESP(plr) end
end

RunService.RenderStepped:Connect(function()
    if not playerESPEnabled then return end
    local myHRP = HRP; if not myHRP then return end
    for plr, obj in pairs(playerESPObjects) do
        local char = plr.Character
        if not char or not char.Parent then
            removePlayerESP(plr)
        else
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp and obj.billboard then
                local dist = math.floor((myHRP.Position - hrp.Position).Magnitude)
                local lbl  = obj.billboard:FindFirstChildOfClass("TextLabel")
                if lbl then lbl.Text = plr.Name .. "\n" .. dist .. "m" end
            end
        end
    end
end)

Players.PlayerAdded:Connect(function(plr)
    if playerESPEnabled then
        plr.CharacterAdded:Connect(function()
            task.wait(1)
            if playerESPEnabled then createPlayerESP(plr) end
        end)
    end
end)

Players.PlayerRemoving:Connect(function(plr) removePlayerESP(plr) end)

