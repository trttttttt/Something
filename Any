local function farmQuestSlaying(npcName, target, lbl)
    local folder = workspace:FindFirstChild("Enemies")
    if not folder then return end
    setNoclip(true)
    while slayingActive do
        if justRespawned then while justRespawned and slayingActive do task.wait(0.5) end end
        if not slayingActive then break end
        local prog, pEnd = getProgressFromServer(npcName)
        if not prog then break end
        lbl:Set(prog .. " / " .. pEnd)
        if prog >= pEnd then break end
        local nearest, shortest = nil, math.huge
        for _, mob in pairs(folder:GetChildren()) do
            if mob.Name == target then
                local hum = mob:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    local ok, pos = pcall(function() return mob:GetPivot().Position end)
                    if ok then
                        local d = (HRP.Position - pos).Magnitude
                        if d < shortest then shortest = d; nearest = mob end
                    end
                end
            end
        end
        if not nearest then
            setNoclip(false); snapToGround()
            local waited = 0
            while slayingActive and waited < 30 do
                task.wait(0.5); waited += 0.5
                local found = false
                for _, mob in pairs(folder:GetChildren()) do
                    if mob.Name == target then
                        local hum = mob:FindFirstChildOfClass("Humanoid")
                        if hum and hum.Health > 0 then found = true; break end
                    end
                end
                if found then break end
            end
            if slayingActive then setNoclip(true) end
            continue
        end
        local mobRoot = nearest:FindFirstChild("HumanoidRootPart")
        if not mobRoot then task.wait(0.5); continue end
        flyTo(getCombatCFrame(mobRoot).Position, function() return slayingActive end)
        task.wait(0.05)
        if not slayingActive then break end
        if not nearest.Parent then task.wait(0.5); continue end
        local hum = nearest:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then task.wait(0.5); continue end
        Humanoid.PlatformStand = true
        while slayingActive and nearest.Parent do
            if justRespawned then break end
            local h = nearest:FindFirstChildOfClass("Humanoid")
            if not h or h.Health <= 0 then break end
            if mobRoot and mobRoot.Parent then
                HRP.CFrame = getCombatCFrame(mobRoot)
                HRP.AssemblyLinearVelocity  = Vector3.zero
                HRP.AssemblyAngularVelocity = Vector3.zero
            end
            stopCultivatingIfNeeded()
            pcall(function() ReplicatedStorage.RemoteEvents.Attack:FireServer("Light", {["RootPart"]=HRP}) end)
            task.wait(0.1)
        end
        if Humanoid and Humanoid.Parent then
            Humanoid.PlatformStand = false
            Humanoid.AutoRotate = true
        end
        if HRP and HRP.Parent then
            HRP.Anchored = true
            HRP.AssemblyLinearVelocity  = Vector3.zero
            HRP.AssemblyAngularVelocity = Vector3.zero
        end
        setNoclip(true)
        task.wait(0.3)
    end
    if Humanoid and Humanoid.Parent then
        Humanoid.PlatformStand = false
        Humanoid.AutoRotate = true
    end
    if HRP and HRP.Parent then HRP.Anchored = false end
    stopFlyNoclip()
    task.wait(0.1)
    snapToGround()
end

local function farmQuestHarvesting(npcName, target, lbl)
    setNoclip(true)
    while harvestingActive do
        local prog, pEnd = getProgressFromServer(npcName)
        if not prog then break end
        lbl:Set(prog .. " / " .. pEnd)
        if prog >= pEnd then break end
        local herbFolder = getHerbFolder(target)
        if not herbFolder then task.wait(3); continue end
        local foundHerb = findRandomHerb(herbFolder, 0, nil)
        if not foundHerb or not foundHerb.Parent then task.wait(2); continue end
        local zone = foundHerb:FindFirstChild("HerbZone", true)
        if not zone then continue end
        local targetCF = getCF(zone)
        if not targetCF then task.wait(0.2); continue end
        local zonePos = targetCF.Position
        local safePos = Vector3.new(zonePos.X, zonePos.Y + 1.5, zonePos.Z)
        local reached = flyTo(safePos, function() return harvestingActive end)
        if not harvestingActive then break end
        setNoclip(true)
        if not reached then
            local zCF = getCF(zone)
            if zCF and HRP and HRP.Parent then
                HRP.CFrame = CFrame.new(zCF.Position.X, zCF.Position.Y + 1.5, zCF.Position.Z)
                HRP.AssemblyLinearVelocity = Vector3.zero
                task.wait(0.1)
            end
        end
        local attempt = 0
        while not isPlayerInZone(zone) and attempt < 20 and harvestingActive do
            attempt += 1
            local zCF = getCF(zone)
            if zCF then
                HRP.CFrame = CFrame.new(zCF.Position.X, zCF.Position.Y + 1.5, zCF.Position.Z)
                HRP.AssemblyLinearVelocity = Vector3.zero
            end
            task.wait(0.05)
        end
        if not isPlayerInZone(zone) then continue end
        task.wait(0.2)
        if not isPlayerInZone(zone) or not harvestingActive then continue end
        if HRP then HRP.Anchored = true end
        setNoclip(true)
        pcall(function() ReplicatedStorage.RemoteEvents.Harvest:FireServer() end)
        local result = waitForHarvestComplete(function() return harvestingActive end)
        if HRP then
            HRP.Anchored = false
            HRP.AssemblyLinearVelocity = Vector3.zero
        end
        if not harvestingActive then break end
        if result == "timeout" or result == "stuck" then
            task.wait(0.2)
        end
    end
end

