end

local function treasureMatchesFilter(obj)
    if not selectedTreasure or #selectedTreasure == 0 then return true end
    for _, pick in ipairs(selectedTreasure) do
        if pick == "All Treasures" then return true end
        local nameLen = #pick
        if obj.Name:sub(1, nameLen) == pick then
            local nextChar = obj.Name:sub(nameLen + 1, nameLen + 1)
            if nextChar == "" or nextChar == " " or tonumber(nextChar) then return true end
        end
    end
    return false
end

local function doOneTreasure(extraCheck)
    local function isActive()
        if not treasureActive then return false end
        if extraCheck and not extraCheck() then return false end
        return true
    end
    local folder = workspace:FindFirstChild("Treasures")
    if not folder then return false end
    local treasure = findNearest(folder, 0, treasureMatchesFilter)
    if not treasure then
        if tick() - lastTreasureNotify >= NOTIFY_COOLDOWN then
            local label = (selectedTreasure and #selectedTreasure > 0) and table.concat(selectedTreasure, ", ") or "All Treasures"
            Rayfield:Notify({Title="Treasure Farm", Content="No "..label.." found yet", Duration=3, Image=4483362458})
            lastTreasureNotify = tick()
        end
        return false
    end
    local cf = getCF(treasure)
    if not cf then return false end
    local reached = flyTo(cf.Position, isActive)
    if not reached or not treasure.Parent or not isActive() then return false end
    setNoclip(true)
    task.wait(0.3)
    local hasPrompt = false; local count = 0
    while treasure.Parent and isActive() and count < 400 do
        local curCF = getCF(treasure)
        if curCF and (HRP.Position - curCF.Position).Magnitude > 20 then
            flyTo(curCF.Position, isActive)
            task.wait(0.2)
        end
        if firePrompt(treasure) then hasPrompt = true end
        count += 1; task.wait(0.05)
    end
    if not treasure.Parent then treasureCollectCount += 1; return true end
    return false
end

