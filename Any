local CONFIG_FILE = "MelayuHub_config.json"

local function encodeConfig()
    local cfg = {
        -- Selections
        selectedHerb           = selectedHerb,
        selectedMob            = selectedMob,
        selectedTreasure       = selectedTreasure,
        selectedBloodline      = selectedBloodline,
        selectedBosses         = selectedBosses,
        selectedSlayingQuest   = selectedSlayingQuest,
        selectedHarvestingQuest= selectedHarvestingQuest,
        selectedRecipe         = selectedRecipe,
        selectedAlchemyYear    = selectedAlchemyYear,
        alchemyCraftAmount     = alchemyCraftAmount,
        selectedAutoThreshold  = selectedAutoThreshold,
        autoPillSlot           = autoPillSlot,
        -- Element herbs
        selectedElementHerb    = selectedElementHerb,
        -- Priority
        farmPriority           = farmPriority,
        -- Settings
        flySpeed               = flySpeed,
        mobDistance            = mobDistance,
        bossNotifyEnabled      = bossNotifyEnabled,
        -- Quest loops
        questLoopSlaying       = questLoopSlaying,
        questLoopHarvesting    = questLoopHarvesting,
    }
    -- Simple JSON encode
    local function encVal(v)
        local t = type(v)
        if t == "nil" then return "null"
        elseif t == "boolean" then return v and "true" or "false"
        elseif t == "number" then return tostring(v)
        elseif t == "string" then return '"' .. v:gsub('"', '\"') .. '"'
        elseif t == "table" then
            -- Check if array
            local isArr = true
            local n = 0
            for k in pairs(v) do n += 1; if type(k) ~= "number" then isArr = false; break end end
            if isArr then
                local parts = {}
                for _, val in ipairs(v) do table.insert(parts, encVal(val)) end
                return "[" .. table.concat(parts, ",") .. "]"
            else
                local parts = {}
                for k, val in pairs(v) do
                    table.insert(parts, '"' .. tostring(k) .. '":' .. encVal(val))
                end
                return "{" .. table.concat(parts, ",") .. "}"
            end
        end
        return "null"
    end
    return encVal(cfg)
end

local function saveConfig()
    pcall(function()
        writefile(CONFIG_FILE, encodeConfig())
    end)
end
    local ok, data = pcall(function() return readfile(CONFIG_FILE) end
    if not ok or not data or data == "" then return end


local function loadConfig()
    local ok, data = pcall(function() return readfile(CONFIG_FILE) end)
    if not ok or not data or data == "" then return end

    -- Simple JSON decode — hanya support flat values dan arrays/objects satu level
    local function decodeSimple(s)
        s = s:match("^%s*(.-)%s*$")
        if s == "null" then return nil
        elseif s == "true" then return true
        elseif s == "false" then return false
        elseif s:match('^"(.*)"$') then
            return s:match('^"(.*)"$'):gsub('\"', '"')
        elseif tonumber(s) then return tonumber(s)
        end
        return nil

    local function decodeArray(s)
        local arr = {}
        s = s:match("^%[(.*)%]$")
        if not s then return arr end
        -- Split by comma tapi elak comma dalam string
        local depth, cur, inStr = 0, "", false
        for i = 1, #s do
            local c = s:sub(i,i)
            if c == '"' then inStr = not inStr end
    end
            if not inStr then
                if c == "{" or c == "[" then depth += 1
                elseif c == "}" or c == "]" then depth -= 1
                elseif c == "," and depth == 0 then
                    local v = decodeSimple(cur:match("^%s*(.-)%s*$"))
                    if v ~= nil then table.insert(arr, v) end
                    cur = ""; continue
                end
            end
            cur = cur .. c
        end
        if cur ~= "" then
            local v = decodeSimple(cur:match("^%s*(.-)%s*$"))
            if v ~= nil then table.insert(arr, v) end
        end
        return arr
    end

    -- Parse setiap key dari JSON object
    local function getField(json, key)
        -- Try string/number/bool value
        local val = json:match('"' .. key .. '"%s*:%s*("(?:[^"\\]|\\.)*"|true|false|null|%-?%d+%.?%d*)')
        if val then return decodeSimple(val) end
        -- Try array
        local arr = json:match('"' .. key .. '"%s*:%s*(%[.-%])')
        if arr then return decodeArray(arr) end
        -- Try object
        local obj = json:match('"' .. key .. '"%s*:%s*({[^}]*})')
        if obj then
            local result = {}
            for k, v in obj:gmatch('"([^"]+)"%s*:%s*("(?:[^"\\]|\\.)*"|true|false|null|%-?%d+%.?%d*)') do
                result[k] = decodeSimple(v)
            end
            return result
        end
        return nil
    end

    -- Load values
    local h = getField(data, "selectedHerb")
    if type(h) == "table" and #h > 0 then selectedHerb = h
    elseif type(h) == "string" then selectedHerb = {h} end

    local mob = getField(data, "selectedMob")
    if mob then selectedMob = mob end

    local tr = getField(data, "selectedTreasure")
    if type(tr) == "table" then selectedTreasure = tr end

    local bl = getField(data, "selectedBloodline")
    if type(bl) == "table" then selectedBloodline = bl end

    local bs = getField(data, "selectedBosses")
    if type(bs) == "table" and #bs > 0 then selectedBosses = bs end

    local sq = getField(data, "selectedSlayingQuest")
    if sq then selectedSlayingQuest = sq end

    local hq = getField(data, "selectedHarvestingQuest")
    if hq then selectedHarvestingQuest = hq end

    local rec = getField(data, "selectedRecipe")
    if rec then selectedRecipe = rec end

    local ay = getField(data, "selectedAlchemyYear")
    if ay then selectedAlchemyYear = ay end

    local ca = getField(data, "alchemyCraftAmount")
    if ca then alchemyCraftAmount = ca end

    local sat = getField(data, "selectedAutoThreshold")
    if sat then selectedAutoThreshold = sat end

    local aps = getField(data, "autoPillSlot")
    if aps then autoPillSlot = aps end

    local seh = getField(data, "selectedElementHerb")
    if type(seh) == "table" then
        for k, v in pairs(seh) do selectedElementHerb[k] = v end
    end

    local fp = getField(data, "farmPriority")
    if type(fp) == "table" then
        for k, v in pairs(fp) do if farmPriority[k] then farmPriority[k] = v end end
    end

    local fs = getField(data, "flySpeed")
    if fs then flySpeed = fs end

    local md = getField(data, "mobDistance")
    if md then mobDistance = md end

    local bn = getField(data, "bossNotifyEnabled")
    if bn ~= nil then bossNotifyEnabled = bn end

    local qls = getField(data, "questLoopSlaying")
    if qls ~= nil then questLoopSlaying = qls end

    local qlh = getField(data, "questLoopHarvesting")
    if qlh ~= nil then questLoopHarvesting = qlh end
end

