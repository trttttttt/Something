        if p and p:IsA("ProximityPrompt") then
            local old = p.HoldDuration; p.HoldDuration = 0
            fireproximityprompt(p); p.HoldDuration = old; return true
        end
    end
    local p = obj:FindFirstChildOfClass("ProximityPrompt", true)
    if p then
        local old = p.HoldDuration; p.HoldDuration = 0
        fireproximityprompt(p); p.HoldDuration = old; return true
    end
