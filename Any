local function stopCultivatingIfNeeded()
    local state = Character and Character:FindFirstChild("State")
    if not state then return end
    local isCult = state:FindFirstChild("IsCultivating")
    if not isCult then return end
    if isCult.Value == true then
        pcall(function() ReplicatedStorage.RemoteEvents.Cultivate:FireServer() end)
        local t0 = tick()
        while isCult.Value == true and tick() - t0 < 3 do
            task.wait(0.05)
        end
        if isCult.Value == true then
            pcall(function() ReplicatedStorage.RemoteEvents.Cultivate:FireServer() end)
            task.wait(0.3)
        end
    end
end

local function getCombatCFrame(mobRoot)
    local abovePos = mobRoot.Position + Vector3.new(0, mobDistance, 0)
    return CFrame.new(abovePos, abovePos + mobRoot.CFrame.LookVector) * CFrame.Angles(-math.pi/2, 0, 0)
end

-- ============================================================
-- UNIFIED FARM COORDINATOR — single thread, priority queue
-- ONE action per farm per cycle → no two flyTo calls conflict
-- Herb/treasure/altar: one zone per turn
-- Mob: fly + kill ONE mob per turn, loop back if more alive
-- Boss: fly + kill ONE boss per turn, loop back if more alive
-- ============================================================

local function anyFarmActive()
    return herbActive or treasureActive or altarActive or mobActive or bossActive
end

local function doOneMob()
    -- Fly to nearest mob, kill it. Return true = killed/found, false = none.
    local folder = workspace:FindFirstChild("Enemies")
    if not folder or not selectedMob then return false end
    local nearest, shortest = nil, math.huge
    for _, mob in pairs(folder:GetChildren()) do
        if mob.Name == selectedMob then
            local hum = mob:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local ok, pos = pcall(function() return mob:GetPivot().Position end)
                if ok then
                    local d = (HRP.Position - pos).Magnitude
                    if d < shortest then shortest = d; nearest = mob end
                end
            end
        end
    end
    if not nearest then return false end
    local mobRoot = nearest:FindFirstChild("HumanoidRootPart")
    if not mobRoot then return false end
    flyTo(getCombatCFrame(mobRoot).Position, function() return mobActive end)
    task.wait(0.05)
    if not nearest.Parent then return true end
    local hum = nearest:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return true end
    Humanoid.PlatformStand = true
    while nearest.Parent and mobActive do
        if justRespawned then break end
        local h = nearest:FindFirstChildOfClass("Humanoid")
        if not h or h.Health <= 0 then break end
        if mobRoot and mobRoot.Parent then
            HRP.CFrame = getCombatCFrame(mobRoot)
            HRP.AssemblyLinearVelocity  = Vector3.zero
            HRP.AssemblyAngularVelocity = Vector3.zero
        end
        stopCultivatingIfNeeded()
        local h2 = nearest:FindFirstChildOfClass("Humanoid")
        if not h2 or h2.Health <= 0 then break end
        pcall(function() ReplicatedStorage.RemoteEvents.Attack:FireServer("Light", {["RootPart"]=HRP}) end)
        task.wait(0.3)
    end
    Humanoid.PlatformStand = false
    Humanoid.AutoRotate = true
    if HRP and HRP.Parent then
        HRP.AssemblyLinearVelocity  = Vector3.zero
        HRP.AssemblyAngularVelocity = Vector3.zero
    end
    setNoclip(true)
    return true
end

local function doOneBoss()
    -- Fly to nearest boss, kill it. Return true = killed/found, false = none.
    local nearest = findBoss()
    if not nearest then return false end
    local mobRoot = nearest:FindFirstChild("HumanoidRootPart")
    if not mobRoot then return false end
    flyTo(getCombatCFrame(mobRoot).Position, function()
        return bossActive and findBoss() ~= nil
    end)
    task.wait(0.05)
    if not nearest.Parent then return true end
    local hum = nearest:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return true end
    Humanoid.PlatformStand = true
    while nearest.Parent and bossActive do
        if justRespawned then break end
        local h = nearest:FindFirstChildOfClass("Humanoid")
        if not h or h.Health <= 0 then break end
        if mobRoot and mobRoot.Parent then
            HRP.CFrame = getCombatCFrame(mobRoot)
            HRP.AssemblyLinearVelocity  = Vector3.zero
            HRP.AssemblyAngularVelocity = Vector3.zero
        end
        stopCultivatingIfNeeded()
        local h2 = nearest:FindFirstChildOfClass("Humanoid")
        if not h2 or h2.Health <= 0 then break end
        pcall(function() ReplicatedStorage.RemoteEvents.Attack:FireServer("Light", {["RootPart"]=HRP}) end)
        task.wait(0.3)
    end
    Humanoid.PlatformStand = false
    Humanoid.AutoRotate = true
    if HRP and HRP.Parent then
        HRP.AssemblyLinearVelocity  = Vector3.zero
        HRP.AssemblyAngularVelocity = Vector3.zero
    end
    setNoclip(true)
    return true
end

local function runUnifiedFarm()
    setNoclip(true)
    while anyFarmActive() do
        if justRespawned then
            while justRespawned and anyFarmActive() do task.wait(0.5) end
            if not anyFarmActive() then break end
            setNoclip(true)
        end
        if not HRP or not HRP.Parent then task.wait(0.5); continue end

        -- Build priority queue from ALL active farms
        local queue = {}
        if altarActive    then table.insert(queue, {t="altar",    p=farmPriority.altar,    i=1}) end
        if treasureActive then table.insert(queue, {t="treasure", p=farmPriority.treasure, i=2}) end
        if herbActive     then table.insert(queue, {t="herb",     p=farmPriority.herb,     i=3}) end
        if mobActive      then table.insert(queue, {t="mob",      p=farmPriority.mob,      i=4}) end
        if bossActive     then table.insert(queue, {t="boss",     p=farmPriority.boss,     i=5}) end
        if #queue == 0 then break end
        table.sort(queue, function(a, b)
            if a.p == b.p then return a.i < b.i end
            return a.p < b.p
        end)

        for _, farm in ipairs(queue) do
            if not anyFarmActive() or justRespawned then break end
            if not HRP or not HRP.Parent then break end
            setNoclip(true)

            if farm.t == "herb" and herbActive then
                doOneHerb()

            elseif farm.t == "treasure" and treasureActive then
                doOneTreasure()

            elseif farm.t == "altar" and altarActive then
                doOneAltar()

            elseif farm.t == "mob" and mobActive then
                -- Kill all alive mobs of selected type, then yield back to queue
                local found = doOneMob()
                while found and mobActive and not justRespawned do
                    task.wait(0.2)
                    found = doOneMob()
                end
                if not found and tick() - lastBossNotify >= NOTIFY_COOLDOWN then
                    -- no notify needed for mob not found, just skip silently
                end

            elseif farm.t == "boss" and bossActive then
                -- Kill all alive bosses, then yield back to queue
                local found = doOneBoss()
                while found and bossActive and not justRespawned do
                    task.wait(0.2)
                    found = doOneBoss()
                end
                if not found and tick() - lastBossNotify >= NOTIFY_COOLDOWN then
                    Rayfield:Notify({Title="Boss Farm", Content=table.concat(selectedBosses, ", ").." not spawned", Duration=3, Image=4483362458})
                    lastBossNotify = tick()
                end
            end

            task.wait(0.05)
        end

        task.wait(0.05)
    end

    multiFarmThread  = nil
    combatFarmThread = nil
    if Humanoid and Humanoid.Parent then
        Humanoid.PlatformStand = false
        Humanoid.AutoRotate = true
    end
    if not anyFarmActive() then
        stopFlyNoclip()
        task.wait(0.1)
        snapToGround()
    end
end

local function ensureUnifiedFarmRunning()
    if multiFarmThread then
        local s = coroutine.status(multiFarmThread)
        if s == "suspended" or s == "running" then return end
        multiFarmThread = nil
        combatFarmThread = nil
    end
    if combatFarmThread then
        local s = coroutine.status(combatFarmThread)
        if s == "suspended" or s == "running" then return end
        combatFarmThread = nil
    end
    multiFarmThread  = task.spawn(runUnifiedFarm)
    combatFarmThread = multiFarmThread
end

local function ensureMultiFarmRunning()  ensureUnifiedFarmRunning() end
local function ensureCombatFarmRunning() ensureUnifiedFarmRunning() end

-- ============================================================
-- MOB FARMING
-- ============================================================
local COMBAT_DISTANCE = 6

local function findBoss()
    local folder = workspace:FindFirstChild("Enemies")
    if not folder or not selectedBosses or #selectedBosses == 0 then return nil end
    local nearest, shortest = nil, math.huge
    for _, mob in pairs(folder:GetChildren()) do
        for _, bName in ipairs(selectedBosses) do
            if mob.Name == bName then
                local hum = mob:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    local ok, pos = pcall(function() return mob:GetPivot().Position end)
                    if ok then
                        local d = (HRP.Position - pos).Magnitude
                        if d < shortest then shortest = d; nearest = mob end
                    end
                end
                break
            end
        end
    end
    return nearest
end

local function farmBoss()
    if not selectedBosses or #selectedBosses == 0 then return end
    setNoclip(true)
    local fallbackActive = false  -- track sama ada tengah farm fallback atau tidak

    while bossActive do
        if justRespawned then
            while justRespawned and bossActive do task.wait(0.5) end
            if not bossActive then break end
            setNoclip(true)
        end
        if not bossActive then break end

        local nearest = findBoss()

        if nearest then
            -- Boss ada — stop fallback farm kalau tengah jalan
            if fallbackActive then
                fallbackActive = false
                -- Noclip kekal on, tak perlu stopFlyNoclip
                setNoclip(true)
            end

            local mobRoot = nearest:FindFirstChild("HumanoidRootPart")
            if not mobRoot then task.wait(0.5); continue end

            flyTo(getCombatCFrame(mobRoot).Position, function()
                return bossActive and findBoss() ~= nil
            end)
            task.wait(0.05)
            if not bossActive then break end
            if not nearest.Parent then task.wait(0.3); continue end

            local hum = nearest:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then task.wait(0.3); continue end

            Humanoid.PlatformStand = true
            while bossActive and nearest.Parent do
                if justRespawned then break end
                -- Semak boss lain spawn — kalau ada yang lagi dekat, break untuk retarget
                local newNearest = findBoss()
                if not newNearest or not newNearest.Parent then break end
                local h = newNearest:FindFirstChildOfClass("Humanoid")
                if not h or h.Health <= 0 then break end
                -- Guna nearest yang asal kalau masih alive
                local h2 = nearest:FindFirstChildOfClass("Humanoid")
                if not h2 or h2.Health <= 0 then break end
                if mobRoot and mobRoot.Parent then
                    HRP.CFrame = getCombatCFrame(mobRoot)
                    HRP.AssemblyLinearVelocity  = Vector3.zero
                    HRP.AssemblyAngularVelocity = Vector3.zero
                end
                stopCultivatingIfNeeded()
                pcall(function() ReplicatedStorage.RemoteEvents.Attack:FireServer("Light", {["RootPart"]=HRP}) end)
                task.wait(0.1)
            end
            if Humanoid and Humanoid.Parent then
                Humanoid.PlatformStand = false
                Humanoid.AutoRotate = true
            end
            if HRP and HRP.Parent then
                HRP.AssemblyLinearVelocity  = Vector3.zero
                HRP.AssemblyAngularVelocity = Vector3.zero
            end
            task.wait(0.3)

        else
            if tick() - lastBossNotify >= NOTIFY_COOLDOWN then
                Rayfield:Notify({Title="Boss Farm", Content=table.concat(selectedBosses,", ").." not spawned, farming others...", Duration=3, Image=4483362458})
                lastBossNotify = tick()
            end

            local hasFallback = herbActive or treasureActive or altarActive
            if hasFallback then
                fallbackActive = true
                setNoclip(true)
                local queue = {}
                if altarActive    then table.insert(queue, {t="altar",    p=farmPriority.altar,    i=1}) end
                if treasureActive then table.insert(queue, {t="treasure", p=farmPriority.treasure, i=2}) end
                if herbActive     then table.insert(queue, {t="herb",     p=farmPriority.herb,     i=3}) end
                table.sort(queue, function(a,b) if a.p == b.p then return (a.i or 0) < (b.i or 0) end; return a.p < b.p end)
                local function noBoss() return findBoss() == nil end
                for _, farm in ipairs(queue) do
                    if not noBoss() then break end  -- boss spawn, keluar terus
                    setNoclip(true)
                    if farm.t == "herb" and herbActive then
                        doOneHerb(noBoss)
                    elseif farm.t == "treasure" and treasureActive then
                        doOneTreasure(noBoss)
                    elseif farm.t == "altar" and altarActive then
                        doOneAltar(noBoss)
                    end
                    if noBoss() then task.wait(0.3) end
                end

            else
                task.wait(3)
            end
        end
    end

    if Humanoid and Humanoid.Parent then
        Humanoid.PlatformStand = false
        Humanoid.AutoRotate = true
    end
    stopFlyNoclip()
    task.wait(0.1)
    snapToGround()
end



