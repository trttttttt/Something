        --[[
            Tab:CreateContextMenu(element_frame, {
                {Name="Copy Flag",  Icon="copy",  Callback=function() end},
                {Name="Reset",      Icon="trash", Callback=function() end},
            })
        ]]
        function TabObj:CreateContextMenu(targetFrame, items)
            if not targetFrame then return end
            local CM = nil
            local function CloseMenu()
                if CM and CM.Parent then
                    Tween(CM,{BackgroundTransparency=1},0.12)
                    task.delay(0.15,function() pcall(function() CM:Destroy() end); CM=nil end)
                end
            end

            targetFrame.InputBegan:Connect(function(i)
                if i.UserInputType ~= Enum.UserInputType.MouseButton2 then return end
                CloseMenu()

                local mousePos = UIS:GetMouseLocation()
                CM = New("Frame",{
                    Position=UDim2.fromOffset(mousePos.X,mousePos.Y),
                    Size=UDim2.fromOffset(170,0),AutomaticSize=Enum.AutomaticSize.Y,
                    BackgroundColor3=T2.SecondaryBg,BorderSizePixel=0,
                    BackgroundTransparency=0,ZIndex=9999,
                    Parent=self._window._screenGui,
                })
                New("UICorner",{CornerRadius=UDim.new(0,8),Parent=CM})
                New("UIStroke",{Color=T2.Accent,Thickness=1,Transparency=0.5,Parent=CM})
                New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2),Parent=CM})
                New("UIPadding",{PaddingTop=UDim.new(0,4),PaddingBottom=UDim.new(0,4),PaddingLeft=UDim.new(0,4),PaddingRight=UDim.new(0,4),Parent=CM})

                for _, item in ipairs(items) do
                    local btn = New("TextButton",{
                        Size=UDim2.new(1,0,0,30),BackgroundColor3=T2.ElementBg,
                        BorderSizePixel=0,Text="",AutoButtonColor=false,ZIndex=10000,Parent=CM,
                    })
                    New("UICorner",{CornerRadius=UDim.new(0,6),Parent=btn})
                    New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Padding=UDim.new(0,8),Parent=btn})
                    New("UIPadding",{PaddingLeft=UDim.new(0,10),Parent=btn})
                    if item.Icon then New("ImageLabel",{Size=UDim2.fromOffset(13,13),BackgroundTransparency=1,Image=GetIcon(item.Icon),ImageColor3=T2.TextDim,Parent=btn}) end
                    New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=item.Name or "",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,Parent=btn})
                    btn.MouseEnter:Connect(function() Tween(btn,{BackgroundColor3=T2.ElementBgHover},0.1) end)
                    btn.MouseLeave:Connect(function() Tween(btn,{BackgroundColor3=T2.ElementBg},0.1) end)
                    local capturedItem = item
                    btn.MouseButton1Click:Connect(function()
                        CloseMenu()
                        if capturedItem.Callback then pcall(capturedItem.Callback) end
                    end)
                end

                -- Close on click outside
                local conn; conn = UIS.InputBegan:Connect(function(i2,gp)
                    if gp then return end
                    if i2.UserInputType==Enum.UserInputType.MouseButton1 or i2.UserInputType==Enum.UserInputType.MouseButton2 then
                        task.defer(function() CloseMenu() end)
                        conn:Disconnect()
                    end
                end)
                table.insert(self._window._connections, conn)
            end)
        end

