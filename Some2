            -- Deactivate settings first (stored on window to avoid forward-ref nil)
            if Window._deactivateSettings then Window._deactivateSettings() end
            for _, tb in ipairs(self._tabs) do
                Tween(tb._btn, {BackgroundTransparency=1}, 0.15)
                tb._bar.Visible = false
                tb._label.TextColor3 = T2.TabText
                tb._content.Visible = false
                if tb._ico then tb._ico.ImageColor3 = T2.TabText end
            end
            Tween(TabBtn, {BackgroundTransparency=0.8}, 0.15)
            ActiveBar.Visible = true
            TabLabel.TextColor3 = T2.Accent
            TabContent.Visible = true
            if tabIconLabel then tabIconLabel.ImageColor3 = T2.Accent end
            self._activeTab = name
            -- Reset search
            if SearchBox then SearchBox.Text = "" end
            for _, el in ipairs(self._allElements) do
                el.frame.Visible = true
            end
        end

        TabBtn.MouseButton1Click:Connect(Activate)
        TabBtn.MouseEnter:Connect(function()
            if self._activeTab ~= name then Tween(TabBtn,{BackgroundTransparency=0.88},0.1) end
        end)
        TabBtn.MouseLeave:Connect(function()
            if self._activeTab ~= name then Tween(TabBtn,{BackgroundTransparency=1},0.1) end
        end)

        local TabObj = {
            _btn     = TabBtn,
            _bar     = ActiveBar,
            _label   = TabLabel,
            _ico     = tabIconLabel,
            _content = TabContent,
            _name    = name,
            _theme   = T2,
            _window  = self,
        }

        if #self._tabs == 0 then task.defer(Activate) end
        table.insert(self._tabs, TabObj)

        -- ── Auto-resize sidebar ikut tab name terpanjang ──────
        task.defer(function()
            local maxW = TabWidth  -- minimum
            local iconW = 16 + 8   -- icon + gap
            local padW  = 10 + 10  -- left + right padding
            -- Measure all tabs including settings
            local settingsW = MeasureText("Settings", 12, Enum.Font.GothamSemibold) + iconW + padW
            maxW = math.max(maxW, settingsW)
            for _, tb in ipairs(self._tabs) do
                local nameW = MeasureText(tb._name or "", 12, Enum.Font.GothamSemibold)
                local btnW  = nameW + (tb._ico and iconW or 0) + padW
                maxW = math.max(maxW, btnW)
            end
            -- Clamp to constraint
            local maxAllowed = IsMobileDevice and 150 or 240
            maxW = math.clamp(maxW, TabWidth, maxAllowed)
            -- Animate sidebar width
            Tween(self._sidebar, {Size=UDim2.new(0,maxW,1,-44)}, 0.2)
            self._contentHost.Size     = UDim2.new(1,-maxW,1,-44)
            self._contentHost.Position = UDim2.new(0,maxW,0,44)
        end)

        -- ═══════════════════════════════════════════════════
        -- ELEMENT HELPERS
