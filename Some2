        -- ── TOGGLE ─────────────────────────────────────────
        function TabObj:CreateToggle(cfg2)
            local savedVal = self._window:LoadConfigValue(cfg2.Flag, nil)
            local val = savedVal ~= nil and savedVal or (cfg2.CurrentValue or false)
            local fromSave = savedVal ~= nil
            if cfg2.Flag then Flags[cfg2.Flag] = val end

            local f = BaseFrame(44)

            -- Inner layout
            local Inner = New("Frame",{
                Size=UDim2.new(1,-24,1,0),Position=UDim2.fromOffset(12,0),
                BackgroundTransparency=1,Parent=f,
            })
            New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,8),Parent=Inner})

            -- Left info (fixed width: total inner minus 42px track minus 8px gap)
            local InfoCol = New("Frame",{Size=UDim2.new(1,-50,1,0),BackgroundTransparency=1,LayoutOrder=1,Parent=Inner})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2),Parent=InfoCol})

            if cfg2.Icon then
                local tr = New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=InfoCol})
                New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),Parent=tr})
                New("ImageLabel",{Size=UDim2.fromOffset(14,14),BackgroundTransparency=1,Image=GetIcon(cfg2.Icon),ImageColor3=T2.TextDim,Parent=tr})
                New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=cfg2.Name or "Toggle",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=tr})
            else
                New("TextLabel",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Text=cfg2.Name or "Toggle",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,LayoutOrder=1,Parent=InfoCol})
            end
            if cfg2.Description and cfg2.Description ~= "" then
                New("TextLabel",{Size=UDim2.new(1,0,0,13),BackgroundTransparency=1,Text=cfg2.Description,TextColor3=T2.TextMuted,Font=Enum.Font.Gotham,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=2,Parent=InfoCol})
            end

            -- Track (always 42px wide, fixed, RIGHT side)
            local Track = New("Frame",{Size=UDim2.fromOffset(42,22),BackgroundColor3=val and T2.ToggleOn or T2.ToggleBg,BorderSizePixel=0,LayoutOrder=2,Parent=Inner})
            New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Track})
            local TStroke = New("UIStroke",{Color=val and T2.ToggleOn or T2.ElementStroke,Thickness=1,Parent=Track})
            local Knob = New("Frame",{
                Size=UDim2.fromOffset(16,16),
                Position=val and UDim2.fromOffset(23,3) or UDim2.fromOffset(3,3),
                BackgroundColor3=val and T2.ToggleKnobOn or T2.ToggleKnobOff,
                BorderSizePixel=0,Parent=Track,
            })
            New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Knob})

            local function SetVal(v, save)
                val = v
                if cfg2.Flag then Flags[cfg2.Flag] = v end
                Tween(Track, {BackgroundColor3 = v and T2.ToggleOn or T2.ToggleBg}, 0.22)
                Tween(Knob, {
                    Position = v and UDim2.fromOffset(23,3) or UDim2.fromOffset(3,3),
                    BackgroundColor3 = v and T2.ToggleKnobOn or T2.ToggleKnobOff,
                }, 0.22, Enum.EasingStyle.Back)
                TStroke.Color = v and T2.ToggleOn or T2.ElementStroke
                if cfg2.Callback then pcall(cfg2.Callback, v) end
                if save ~= false then self._window:SaveConfig() end
            end

            -- Invisible TextButton overlay — ONLY way to reliably capture clicks inside ScrollingFrame
            local ClickBtn = New("TextButton",{
                Size=UDim2.fromScale(1,1),BackgroundTransparency=1,
                Text="",ZIndex=5,Parent=f,
            })
            ClickBtn.MouseButton1Click:Connect(function() SetVal(not val) end)
            -- Hover effect
            ClickBtn.MouseEnter:Connect(function() Tween(f,{BackgroundColor3=T2.ElementBgHover},0.15) end)
            ClickBtn.MouseLeave:Connect(function() Tween(f,{BackgroundColor3=T2.ElementBg},0.15) end)

            RegisterElement(cfg2.Name or "Toggle", f)
            -- Register toggle in QuickBar registry
            if cfg2.Flag then
                -- Skip internal/test flags
                local flagStr = tostring(cfg2.Flag)
                local isInternal = flagStr:sub(1,2) == "__" or flagStr == "CtxTest" or flagStr == "TipTest"
                if not isInternal then
                    table.insert(self._window._toggleReg, {
                        name = cfg2.Name or "Toggle",
                        flag = cfg2.Flag,
                        icon = cfg2.Icon or "bolt",
                    })
                    -- Store callback so QB can fire it
                    if cfg2.Callback then
                        self._window._toggleCbs[cfg2.Flag] = cfg2.Callback
                    end
                end
            end
            if fromSave and cfg2.Callback then
                task.defer(function() pcall(cfg2.Callback, val) end)
            end
            return WrapElement({SetValue=function(_,v) SetVal(v) end, GetValue=function() return val end}, f)
        end

        -- ── SLIDER ─────────────────────────────────────────
        function TabObj:CreateSlider(cfg2)
            local range   = cfg2.Range or {0, 100}
            local inc     = cfg2.Increment or 1
            local suffix  = cfg2.Suffix or ""
            local savedVal = self._window:LoadConfigValue(cfg2.Flag, nil)
            local val     = math.clamp(savedVal ~= nil and savedVal or (cfg2.CurrentValue or range[1]), range[1], range[2])
            local fromSave = savedVal ~= nil
            if cfg2.Flag then Flags[cfg2.Flag] = val end

            local f = BaseFrame(0)
            New("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,11),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=f})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,7),Parent=f})

            -- Top row — name on left, value label pinned to right (no UIListLayout so it can't get cut)
            local TopRow = New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=f})
            if cfg2.Icon then
                New("ImageLabel",{Size=UDim2.fromOffset(16,16),AnchorPoint=Vector2.new(0,0.5),Position=UDim2.new(0,0,0.5,0),BackgroundTransparency=1,Image=GetIcon(cfg2.Icon),ImageColor3=T2.TextDim,Parent=TopRow})
            end
            local iconOff = cfg2.Icon and 22 or 0
            New("TextLabel",{
                Size=UDim2.new(1,-(iconOff+70),1,0),
                Position=UDim2.fromOffset(iconOff,0),
                BackgroundTransparency=1,Text=cfg2.Name or "Slider",
                TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,
                Parent=TopRow,
            })
            -- Value label — click to type a value directly
            local ValLabel = New("TextBox",{
                Size=UDim2.fromOffset(72,20),AnchorPoint=Vector2.new(1,0),
                Position=UDim2.new(1,0,0,-1),
                BackgroundColor3=T2.InputBg,BorderSizePixel=0,
                Text=tostring(val)..suffix,
                TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Center,
                ClearTextOnFocus=true,
                Parent=TopRow,
            })
            New("UICorner",{CornerRadius=UDim.new(0,5),Parent=ValLabel})
            local _sliderInputStroke=New("UIStroke",{Color=T2.InputStroke,Thickness=1,Transparency=0.5,Parent=ValLabel})
            ValLabel.Focused:Connect(function()
                ValLabel.Text = tostring(val)  -- strip suffix sementara focus
                Tween(_sliderInputStroke,{Color=T2.InputStrokeFocus,Transparency=0},0.15)
            end)
            ValLabel.FocusLost:Connect(function()
                Tween(_sliderInputStroke,{Color=T2.InputStroke,Transparency=0.5},0.15)
                local typed = tonumber(ValLabel.Text)
                if typed then
                    local clamped = math.clamp(math.floor(typed/inc+0.5)*inc, range[1], range[2])
                    val = clamped
                    local fp = (clamped-range[1])/(range[2]-range[1])
                    Tween(Fill,{Size=UDim2.fromScale(fp,1)},0.15)
                    Tween(Knob,{Position=UDim2.new(fp,0,0.5,0)},0.15)
                    if cfg2.Flag then Flags[cfg2.Flag]=clamped end
                    if cfg2.Callback then pcall(cfg2.Callback,clamped) end
                    self._window:SaveConfig()
                end
                ValLabel.Text = tostring(val)..suffix
            end)

            if cfg2.Description then
                New("TextLabel",{Size=UDim2.new(1,0,0,13),BackgroundTransparency=1,Text=cfg2.Description,TextColor3=T2.TextMuted,Font=Enum.Font.Gotham,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=2,Parent=f})
            end

            -- Track
            local TrackBG = New("Frame",{Size=UDim2.new(1,0,0,5),BackgroundColor3=T2.SliderBg,BorderSizePixel=0,LayoutOrder=cfg2.Description and 3 or 2,Parent=f})
            New("UICorner",{CornerRadius=UDim.new(0,3),Parent=TrackBG})
            local pct = (val - range[1]) / (range[2] - range[1])
            local Fill = New("Frame",{Size=UDim2.fromScale(pct,1),BackgroundColor3=T2.SliderFill,BorderSizePixel=0,Parent=TrackBG})
            New("UICorner",{CornerRadius=UDim.new(0,3),Parent=Fill})
            New("UIGradient",{Color=ColorSequence.new{ColorSequenceKeypoint.new(0,T2.SliderFill),ColorSequenceKeypoint.new(1,T2.SliderBg)},Rotation=90,Transparency=NumberSequence.new{NumberSequenceKeypoint.new(0,0.5),NumberSequenceKeypoint.new(1,0)},Parent=Fill})
            local Knob = New("Frame",{
                Size=UDim2.fromOffset(15,15),AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new(pct,0,0.5,0),
                BackgroundColor3=T2.SliderKnob,BorderSizePixel=0,Parent=TrackBG,
            })
            New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Knob})
            New("UIStroke",{Color=Color3.new(0,0,0),Thickness=1.5,Transparency=0.6,Parent=Knob})

            if cfg2.Flag then Flags[cfg2.Flag] = val end

            local sliding = false
            local function UpdateSlider(mx)
                local abs = TrackBG.AbsolutePosition
                local sz  = TrackBG.AbsoluteSize
                local p   = math.clamp((mx - abs.X) / sz.X, 0, 1)
                local raw = range[1] + p * (range[2] - range[1])
                -- Round to increment
                local rounded = math.floor(raw / inc + 0.5) * inc
                rounded = math.clamp(rounded, range[1], range[2])
                val = rounded
                local fp = (rounded - range[1]) / (range[2] - range[1])
                Fill.Size = UDim2.fromScale(fp, 1)
                Knob.Position = UDim2.new(fp, 0, 0.5, 0)
                ValLabel.Text = tostring(rounded)..suffix
                if cfg2.Flag then Flags[cfg2.Flag] = rounded end
                if cfg2.Callback then pcall(cfg2.Callback, rounded) end
            end

            TrackBG.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    sliding = true; UpdateSlider(i.Position.X)
                end
            end)
            local uis_conn = UIS.InputChanged:Connect(function(i)
                if sliding and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider(i.Position.X)
                end
            end)
            local uis_end = UIS.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    if sliding then
                        sliding = false
                        self._window:SaveConfig()
                    end
                end
            end)
            table.insert(self._window._connections, uis_conn)
            table.insert(self._window._connections, uis_end)

            RegisterElement(cfg2.Name or "Slider", f)
            if fromSave and cfg2.Callback then
                task.defer(function() pcall(cfg2.Callback, val) end)
            end
            return WrapElement({
                SetValue = function(_,v)
                    if type(v) ~= "number" then return end
                    val = math.clamp(v, range[1], range[2])
                    local fp2 = (val-range[1])/(range[2]-range[1])
                    Fill.Size=UDim2.fromScale(fp2,1)
                    Knob.Position=UDim2.new(fp2,0,0.5,0)
                    ValLabel.Text=tostring(val)..suffix
                    if cfg2.Flag then Flags[cfg2.Flag]=val end
                end,
                GetValue = function() return val end,
            }, f)
        end

        -- ── INPUT ──────────────────────────────────────────
        function TabObj:CreateInput(cfg2)
            local val = self._window:LoadConfigValue(cfg2.Flag, cfg2.Default or "")
            if cfg2.Flag then Flags[cfg2.Flag] = val end

            local f = BaseFrame(0)
            New("UIPadding",{PaddingTop=UDim.new(0,9),PaddingBottom=UDim.new(0,10),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=f})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),Parent=f})

