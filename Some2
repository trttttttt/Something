                    return r
                end
                return {
                    AddRow=function(cells) local r=MkRow(cells,#rows%2==0); table.insert(rows,r) end,
                    SetRows=function(data)
                        for _,r in ipairs(rows) do pcall(function() r:Destroy() end) end; rows={}
                        for i,cells in ipairs(data) do local r=MkRow(cells,i%2==0); table.insert(rows,r) end
                    end,
                    Clear=function() for _,r in ipairs(rows) do pcall(function() r:Destroy() end) end; rows={} end,
                }
            end

            return CSAPI
        end

