    local ThemeName   = cfg.Theme        or "Cyan"
    -- Responsive sizing
    local IsMobileDevice = UIS and UIS.TouchEnabled and not UIS.KeyboardEnabled
    local VP = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
    local function CalcSize()
        local vp = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or VP
        if IsMobileDevice then
            -- Mobile: 95% of screen
            return UDim2.fromOffset(math.floor(vp.X * 0.95), math.floor(vp.Y * 0.88))
        else
            -- PC: honour cfg or default, but clamp to viewport
            local w = math.min(cfg.Size and cfg.Size.X.Offset or 720, vp.X - 40)
            local h = math.min(cfg.Size and cfg.Size.Y.Offset or 500, vp.Y - 60)
            return UDim2.fromOffset(w, h)
        end
    end
    local Size = CalcSize()
    local TabWidth = IsMobileDevice and 80 or (cfg.TabWidth or 140)  -- minimum sidebar width
    local CfgFolder   = cfg.ConfigFolder or "NexusLib"
    local LoadTitle   = cfg.LoadingTitle or "NEXUSLIB"
    local LoadSub     = cfg.LoadingSubtitle or "Initializing..."

    local T = Themes[ThemeName] or Themes.Cyan
    local cfgPath     = CfgFolder .. "/" .. (Title:gsub("[^%w]","_")) .. CONFIG_EXT
    local cfgFolderOk = false

    -- Ensure config folder
    pcall(function()
        if not FolderExists(CfgFolder) then MakeFolder(CfgFolder) end
        cfgFolderOk = true
    end)

    -- Load saved config
    local savedCfg = {}
    pcall(function()
        if cfgFolderOk and FileExists(cfgPath) then
            local raw = ReadFile(cfgPath)
            if raw and #raw > 0 then
                local ok, decoded = pcall(HttpService.JSONDecode, HttpService, raw)
                if ok then savedCfg = decoded end
            end
        end
    end)

