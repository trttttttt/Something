        -- ── GRID LAYOUT ────────────────────────────────────
        --[[
            local grid = Tab:CreateGrid({Columns=2})
            grid:Add(function(parent) -- create elements inside parent end)
        ]]
        function TabObj:CreateGrid(cfg2)
            local cols = (cfg2 and cfg2.Columns) or 2
            local gap  = (cfg2 and cfg2.Gap) or 6

            local wrapper = New("Frame",{
                Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,Parent=TabContent,
            })
            local grid = New("Frame",{
                Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,Parent=wrapper,
            })
            local cellH = (cfg2 and cfg2.CellHeight) or 70  -- taller default for icon+text
            New("UIGridLayout",{
                CellSize=UDim2.new(1/cols,-math.ceil(gap*(cols-1)/cols),0,cellH),
                CellPadding=UDim2.fromOffset(gap,gap),
                SortOrder=Enum.SortOrder.LayoutOrder,
                Parent=grid,
            })
            RegisterElement("Grid", wrapper)

            -- Returns a proxy Tab-like object that creates elements inside grid cells
            local GridAPI = {}
            GridAPI._window = self._window
            GridAPI._grid   = grid
            GridAPI._theme  = T2

            -- Helper to create a cell
            local function Cell(h)
                local c = New("Frame",{
                    Size=UDim2.fromOffset(0,h or 44),
                    BackgroundColor3=T2.ElementBg,BorderSizePixel=0,
                    AutomaticSize=h==0 and Enum.AutomaticSize.Y or Enum.AutomaticSize.None,
                    Parent=grid,
                })
                New("UICorner",{CornerRadius=UDim.new(0,8),Parent=c})
                New("UIStroke",{Color=T2.ElementStroke,Thickness=1,Parent=c})
                c.MouseEnter:Connect(function() Tween(c,{BackgroundColor3=T2.ElementBgHover},0.15) end)
                c.MouseLeave:Connect(function() Tween(c,{BackgroundColor3=T2.ElementBg},0.15) end)
                return c
            end

            -- Card-like stat cell
            function GridAPI:AddCard(c)
                local cell=Cell(0)
                New("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,10),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=cell})
                New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,3),Parent=cell})
                local TR=New("Frame",{Size=UDim2.new(1,0,0,13),BackgroundTransparency=1,LayoutOrder=1,Parent=cell})
                New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Padding=UDim.new(0,4),Parent=TR})
                if c.Icon then New("ImageLabel",{Size=UDim2.fromOffset(11,11),BackgroundTransparency=1,Image=GetIcon(c.Icon),ImageColor3=T2.TextDim,Parent=TR}) end
                New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=(c.Title or ""):upper(),TextColor3=T2.TextDim,Font=Enum.Font.GothamBold,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left,Parent=TR})
                local VL=New("TextLabel",{Size=UDim2.new(1,0,0,28),BackgroundTransparency=1,Text=tostring(c.Value or "—"),TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=20,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=2,Parent=cell})
                if c.Description then New("TextLabel",{Size=UDim2.new(1,0,0,11),BackgroundTransparency=1,Text=c.Description,TextColor3=T2.TextMuted,Font=Enum.Font.Gotham,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=3,Parent=cell}) end
                return {SetValue=function(_,v) VL.Text=tostring(v) end, GetValue=function() return VL.Text end}
            end

            -- Button cell
            function GridAPI:AddButton(c)
                -- UIGridLayout controls cell size — we just fill it
                local cell=Cell(44)  -- height ignored by UIGridLayout, just for Cell()
                -- Stack: icon (optional) + text, both centered
                local inner=New("Frame",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Parent=cell})
                New("UIListLayout",{
                    FillDirection=Enum.FillDirection.Vertical,
                    HorizontalAlignment=Enum.HorizontalAlignment.Center,
                    VerticalAlignment=Enum.VerticalAlignment.Center,
                    SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,3),Parent=inner,
                })
                New("UIPadding",{PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6),Parent=inner})
                if c.Icon then
                    New("ImageLabel",{
                        Size=UDim2.fromOffset(20,20),BackgroundTransparency=1,
                        Image=GetIcon(c.Icon),ImageColor3=T2.Accent,
                        LayoutOrder=1,Parent=inner,
                    })
                end
                New("TextLabel",{
                    Size=UDim2.new(1,0,0,14),
                    BackgroundTransparency=1,Text=c.Name or "Button",
                    TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=11,
                    TextXAlignment=Enum.TextXAlignment.Center,
                    TextTruncate=Enum.TextTruncate.AtEnd,
                    LayoutOrder=2,Parent=inner,
                })
                -- Full-cell click overlay
                local CB=New("TextButton",{
                    Size=UDim2.fromScale(1,1),BackgroundTransparency=1,
                    Text="",ZIndex=5,Parent=cell,
                })
                CB.MouseButton1Click:Connect(function()
                    Tween(cell,{BackgroundColor3=T2.Accent},0.08)
                    task.delay(0.15,function() Tween(cell,{BackgroundColor3=T2.ElementBg},0.18) end)
                    if c.Callback then pcall(c.Callback) end
                end)
                -- MouseButton1Click fires on both mouse AND touch — no extra handler needed
            end

            -- Toggle cell
            function GridAPI:AddToggle(c)
                local sv2=self._window:LoadConfigValue(c.Flag,nil)
                local v=sv2~=nil and sv2 or (c.CurrentValue or false)
                if c.Flag then Flags[c.Flag]=v end
                local cell=Cell(44)
                New("UIPadding",{PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,10),Parent=cell})
                New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Padding=UDim.new(0,6),Parent=cell})
                local lbl=New("TextLabel",{Size=UDim2.new(1,-46,1,0),BackgroundTransparency=1,Text=c.Name or "Toggle",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,Parent=cell})
                local Tr=New("Frame",{Size=UDim2.fromOffset(38,20),BackgroundColor3=v and T2.ToggleOn or T2.ToggleBg,BorderSizePixel=0,Parent=cell})
                New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Tr})
                local Kn=New("Frame",{Size=UDim2.fromOffset(14,14),Position=v and UDim2.fromOffset(21,3) or UDim2.fromOffset(3,3),BackgroundColor3=v and T2.ToggleKnobOn or T2.ToggleKnobOff,BorderSizePixel=0,Parent=Tr})
                New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Kn})
                local function Sv(nv) v=nv; if c.Flag then Flags[c.Flag]=nv end
                    Tween(Tr,{BackgroundColor3=nv and T2.ToggleOn or T2.ToggleBg},0.2)
                    Tween(Kn,{Position=nv and UDim2.fromOffset(21,3) or UDim2.fromOffset(3,3)},0.2,Enum.EasingStyle.Back)
                    if c.Callback then pcall(c.Callback,nv) end
                    self._window:SaveConfig()
                end
                local CB=New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",ZIndex=5,Parent=cell})
                CB.MouseButton1Click:Connect(function() Sv(not v) end)
                return {SetValue=function(_,nv) Sv(nv) end, GetValue=function() return v end}
            end

            return GridAPI
        end

