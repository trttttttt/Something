    end)
    local resizeConn=UIS.InputChanged:Connect(function(i)
        if not resizing then return end
        if i.UserInputType~=Enum.UserInputType.MouseMovement and i.UserInputType~=Enum.UserInputType.Touch then return end
        local delta=UIS:GetMouseLocation()-resizeStart
        local vp=workspace.CurrentCamera.ViewportSize
        local newW=math.clamp(startSize.X+delta.X, 340, vp.X-20)
        local newH=math.clamp(startSize.Y+delta.Y, 260, vp.Y-20)
        Main.Size=UDim2.fromOffset(newW,newH)
    end)
