        local function AddTooltip(frame, text, win)
            if not frame or not text or text=="" then return end
            local tip = nil
            frame.MouseEnter:Connect(function()
                if tip and tip.Parent then return end
                local mp = UIS:GetMouseLocation()
                tip = New("Frame",{
                    Position=UDim2.fromOffset(mp.X+12, mp.Y-8),
                    Size=UDim2.fromOffset(0,22),AutomaticSize=Enum.AutomaticSize.X,
                    BackgroundColor3=T2.SecondaryBg,BorderSizePixel=0,
