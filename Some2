        -- ── COLLAPSIBLE SECTION ────────────────────────────
        --[[
            Tab:CreateCollapsibleSection({
                Name        = "Setting",
                Icon        = "settings",   -- optional
                DefaultOpen = true,         -- optional, default true
            })
            -- atau shorthand:
            Tab:CreateCollapsibleSection("Setting")

            Returns API dengan: CreateToggle / CreateSlider / CreateButton /
            CreateDropdown / CreateInput / CreateKeybind / CreateColorPicker /
            CreateLabel / CreateParagraph / CreateDivider / CreateSection
        ]]
        function TabObj:CreateCollapsibleSection(cfg2)
            local sName    = type(cfg2)=="string" and cfg2 or (cfg2.Name or "Section")
            local sIcon    = type(cfg2)=="table" and cfg2.Icon or nil
            local defOpen  = type(cfg2)=="table" and (cfg2.DefaultOpen~=false) or true

            -- ── Header ─────────────────────────────────────
            local Header = New("Frame",{
                Size=UDim2.new(1,0,0,40),
                BackgroundColor3=T2.ElementBg,BorderSizePixel=0,
                Parent=TabContent,
            })
            New("UICorner",{CornerRadius=UDim.new(0,8),Parent=Header})
            local HStroke = New("UIStroke",{Color=defOpen and T2.Accent or T2.ElementStroke,Thickness=1,Parent=Header})
            New("UIPadding",{PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=Header})
            New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,8),Parent=Header})

            if sIcon then
                New("ImageLabel",{
                    Size=UDim2.fromOffset(15,15),BackgroundTransparency=1,
                    Image=GetIcon(sIcon),ImageColor3=T2.Accent,Parent=Header,
                })
            end

            New("TextLabel",{
                Size=UDim2.new(1,-30,1,0),BackgroundTransparency=1,
                Text=sName,TextColor3=T2.Text,Font=Enum.Font.GothamBold,
                TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,
                TextTruncate=Enum.TextTruncate.AtEnd,Parent=Header,
            })

            local Arrow = New("TextLabel",{
                Size=UDim2.fromOffset(22,22),
                AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-2,0.5,0),
                BackgroundTransparency=1,
                Text=defOpen and "▾" or "▸",
                TextColor3=defOpen and T2.Accent or T2.TextDim,
                Font=Enum.Font.GothamBold,TextSize=16,Parent=Header,
            })

            local HBtn = New("TextButton",{
                Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",ZIndex=10,Parent=Header,
            })

            -- ── Inner Container ────────────────────────────
            local Container = New("Frame",{
                Size=UDim2.new(1,0,0,0),
                AutomaticSize=defOpen and Enum.AutomaticSize.Y or Enum.AutomaticSize.None,
                BackgroundTransparency=1,ClipsDescendants=true,
                Parent=TabContent,
            })
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),Parent=Container})

            RegisterElement(sName, Header)
            RegisterElement(sName.."_csec", Container)

            local isOpen = defOpen

            local function SetOpen(open)
                isOpen = open
                Arrow.Text = open and "▾" or "▸"
                Tween(Arrow,{TextColor3=open and T2.Accent or T2.TextDim},0.15)
                Tween(HStroke,{Color=open and T2.Accent or T2.ElementStroke},0.15)
                if open then
                    Container.AutomaticSize = Enum.AutomaticSize.Y
                else
                    Container.AutomaticSize = Enum.AutomaticSize.None
                    Tween(Container,{Size=UDim2.new(1,0,0,0)},0.2)
                end
            end

            HBtn.MouseEnter:Connect(function()
                Tween(Header,{BackgroundColor3=T2.ElementBgHover},0.12)
                if not isOpen then HStroke.Color=T2.Accent end
            end)
            HBtn.MouseLeave:Connect(function()
                Tween(Header,{BackgroundColor3=T2.ElementBg},0.12)
                if not isOpen then HStroke.Color=T2.ElementStroke end
            end)
            HBtn.MouseButton1Click:Connect(function() SetOpen(not isOpen) end)

            -- ── Sub BaseFrame (target Container) ───────────
            local function CBase(h)
                local sf = New("Frame",{
                    Size=UDim2.new(1,0,0,h or 44),
                    BackgroundColor3=T2.ElementBg,BorderSizePixel=0,
                    AutomaticSize=(h==0) and Enum.AutomaticSize.Y or Enum.AutomaticSize.None,
                    Parent=Container,
                })
                New("UICorner",{CornerRadius=UDim.new(0,8),Parent=sf})
                New("UIStroke",{Color=T2.ElementStroke,Thickness=1,Parent=sf})
                sf.MouseEnter:Connect(function() Tween(sf,{BackgroundColor3=T2.ElementBgHover},0.15) end)
                sf.MouseLeave:Connect(function() Tween(sf,{BackgroundColor3=T2.ElementBg},0.15) end)
                return sf
            end

            -- ── Sub-API ────────────────────────────────────
            local CSAPI = {}
            CSAPI._window = self._window

