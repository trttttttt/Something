        -- ── TABLE ──────────────────────────────────────────
        --[[
            local Tbl = Tab:CreateTable({
                Name    = "Players",
                Headers = {"Name","Health","Distance"},
            })
            Tbl:SetRows({{"Player1","100","50m"},{"Player2","30","120m"}})
            Tbl:AddRow({"Player3","75","88m"})
            Tbl:Clear()
        ]]
        function TabObj:CreateTable(cfg2)
            local headers = cfg2.Headers or {}
            local cols    = #headers

            local f = BaseFrame(0)
            New("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,10),PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,10),Parent=f})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),Parent=f})

            -- Title
            if cfg2.Name then
                New("TextLabel",{Size=UDim2.new(1,0,0,16),BackgroundTransparency=1,Text=cfg2.Name,TextColor3=T2.Text,Font=Enum.Font.GothamBold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=1,Parent=f})
            end

            -- Header row
            local HeaderRow = New("Frame",{Size=UDim2.new(1,0,0,24),BackgroundColor3=T2.SecondaryBg,BorderSizePixel=0,LayoutOrder=2,Parent=f})
            New("UICorner",{CornerRadius=UDim.new(0,6),Parent=HeaderRow})
            New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Parent=HeaderRow})
            for _, h in ipairs(headers) do
                New("TextLabel",{Size=UDim2.new(1/cols,0,1,0),BackgroundTransparency=1,Text=h,TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=10,Parent=HeaderRow})
            end

            -- Body scroll
            local Body = New("ScrollingFrame",{
                Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,BorderSizePixel=0,
                ScrollBarThickness=2,ScrollBarImageColor3=T2.ScrollBar,
                CanvasSize=UDim2.fromOffset(0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
                LayoutOrder=3,Parent=f,
            })
            local BodyLayout = New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2),Parent=Body})
            local rowCount = 0

            local function MakeRow(cells, isEven)
                rowCount=rowCount+1
                local r = New("Frame",{
                    Size=UDim2.new(1,0,0,26),
                    BackgroundColor3=isEven and T2.ElementBg or T2.SecondaryBg,
                    BorderSizePixel=0,Parent=Body,
                })
                New("UICorner",{CornerRadius=UDim.new(0,5),Parent=r})
                New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,Parent=r})
                for i=1,cols do
                    New("TextLabel",{Size=UDim2.new(1/cols,0,1,0),BackgroundTransparency=1,Text=tostring(cells[i] or ""),TextColor3=T2.Text,Font=Enum.Font.Gotham,TextSize=11,Parent=r})
                end
                return r
            end

            RegisterElement(cfg2.Name or "Table", f)
            local rows = {}
            return {
                AddRow = function(cells)
                    local r = MakeRow(cells, #rows%2==0)
                    table.insert(rows,r)
                end,
                SetRows = function(data)
                    for _, r in ipairs(rows) do pcall(function() r:Destroy() end) end
                    rows={}; rowCount=0
                    for i, cells in ipairs(data) do
                        local r = MakeRow(cells, i%2==0)
                        table.insert(rows,r)
                    end
                end,
                Clear = function()
                    for _, r in ipairs(rows) do pcall(function() r:Destroy() end) end
                    rows={}; rowCount=0
                end,
            }
        end

