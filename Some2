                    if c.Description then New("TextLabel",{Size=UDim2.new(1,0,0,13),BackgroundTransparency=1,Text=c.Description,TextColor3=T2.TextMuted,Font=Enum.Font.Gotham,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=2,Parent=IC}) end
                    local Tr=New("Frame",{Size=UDim2.fromOffset(42,22),BackgroundColor3=v and T2.ToggleOn or T2.ToggleBg,BorderSizePixel=0,Parent=In})
                    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Tr})
