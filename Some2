        Tokens: {game} {fps} {ping} {time} {player}
    ]]
    local _wmConn = nil
    local _wmFrame = nil

    function Window:SetWatermark(template)
        -- Buang yang lama
        if _wmConn  then pcall(function() _wmConn:Disconnect()  end); _wmConn=nil  end
        if _wmFrame then pcall(function() _wmFrame:Destroy()     end); _wmFrame=nil end
        if not template then return end

        local T2    = self._theme
        local stats = game:GetService("Stats")

        -- ── Frame ──────────────────────────────────────────
        local WF = New("Frame",{
            Size=UDim2.fromOffset(0,28),AutomaticSize=Enum.AutomaticSize.X,
            AnchorPoint=Vector2.new(0.5,0),
            Position=UDim2.new(0.5,0,0,0),
            BackgroundColor3=T2.NotifBg,BorderSizePixel=0,
            ZIndex=500,Parent=self._screenGui,
        })
        New("UICorner",{CornerRadius=UDim.new(0,8),Parent=WF})
        New("UIStroke",{Color=T2.Accent,Thickness=1,Transparency=0.55,Parent=WF})
        New("UIPadding",{PaddingLeft=UDim.new(0,14),PaddingRight=UDim.new(0,14),Parent=WF})

        -- Accent top line
        local topLine = New("Frame",{
            Size=UDim2.new(1,0,0,2),Position=UDim2.fromOffset(0,0),
            BackgroundColor3=T2.Accent,BorderSizePixel=0,ZIndex=501,Parent=WF,
        })
        New("UIGradient",{
            Color=ColorSequence.new{ColorSequenceKeypoint.new(0,T2.Accent),ColorSequenceKeypoint.new(1,T2.AccentDark)},
            Parent=topLine,
        })

        local WL = New("TextLabel",{
            Size=UDim2.fromScale(1,1),BackgroundTransparency=1,
            Text="NexusHub",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,
            TextSize=11,ZIndex=502,Parent=WF,
        })
        _wmFrame = WF

        -- Draggable — boleh drag sampai atas screen (minY=0)
        MakeDraggable(WF, WF, 0)

        -- ── Single update loop — semua token serentak ──────
        -- Guna RenderStepped untuk FPS accurate
        -- Throttle: update teks setiap 30 frames (~0.5s)
        local tick2   = 0
        local lastFPS = 0
        local cachedPing = "?"
        local cachedGame = "?"
        local cachedPlayer = "?"
        local cachedTime = "?"

        -- Pre-cache static tokens sekali
        pcall(function() cachedGame   = game.Name end)
        pcall(function() cachedPlayer = LocalPlayer and LocalPlayer.Name or "?" end)

        _wmConn = RunService.RenderStepped:Connect(function(dt)
            tick2 = tick2 + 1

            -- FPS update setiap frame
            lastFPS = math.floor(1/math.max(dt,0.001))

            -- Slow tokens update setiap 60 frames (~1s)
            if tick2 % 60 == 0 then
                -- Try Stats service first, fallback to GetNetworkPing
                local ok=pcall(function() cachedPing=tostring(math.floor(stats.Network.ServerStatsItem["Data Ping"].Value)) end)
                if not ok or cachedPing=="?" then
                    pcall(function() cachedPing=tostring(math.floor(LocalPlayer:GetNetworkPing()*1000)) end)
                end
                pcall(function() cachedTime=os.date("%H:%M") end)
            end

            -- Render teks setiap 30 frames
            if tick2 % 30 ~= 0 then return end

            if not WL or not WL.Parent then return end

            local s = template
            s = s:gsub("{game}",   cachedGame)
            s = s:gsub("{player}", cachedPlayer)
            s = s:gsub("{fps}",    tostring(lastFPS))
            s = s:gsub("{ping}",   cachedPing)
            s = s:gsub("{time}",   cachedTime)
            WL.Text = s
        end)

        table.insert(self._connections, _wmConn)
    end

