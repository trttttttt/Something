    local function SS(name, val, min, max, inc, suf, cb)
        -- Settings Slider
        local f = SBaseFrame(0)
        New("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,11),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=f})
        New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,7),Parent=f})
        local TR=New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=f})
        New("TextLabel",{Size=UDim2.new(1,-70,1,0),BackgroundTransparency=1,Text=name,TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=TR})
        local VL=New("TextLabel",{Size=UDim2.fromOffset(68,18),AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,0,0,0),BackgroundTransparency=1,Text=tostring(val)..(suf or ""),TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Right,Parent=TR})
        local TBG=New("Frame",{Size=UDim2.new(1,0,0,5),BackgroundColor3=T2.SliderBg,BorderSizePixel=0,LayoutOrder=2,Parent=f})
        New("UICorner",{CornerRadius=UDim.new(0,3),Parent=TBG})
        local pct=(val-min)/(max-min)
        local Fil=New("Frame",{Size=UDim2.fromScale(pct,1),BackgroundColor3=T2.SliderFill,BorderSizePixel=0,Parent=TBG}); New("UICorner",{CornerRadius=UDim.new(0,3),Parent=Fil})
        local Kn=New("Frame",{Size=UDim2.fromOffset(15,15),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(pct,0,0.5,0),BackgroundColor3=T2.SliderKnob,BorderSizePixel=0,Parent=TBG})
        New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Kn}); New("UIStroke",{Color=Color3.new(0,0,0),Thickness=1.5,Transparency=0.6,Parent=Kn})
        local sl=false
        local function US(mx)
            local sz=TBG.AbsoluteSize.X; if sz<=0 then return end
            local p=math.clamp((mx-TBG.AbsolutePosition.X)/sz,0,1)
            local range=max-min; if range<=0 then return end
            local rd=math.clamp(math.floor((min+p*range)/(inc or 1)+0.5)*(inc or 1),min,max)
            val=rd; local fp=(rd-min)/range
            Fil.Size=UDim2.fromScale(fp,1); Kn.Position=UDim2.new(fp,0,0.5,0)
            VL.Text=tostring(rd)..(suf or ""); if cb then pcall(cb,rd) end
        end
        TBG.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sl=true;US(i.Position.X) end end)
        local sc1=UIS.InputChanged:Connect(function(i) if sl and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then US(i.Position.X) end end)
        local sc2=UIS.InputEnded:Connect(function(i) if (i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch) and sl then sl=false end end)
        table.insert(Window._connections,sc1); table.insert(Window._connections,sc2)
        return function(nv) val=math.clamp(nv,min,max); local fp=(val-min)/(max-min); Fil.Size=UDim2.fromScale(fp,1); Kn.Position=UDim2.new(fp,0,0.5,0); VL.Text=tostring(val)..(suf or "") end
    end

