    -- ── EXPORT CONFIG (string) ────────────────────────────────
    --[[ local str = Win:ExportConfig() ]]
    function Window:ExportConfig()
        local data={}
        for flag,val in pairs(Flags) do
            local t=type(val)
            if t=="boolean" or t=="number" or t=="string" then
                data[flag]=val
            elseif t=="userdata" and typeof(val)=="Color3" then
                data[flag]={r=val.R,g=val.G,b=val.B}
            elseif t=="table" then
                data[flag]=val
            end
        end
        local ok,encoded=pcall(HttpService.JSONEncode,HttpService,data)
        return ok and encoded or nil
    end

    -- ── IMPORT CONFIG (string) ────────────────────────────────
    --[[ Win:ImportConfig(str) ]]
    function Window:ImportConfig(str)
        if not str or str=="" then return false end
        local ok,decoded=pcall(HttpService.JSONDecode,HttpService,str)
        if not ok then return false end
        for k,v in pairs(decoded) do
            if type(v)=="table" and v.r then
                Flags[k]=Color3.new(v.r,v.g,v.b)
            else
                Flags[k]=v
            end
        end
        self._savedCfg=decoded
        return true
    end

    -- ── SET THEME COLOR (live accent override) ────────────────
    --[[ Win:SetThemeColor(Color3.fromRGB(255,0,128)) ]]
    function Window:SetThemeColor(color)
        if not color then return end
        local T2=self._theme
        T2.Accent=color
        T2.SliderFill=color
        T2.SliderKnob=color
        T2.ToggleOn=color
        T2.NotifStroke=color
        T2.InputStrokeFocus=color
        T2.ScrollBar=color
        -- Retween all active strokes + text that use accent
        for _,el in ipairs(self._allElements) do
            if el.frame and el.frame.Parent then
                pcall(function()
                    for _,child in ipairs(el.frame:GetDescendants()) do
                        if child:IsA("UIStroke") then
                            if (child.Color-T2.ElementStroke).Magnitude<0.1 then continue end
                            Tween(child,{Color=color},0.25)
                        end
                        if child:IsA("TextLabel") or child:IsA("TextButton") then
                            if child.TextColor3==T2.Accent then
                                Tween(child,{TextColor3=color},0.25)
                            end
                        end
                    end
                end)
            end
        end
        -- Topbar gradient
        pcall(function()
            for _,g in ipairs(self._main:GetDescendants()) do
                if g:IsA("UIGradient") then
                    g.Color=ColorSequence.new{ColorSequenceKeypoint.new(0,color),ColorSequenceKeypoint.new(1,T2.AccentDark)}
                end
            end
        end)
    end


