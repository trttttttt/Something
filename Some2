    -- ── APPLY SEARCH (cross-tab) ─────────────────────────────
    SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q = SearchBox.Text:lower()
        if q == "" then
            -- restore — only show elements for active tab
            for _, el in ipairs(Window._allElements) do
                el.frame.Visible = (el.tab == Window._activeTab)
            end
        else
            -- search ALL tabs
            local found = false
            for _, el in ipairs(Window._allElements) do
                local match = el.name:lower():find(q, 1, true) ~= nil
                el.frame.Visible = match
                if match and not found then
                    -- switch to that tab automatically
                    found = true
                    if el.tab ~= Window._activeTab then
                        for _, tb in ipairs(Window._tabs) do
                            if tb._name == el.tab then
                                -- activate
                                for _, tb2 in ipairs(Window._tabs) do
                                    Tween(tb2._btn,{BackgroundTransparency=1},0.1)
                                    tb2._bar.Visible=false
                                    tb2._label.TextColor3=Window._theme.TabText
                                    tb2._content.Visible=false
                                    if tb2._ico then tb2._ico.ImageColor3=Window._theme.TabText end
                                end
                                Tween(tb._btn,{BackgroundTransparency=0.8},0.1)
                                tb._bar.Visible=true
                                tb._label.TextColor3=Window._theme.Accent
                                tb._content.Visible=true
                                if tb._ico then tb._ico.ImageColor3=Window._theme.Accent end
                                Window._activeTab=el.tab
                                break
                            end
                        end
                    end
                elseif not match then
                    el.frame.Visible = false
                end
            end
        end
    end)

