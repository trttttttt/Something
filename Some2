                    bg2.InputBegan:Connect(function(i2)
                        if i2.UserInputType==Enum.UserInputType.MouseButton1 or i2.UserInputType==Enum.UserInputType.Touch then sl2=true;US(i2.Position.X) end
                    end)
                    local sc1=UIS.InputChanged:Connect(function(i2)
                        if sl2 and (i2.UserInputType==Enum.UserInputType.MouseMovement or i2.UserInputType==Enum.UserInputType.Touch) then US(i2.Position.X) end
                    end)
                    local sc2=UIS.InputEnded:Connect(function(i2)
