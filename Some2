                New("Frame",{Size=UDim2.new(1,0,0,1),BackgroundColor3=T2.SectionLine,BorderSizePixel=0,Parent=sf2})
            end

            function CSAPI:CreateToggle(c)
                local sv2=self._window:LoadConfigValue(c.Flag,nil)
                local v=sv2~=nil and sv2 or (c.CurrentValue or false)
                local fromSv=sv2~=nil
                if c.Flag then Flags[c.Flag]=v end
                local sf=CBase(44)
                local In=New("Frame",{Size=UDim2.new(1,-24,1,0),Position=UDim2.fromOffset(12,0),BackgroundTransparency=1,Parent=sf})
                New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,8),Parent=In})
                local IC=New("Frame",{Size=UDim2.new(1,-50,1,0),BackgroundTransparency=1,Parent=In})
                New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2),Parent=IC})
                if c.Icon then
                    local tr=New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=IC})
                    New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),Parent=tr})
                    New("ImageLabel",{Size=UDim2.fromOffset(14,14),BackgroundTransparency=1,Image=GetIcon(c.Icon),ImageColor3=T2.TextDim,Parent=tr})
                    New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=c.Name or "Toggle",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=tr})
                else
                    New("TextLabel",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Text=c.Name or "Toggle",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,LayoutOrder=1,Parent=IC})
                end
                if c.Description then New("TextLabel",{Size=UDim2.new(1,0,0,13),BackgroundTransparency=1,Text=c.Description,TextColor3=T2.TextMuted,Font=Enum.Font.Gotham,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=2,Parent=IC}) end
                local Tr=New("Frame",{Size=UDim2.fromOffset(42,22),BackgroundColor3=v and T2.ToggleOn or T2.ToggleBg,BorderSizePixel=0,Parent=In})
                New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Tr})
                local TS=New("UIStroke",{Color=v and T2.ToggleOn or T2.ElementStroke,Thickness=1,Parent=Tr})
                local Kn=New("Frame",{Size=UDim2.fromOffset(16,16),Position=v and UDim2.fromOffset(23,3) or UDim2.fromOffset(3,3),BackgroundColor3=v and T2.ToggleKnobOn or T2.ToggleKnobOff,BorderSizePixel=0,Parent=Tr})
                New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Kn})
                local function Sv(nv)
                    v=nv; if c.Flag then Flags[c.Flag]=nv end
                    Tween(Tr,{BackgroundColor3=nv and T2.ToggleOn or T2.ToggleBg},0.22)
                    Tween(Kn,{Position=nv and UDim2.fromOffset(23,3) or UDim2.fromOffset(3,3),BackgroundColor3=nv and T2.ToggleKnobOn or T2.ToggleKnobOff},0.22,Enum.EasingStyle.Back)
                    TS.Color=nv and T2.ToggleOn or T2.ElementStroke
                    if c.Callback then pcall(c.Callback,nv) end
                    self._window:SaveConfig()
                end
                local CB=New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",ZIndex=5,Parent=sf})
                CB.MouseButton1Click:Connect(function() Sv(not v) end)
                if fromSv and c.Callback then task.defer(function() pcall(c.Callback,v) end) end
                return {SetValue=Sv,GetValue=function() return v end}
            end

            function CSAPI:CreateSlider(c)
                local rng=c.Range or {0,100}; local inc2=c.Increment or 1
                local suf2=c.Suffix or ""
                local sv2=self._window:LoadConfigValue(c.Flag,nil)
                local sv=math.clamp(sv2~=nil and sv2 or (c.CurrentValue or rng[1]),rng[1],rng[2])
                local fromSv=sv2~=nil
                if c.Flag then Flags[c.Flag]=sv end
                local sf=CBase(0)
                New("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,11),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=sf})
                New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,7),Parent=sf})
                local TR=New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=sf})
                if c.Icon then New("ImageLabel",{Size=UDim2.fromOffset(16,16),AnchorPoint=Vector2.new(0,0.5),Position=UDim2.new(0,0,0.5,0),BackgroundTransparency=1,Image=GetIcon(c.Icon),ImageColor3=T2.TextDim,Parent=TR}) end
                local iconOff=c.Icon and 22 or 0
                New("TextLabel",{Size=UDim2.new(1,-(iconOff+70),1,0),Position=UDim2.fromOffset(iconOff,0),BackgroundTransparency=1,Text=c.Name or "Slider",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=TR})
                local VL=New("TextLabel",{Size=UDim2.fromOffset(68,18),AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,0,0,0),BackgroundTransparency=1,Text=tostring(sv)..suf2,TextColor3=T2.Accent,Font=Enum.Font.GothamBold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Right,Parent=TR})
                if c.Description then New("TextLabel",{Size=UDim2.new(1,0,0,13),BackgroundTransparency=1,Text=c.Description,TextColor3=T2.TextMuted,Font=Enum.Font.Gotham,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=2,Parent=sf}) end
                local TBG=New("Frame",{Size=UDim2.new(1,0,0,5),BackgroundColor3=T2.SliderBg,BorderSizePixel=0,LayoutOrder=c.Description and 3 or 2,Parent=sf})
                New("UICorner",{CornerRadius=UDim.new(0,3),Parent=TBG})
                local fp2=(sv-rng[1])/(rng[2]-rng[1])
                local Fil=New("Frame",{Size=UDim2.fromScale(fp2,1),BackgroundColor3=T2.SliderFill,BorderSizePixel=0,Parent=TBG})
                New("UICorner",{CornerRadius=UDim.new(0,3),Parent=Fil})
                New("UIGradient",{Color=ColorSequence.new{ColorSequenceKeypoint.new(0,T2.SliderFill),ColorSequenceKeypoint.new(1,T2.SliderBg)},Rotation=90,Transparency=NumberSequence.new{NumberSequenceKeypoint.new(0,0.5),NumberSequenceKeypoint.new(1,0)},Parent=Fil})
                local Kn2=New("Frame",{Size=UDim2.fromOffset(15,15),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(fp2,0,0.5,0),BackgroundColor3=T2.SliderKnob,BorderSizePixel=0,Parent=TBG})
                New("UICorner",{CornerRadius=UDim.new(1,0),Parent=Kn2})
                New("UIStroke",{Color=Color3.new(0,0,0),Thickness=1.5,Transparency=0.6,Parent=Kn2})
                local sl3=false
                local function US(mx)
                    local p=math.clamp((mx-TBG.AbsolutePosition.X)/TBG.AbsoluteSize.X,0,1)
                    local rd=math.clamp(math.floor((rng[1]+p*(rng[2]-rng[1]))/inc2+0.5)*inc2,rng[1],rng[2])
                    sv=rd; local fp3=(rd-rng[1])/(rng[2]-rng[1])
                    Fil.Size=UDim2.fromScale(fp3,1); Kn2.Position=UDim2.new(fp3,0,0.5,0)
                    VL.Text=tostring(rd)..suf2; if c.Flag then Flags[c.Flag]=rd end
                    if c.Callback then pcall(c.Callback,rd) end
                end
                TBG.InputBegan:Connect(function(i2)
                    if i2.UserInputType==Enum.UserInputType.MouseButton1 or i2.UserInputType==Enum.UserInputType.Touch then sl3=true;US(i2.Position.X) end
                end)
                local sc1=UIS.InputChanged:Connect(function(i2)
                    if sl3 and (i2.UserInputType==Enum.UserInputType.MouseMovement or i2.UserInputType==Enum.UserInputType.Touch) then US(i2.Position.X) end
                end)
                local sc2=UIS.InputEnded:Connect(function(i2)
                    if (i2.UserInputType==Enum.UserInputType.MouseButton1 or i2.UserInputType==Enum.UserInputType.Touch) and sl3 then sl3=false; self._window:SaveConfig() end
                end)
                table.insert(self._window._connections,sc1); table.insert(self._window._connections,sc2)
                if fromSv and c.Callback then task.defer(function() pcall(c.Callback,sv) end) end
                return {
                    SetValue=function(_,nv)
                        sv=math.clamp(nv,rng[1],rng[2]); local fp4=(sv-rng[1])/(rng[2]-rng[1])
                        Fil.Size=UDim2.fromScale(fp4,1); Kn2.Position=UDim2.new(fp4,0,0.5,0)
                        VL.Text=tostring(sv)..suf2; if c.Flag then Flags[c.Flag]=sv end
                    end,
                    GetValue=function() return sv end
                }
            end

            function CSAPI:CreateButton(c)
                local sf=CBase(44)
                local row=New("Frame",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Parent=sf})
                New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,8),Parent=row})
