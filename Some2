        local function RegisterElement(elName, frame)
            table.insert(self._allElements, {name=elName, frame=frame, tab=name})
        end

        -- Wrap any element API table with SetVisible / SetLocked
        local function WrapElement(api, frame, tooltip)
            api = api or {}
            -- Tooltip support
            if tooltip and tooltip~="" and frame then
                if self._addTooltip then self._addTooltip(frame, tooltip, self._window) end
            end
            function api:SetVisible(v)
                if frame and frame.Parent then frame.Visible=v end
            end
            function api:SetBadge(text)
                if not frame or not frame.Parent then return end
                local existing=frame:FindFirstChild("__Badge")
                if existing then existing:Destroy() end
                if not text or text=="" then return end
                local bg=New("Frame",{
                    Name="__Badge",
                    Size=UDim2.fromOffset(0,16),AutomaticSize=Enum.AutomaticSize.X,
                    AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-4,0,4),
                    BackgroundColor3=T2.Accent,BorderSizePixel=0,ZIndex=15,Parent=frame,
                })
                New("UICorner",{CornerRadius=UDim.new(0,4),Parent=bg})
                New("UIPadding",{PaddingLeft=UDim.new(0,5),PaddingRight=UDim.new(0,5),Parent=bg})
                New("TextLabel",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text=tostring(text),TextColor3=T2.AccentText,Font=Enum.Font.GothamBold,TextSize=9,ZIndex=16,Parent=bg})
            end
            function api:SetLocked(locked)
                if not frame or not frame.Parent then return end
                -- overlay a grey tint + block input
                local existing = frame:FindFirstChild("__LockOverlay")
                if locked and not existing then
                    local ov=Instance.new("Frame")
                    ov.Name="__LockOverlay"
                    ov.Size=UDim2.fromScale(1,1)
                    ov.BackgroundColor3=Color3.new(0,0,0)
                    ov.BackgroundTransparency=0.55
                    ov.BorderSizePixel=0
                    ov.ZIndex=20
                    Instance.new("UICorner",ov).CornerRadius=UDim.new(0,8)
                    -- Block clicks
                    local blocker=Instance.new("TextButton",ov)
                    blocker.Size=UDim2.fromScale(1,1)
                    blocker.BackgroundTransparency=1
                    blocker.Text=""
                    blocker.ZIndex=21
                    ov.Parent=frame
                elseif not locked and existing then
                    existing:Destroy()
                end
            end
            return api
        end

