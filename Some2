                New("UICorner",{CornerRadius=UDim.new(1,0),Parent=dot})
                local lbl2 = New("TextLabel",{Size=UDim2.fromOffset(0,28),AutomaticSize=Enum.AutomaticSize.X,BackgroundTransparency=1,Text=opt,TextColor3=active and T2.AccentText or T2.Text,Font=active and Enum.Font.GothamBold or Enum.Font.Gotham,TextSize=11,Parent=btn})
