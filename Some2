    -- ── SWIPE TABS (mobile) ───────────────────────────────────
    do
        local swipeStart=nil; local swipeThreshold=60
        ContentHost.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch then
                swipeStart=i.Position
            end
        end)
        ContentHost.InputEnded:Connect(function(i)
            if i.UserInputType~=Enum.UserInputType.Touch or not swipeStart then return end
            local delta=i.Position.X-swipeStart.X
            if math.abs(delta)<swipeThreshold then swipeStart=nil; return end
            -- Find current tab index
            local curIdx=nil
            for idx,tb in ipairs(Window._tabs) do
                if tb._name==Window._activeTab then curIdx=idx; break end
            end
            if not curIdx then swipeStart=nil; return end
            -- Swipe left = next tab, swipe right = prev tab
            local nextIdx = delta<0 and math.min(curIdx+1,#Window._tabs) or math.max(curIdx-1,1)
            if nextIdx~=curIdx then
                Window._tabs[nextIdx]._btn:SetAttribute("__swipe",true)
                pcall(function() Window._tabs[nextIdx]._btn.MouseButton1Click:Fire() end)
                -- Fallback: direct activate via content visibility
                for _,tb in ipairs(Window._tabs) do tb._content.Visible=(tb==Window._tabs[nextIdx]) end
                Window._activeTab=Window._tabs[nextIdx]._name
            end
            swipeStart=nil
        end)
    end


    -- ── KEYBOARD PUSH-UP (mobile) ─────────────────────────────
    local _kbGuiSvc=game:GetService("GuiService")
    local _lastInsetBottom=0
    local _kbTick=0
    local kbConn=game:GetService("RunService").Heartbeat:Connect(function()
        _kbTick=_kbTick+1; if _kbTick%12~=0 then return end; _kbTick=0
        pcall(function()
            local _,br=_kbGuiSvc:GetGuiInset()
            local kbH=math.max(0,br.Y)
            if math.abs(kbH-_lastInsetBottom)<2 then return end
            _lastInsetBottom=kbH
            local vp=workspace.CurrentCamera.ViewportSize
            if kbH>60 then
                local mainBottom=Main.AbsolutePosition.Y+Main.AbsoluteSize.Y
                local overlap=mainBottom-(vp.Y-kbH)
                if overlap>0 then
                    Tween(Main,{Position=UDim2.fromOffset(Main.AbsolutePosition.X,
                        math.max(10,Main.AbsolutePosition.Y-overlap-8))},0.22)
                end
            else
                local ap=Main.AbsolutePosition
                if ap.Y<10 then
                    Tween(Main,{Position=UDim2.fromOffset(ap.X,10)},0.22)
                end
            end
        end)
    end)
    table.insert(Window._connections,kbConn)


    -- ── HAPTIC FEEDBACK helper ────────────────────────────────
    -- Haptic feedback — mobile only via HapticService
    local _hapticSvc=nil
    pcall(function() _hapticSvc=game:GetService("HapticService") end)
    local function Haptic()
        if not _hapticSvc then return end
        pcall(function()
            -- Check mobile controller support
            local ut=Enum.UserInputType.Gamepad1
            local vm=Enum.VibrationMotor.Small
            if _hapticSvc:IsVibrationSupported(ut) and _hapticSvc:IsMotorSupported(ut,vm) then
                _hapticSvc:SetMotor(ut,vm,0.3)
                task.delay(0.05,function()
                    pcall(function() _hapticSvc:SetMotor(ut,vm,0) end)
                end)
            end
        end)
    end
    Window._haptic=Haptic


    -- ── KEYBOARD SHORTCUTS (PC) ───────────────────────────────
    local _undoStack={}  -- {flag, oldVal, newVal}
    Window._undoStack=_undoStack
    local function PushUndo(flag,oldVal,newVal)
        if not flag then return end
        table.insert(_undoStack,{flag=flag,old=oldVal,new=newVal})
        if #_undoStack>50 then table.remove(_undoStack,1) end
    end
    Window._pushUndo=PushUndo

    local shortcutConn=UIS.InputBegan:Connect(function(i,gp)
        if gp then return end
        if i.UserInputType~=Enum.UserInputType.Keyboard then return end
        local ctrl=UIS:IsKeyDown(Enum.KeyCode.LeftControl) or UIS:IsKeyDown(Enum.KeyCode.RightControl)
        if not ctrl then return end
        if i.KeyCode==Enum.KeyCode.S then
            -- Ctrl+S = Save config
            Window:SaveConfig()
            Window:Notify({Title="Saved",Content="Config saved  (Ctrl+S)",Duration=2,Type="success",Icon="save"})
        elseif i.KeyCode==Enum.KeyCode.Z then
            -- Ctrl+Z = Undo last flag change
            local last=_undoStack[#_undoStack]
            if last then
                table.remove(_undoStack)
                Flags[last.flag]=last.old
                Window:SaveConfig()
                Window:Notify({Title="Undo",Content="Reverted: "..last.flag,Duration=2,Type="warn",Icon="arrow"})
            end
        end
    end)
    table.insert(Window._connections,shortcutConn)


    -- ── QUICK TOGGLE BAR ─────────────────────────────────────
    --[[
        Win:CreateQuickBar({
            {Name="Speed",  Flag="SpeedOn",  Icon="bolt"},
            {Name="Fly",    Flag="FlyOn",    Icon="fly"},
            {Name="God",    Flag="GodOn",    Icon="shield"},
        })
        Win:ToggleQuickBar()   -- show/hide
    ]]
    local _qbFrame=nil
    local _qbItems={}
    local _qbVisible=true

    function Window:CreateQuickBar(items)
        if _qbFrame then _qbFrame:Destroy() end
        _qbItems=items or {}
        -- Store rebuild function for Settings tab
        self._qbRebuild = function()
            -- Read __QB_Active flags and rebuild
            local saved=Flags["__QB_Active"]
            local list=type(saved)=="table" and saved or {}
            if #list==0 then return end
            local newItems={}
            for _,flag in ipairs(list) do
                for _,reg in ipairs(self._toggleReg) do
                    if reg.flag==flag then
                        table.insert(newItems,{Name=reg.name,Flag=reg.flag,Icon=reg.icon or "bolt"})
                        break
                    end
                end
            end
            if #newItems>0 then self:CreateQuickBar(newItems) end
        end
        local T2=self._theme

        -- Outer container (draggable, fixed width 300px on mobile else 360px)
        local _isMobQB = UIS and UIS.TouchEnabled and not UIS.KeyboardEnabled
        local _qbW = _isMobQB and 300 or 360
        _qbFrame=New("Frame",{
            Size=UDim2.fromOffset(_qbW, 64),
            AnchorPoint=Vector2.new(0.5,1),
            Position=UDim2.new(0.5,0,1,-10),
            BackgroundColor3=T2.SecondaryBg,BorderSizePixel=0,
            ZIndex=600,ClipsDescendants=true,
            Parent=self._screenGui,
        })
        New("UICorner",{CornerRadius=UDim.new(0,14),Parent=_qbFrame})
        New("UIStroke",{Color=T2.Accent,Thickness=1.5,Transparency=0.3,Parent=_qbFrame})

        -- Inner ScrollingFrame — horizontal scroll
        local _qbScroll=New("ScrollingFrame",{
            Size=UDim2.new(1,-16,1,0),
            Position=UDim2.fromOffset(8,0),
            BackgroundTransparency=1,BorderSizePixel=0,
            ScrollBarThickness=0,  -- hidden scrollbar, swipe to scroll
            ScrollingDirection=Enum.ScrollingDirection.X,
            CanvasSize=UDim2.fromOffset(0,64),
            AutomaticCanvasSize=Enum.AutomaticSize.X,
            ZIndex=601,Parent=_qbFrame,
        })
        New("UIPadding",{PaddingTop=UDim.new(0,6),PaddingBottom=UDim.new(0,6),PaddingLeft=UDim.new(0,2),PaddingRight=UDim.new(0,4),Parent=_qbScroll})
        New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,4),Parent=_qbScroll})

        MakeDraggable(_qbFrame,_qbFrame,0)
        -- Store scroll ref for button creation
        local _qbBtnParent = _qbScroll

        for _,item in ipairs(items) do
            local active=Flags[item.Flag]==true
            local btn=New("TextButton",{
                Size=UDim2.fromOffset(48,48),
                BackgroundColor3=active and T2.Accent or T2.ElementBg,
                BorderSizePixel=0,Text="",AutoButtonColor=false,ZIndex=602,Parent=_qbBtnParent,
            })
            New("UICorner",{CornerRadius=UDim.new(0,10),Parent=btn})
            New("UIStroke",{Color=active and T2.Accent or T2.ElementStroke,Thickness=1,Parent=btn})
            -- Inner layout: icon + label stacked
            local inner=New("Frame",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Parent=btn})
            New("UIListLayout",{FillDirection=Enum.FillDirection.Vertical,HorizontalAlignment=Enum.HorizontalAlignment.Center,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2),Parent=inner})
            local iconColor = active and T2.AccentText or Color3.new(1,1,1)
            local ico
            if item.Icon then
                ico=New("ImageLabel",{Size=UDim2.fromOffset(18,18),BackgroundTransparency=1,Image=GetIcon(item.Icon),ImageColor3=iconColor,LayoutOrder=1,Parent=inner})
            end
            local lbl=New("TextLabel",{Size=UDim2.new(1,0,0,10),BackgroundTransparency=1,Text=(item.Name or ""):sub(1,5),TextColor3=iconColor,Font=Enum.Font.GothamBold,TextSize=8,TextXAlignment=Enum.TextXAlignment.Center,LayoutOrder=2,Parent=inner})
            local capturedItem=item
            btn.MouseButton1Click:Connect(function()
                local newVal=not (Flags[capturedItem.Flag]==true)
                Flags[capturedItem.Flag]=newVal
                local newBg=newVal and T2.Accent or T2.ElementBg
                local newClr=newVal and T2.AccentText or Color3.new(1,1,1)
                Tween(btn,{BackgroundColor3=newBg},0.15)
                local stroke=btn:FindFirstChildOfClass("UIStroke")
                if stroke then Tween(stroke,{Color=newVal and T2.Accent or T2.ElementStroke},0.15) end
                if ico then Tween(ico,{ImageColor3=newClr},0.15) end
                if lbl then Tween(lbl,{TextColor3=newClr},0.15) end
                if self._haptic then self._haptic() end
                self:SaveConfig()
                -- Fire the real callback stored in registry
                local cb = self._toggleCbs and self._toggleCbs[capturedItem.Flag]
                if cb then pcall(cb, newVal)
                elseif capturedItem.Callback then pcall(capturedItem.Callback, newVal) end
            end)
        end
    end

    function Window:ToggleQuickBar()
        if not _qbFrame then return end
        _qbVisible=not _qbVisible
        _qbFrame.Visible=_qbVisible
    end

    function Window:UpdateQuickBar()
        -- Refresh all quick bar button states from Flags
        if not _qbFrame then return end
        local T2=self._theme
        local btns={}
        for _,c in ipairs(_qbFrame:GetChildren()) do
            if c:IsA("TextButton") then table.insert(btns,c) end
        end
        for i,item in ipairs(_qbItems) do
            local btn=btns[i]; if not btn then continue end
            local active=Flags[item.Flag]==true
            btn.BackgroundColor3=active and T2.Accent or T2.ElementBg
            local ico=btn:FindFirstChildOfClass("ImageLabel") or btn:FindFirstChildOfClass("TextLabel")
            if ico then pcall(function() ico.ImageColor3=active and T2.AccentText or T2.TextDim end); pcall(function() ico.TextColor3=active and T2.AccentText or T2.TextDim end) end
        end
    end


    -- ── FAVOURITES TAB ───────────────────────────────────────
    --[[ 
        Add/remove elements from Favourites tab (pinned first tab).
        Usage: any element API has :SetFavourite(true/false)
        Or via right-click context menu on elements.
    ]]
    local _favTab = nil
    local _favElements = {}  -- {name, frame, original_parent}

    function Window:GetFavTab()
        if _favTab then return _favTab end
        -- Create a special Favourites tab
        _favTab = self:CreateTab("Favourites", "star")
        -- Move it to LayoutOrder 1 (just after settings=0, divider=1.5)
        if _favTab._btn then _favTab._btn.LayoutOrder = 1 end
        return _favTab
    end

    function Window:PinToFavourites(elementName, frame)
        if not frame or not frame.Parent then return end
        if _favElements[elementName] then return end -- already pinned
        -- Clone element into fav tab
        local favTabObj = self:GetFavTab()
        local clone = frame:Clone()
        clone.Parent = favTabObj._content
        _favElements[elementName] = {frame=frame, clone=clone, name=elementName}
        self:Notify({Title="Pinned",Content=elementName.." added to Favourites",Duration=2,Icon="star",Type="success"})
    end

    function Window:UnpinFromFavourites(elementName)
        local entry = _favElements[elementName]
        if not entry then return end
        pcall(function() entry.clone:Destroy() end)
        _favElements[elementName] = nil
        self:Notify({Title="Unpinned",Content=elementName.." removed from Favourites",Duration=2,Icon="star",Type="warn"})
    end

    -- Register to singleton list (for destroy on re-execute)
    table.insert(_G.__NexusLib_Windows, Window)

    return Window
end  -- end CreateWindow


return NexusLib
