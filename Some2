        -- ── DROPDOWN ───────────────────────────────────────
        function TabObj:CreateDropdown(cfg2)
            local opts      = cfg2.Options or {}
            local multiSel  = cfg2.MultiSelect == true
            local savedOpt  = self._window:LoadConfigValue(cfg2.Flag, nil)
            -- For multi-select, selected is a table; single-select is a string
            local selected  -- table for multi, string for single
            if multiSel then
                selected = (type(savedOpt)=="table") and savedOpt or {}
            else
                local current = savedOpt ~= nil and savedOpt or (cfg2.Default or opts[1] or "")
                selected = current
            end
            local fromSave  = savedOpt ~= nil
            local isOpen    = false
            local trackConn = nil
            if cfg2.Flag then
                Flags[cfg2.Flag] = multiSel and selected or selected
            end

            local function getDisplayText()
                if multiSel then
                    if #selected == 0 then return "None" end
                    if #selected == 1 then return selected[1] end
                    return selected[1].." +"..(#selected-1).." more"
                else
                    return tostring(selected)
                end
            end

            local function isSelected(opt)
                if multiSel then
                    for _, v in ipairs(selected) do if v == opt then return true end end
                    return false
                else
                    return opt == selected
                end
            end

            local f = BaseFrame(0)
            f.ClipsDescendants = false
            New("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,10),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),Parent=f})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),Parent=f})

            -- Label row
            local TopRow3 = New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,LayoutOrder=1,Parent=f})
            New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),Parent=TopRow3})
            if cfg2.Icon then
                New("ImageLabel",{Size=UDim2.fromOffset(14,14),BackgroundTransparency=1,Image=GetIcon(cfg2.Icon),ImageColor3=T2.TextDim,Parent=TopRow3})
            end
            New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=cfg2.Name or "Dropdown",TextColor3=T2.Text,Font=Enum.Font.GothamSemibold,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=TopRow3})

            -- Dropdown button
            local DropBtn = New("TextButton",{
                Size=UDim2.new(1,0,0,36),BackgroundColor3=T2.InputBg,BorderSizePixel=0,
                Text="",AutoButtonColor=false,LayoutOrder=2,Parent=f,
            })
            New("UICorner",{CornerRadius=UDim.new(0,8),Parent=DropBtn})
            New("UIStroke",{Color=T2.InputStroke,Thickness=1,Parent=DropBtn})
            New("UIPadding",{PaddingLeft=UDim.new(0,11),PaddingRight=UDim.new(0,8),Parent=DropBtn})
            New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Parent=DropBtn})
            local CurLabel = New("TextLabel",{
                Size=UDim2.new(1,-26,1,0),BackgroundTransparency=1,
                Text=getDisplayText(),TextColor3=T2.Text,
                Font=Enum.Font.GothamSemibold,TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=1,Parent=DropBtn,
            })
            local Arrow = New("TextLabel",{
                Size=UDim2.fromOffset(22,22),BackgroundTransparency=1,
                Text="⌄",TextColor3=T2.Accent,
                Font=Enum.Font.GothamBold,TextSize=16,LayoutOrder=2,Parent=DropBtn,
            })

            local ITEM_H  = 34
            local MAX_VIS = 7
            local PAD     = 8

            local ListBg = New("Frame",{
                Size=UDim2.fromOffset(0,0),
                BackgroundColor3=T2.SecondaryBg,BorderSizePixel=0,
                ClipsDescendants=true,Visible=false,ZIndex=9998,
                Parent=self._window._screenGui,
            })
            New("UICorner",{CornerRadius=UDim.new(0,10),Parent=ListBg})
            New("UIStroke",{Color=T2.Accent,Thickness=1,Transparency=0.5,Parent=ListBg})
            New("ImageLabel",{
                AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,4),
                Size=UDim2.new(1,20,1,20),BackgroundTransparency=1,
                Image="rbxassetid://6014261993",ImageColor3=Color3.new(0,0,0),
                ImageTransparency=0.55,ScaleType=Enum.ScaleType.Slice,
                SliceCenter=Rect.new(49,49,450,450),ZIndex=9997,Parent=ListBg,
            })

            -- Inner layout: scroll list + close button (multi-select)
            local InnerLayout = New("Frame",{
                Size=UDim2.fromScale(1,1),BackgroundTransparency=1,ZIndex=9999,Parent=ListBg,
            })
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Parent=InnerLayout})

            local ListScroll = New("ScrollingFrame",{
                Size=UDim2.fromScale(1,1),
                BackgroundTransparency=1,BorderSizePixel=0,
                ScrollBarThickness=3,ScrollBarImageColor3=T2.Accent,
                CanvasSize=UDim2.fromOffset(0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
                ZIndex=9999,LayoutOrder=1,Parent=InnerLayout,
            })
            New("UIPadding",{PaddingTop=UDim.new(0,PAD/2),PaddingBottom=UDim.new(0,PAD/2),PaddingLeft=UDim.new(0,5),PaddingRight=UDim.new(0,5),Parent=ListScroll})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,3),Parent=ListScroll})

            -- Close button for multi-select (removed - use DropBtn to toggle)
            local CloseBtn = nil

            local function GetListPos()
                local abs = DropBtn.AbsolutePosition
                local sz  = DropBtn.AbsoluteSize
                local visCount = math.min(#opts, MAX_VIS)
                local listH = visCount * ITEM_H + PAD
                local listW = math.max(sz.X, 120)
                local screenH = workspace.CurrentCamera.ViewportSize.Y
                local posY = abs.Y + sz.Y + 6
                if posY + listH > screenH - 16 then
                    posY = abs.Y - listH - 6
                end
                return abs.X, posY, listW, listH
            end

            local function UpdateListPos()
                if not isOpen then return end
                local x, y, w, h = GetListPos()
                ListBg.Position = UDim2.fromOffset(x, y)
            end

            local closeId = tostring(ListBg)
            local function CloseList()
                isOpen = false
                _openDropdowns[closeId] = nil
                if trackConn then trackConn:Disconnect(); trackConn = nil end
                Tween(ListBg,{Size=UDim2.fromOffset(ListBg.AbsoluteSize.X, 0)},0.15)
                Tween(Arrow,{TextColor3=T2.Accent,Rotation=0},0.15)
                task.delay(0.17, function() if not isOpen then ListBg.Visible = false end end)
            end

            local itemButtons = {}
            local function RefreshItemColors()
                for opt, btn in pairs(itemButtons) do
                    local sel = isSelected(opt)
                    Tween(btn,{BackgroundColor3= sel and T2.Accent or T2.ElementBg},0.1)
                    btn.TextColor3 = sel and T2.AccentText or T2.Text
                    btn.Font = sel and Enum.Font.GothamBold or Enum.Font.Gotham
                end
            end

            local function BuildList()
                for _, c in ipairs(ListScroll:GetChildren()) do
                    if c:IsA("TextButton") then c:Destroy() end
                end
                itemButtons = {}
                for i, opt in ipairs(opts) do
                    local sel = isSelected(opt)
                    local item = New("TextButton",{
                        Size=UDim2.new(1,0,0,ITEM_H - 3),
                        BackgroundColor3= sel and T2.Accent or T2.ElementBg,
                        BorderSizePixel=0,Text=opt,
                        TextColor3= sel and T2.AccentText or T2.Text,
                        Font= sel and Enum.Font.GothamBold or Enum.Font.Gotham,
                        TextSize=12,AutoButtonColor=false,ZIndex=10000,Parent=ListScroll,
                    })
                    New("UICorner",{CornerRadius=UDim.new(0,7),Parent=item})
                    New("UIPadding",{PaddingLeft=UDim.new(0,12),Parent=item})
                    item.TextXAlignment = Enum.TextXAlignment.Left
                    itemButtons[opt] = item
                    if not sel then
                        item.MouseEnter:Connect(function()
                            if not isSelected(opt) then Tween(item,{BackgroundColor3=T2.ElementBgHover},0.1) end
                        end)
                        item.MouseLeave:Connect(function()
                            if not isSelected(opt) then Tween(item,{BackgroundColor3=T2.ElementBg},0.1) end
                        end)
                    end
                    item.MouseButton1Click:Connect(function()
                        if multiSel then
                            -- Toggle in selected table
                            local found = false
                            for i2, v in ipairs(selected) do
                                if v == opt then table.remove(selected, i2); found = true; break end
                            end
                            if not found then table.insert(selected, opt) end
                            if cfg2.Flag then Flags[cfg2.Flag] = selected end
                            CurLabel.Text = getDisplayText()
                            RefreshItemColors()
                            if cfg2.Callback then pcall(cfg2.Callback, opt) end
                            self._window:SaveConfig()
                            -- Keep list OPEN for multi-select
                        else
                            selected = opt
                            CurLabel.Text = opt
                            if cfg2.Flag then Flags[cfg2.Flag] = opt end
                            CloseList()
                            task.defer(BuildList)
                            if cfg2.Callback then pcall(cfg2.Callback, opt) end
                            self._window:SaveConfig()
                        end
                    end)
                end
            end
            BuildList()

            DropBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    BuildList()
                    local x, y, w, h = GetListPos()
                    ListBg.Position = UDim2.fromOffset(x, y)
                    ListBg.Size = UDim2.fromOffset(w, 0)
                    ListBg.Visible = true
                    Tween(ListBg,{Size=UDim2.fromOffset(w, h)},0.2)
                    Tween(Arrow,{Rotation=180},0.2)
                    trackConn = RunService.RenderStepped:Connect(UpdateListPos)
                    _openDropdowns[closeId] = CloseList
                else
                    CloseList()
                end
            end)

            -- Close on click outside (both single and multi)
            local closeConn = UIS.InputBegan:Connect(function(i, gp)
                if gp then return end
                if isOpen and (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) then
                    task.defer(function()
                        if isOpen then CloseList() end
                    end)
                end
            end)
            table.insert(self._window._connections, closeConn)

            RegisterElement(cfg2.Name or "Dropdown", f)
            if fromSave and cfg2.Callback then
                if multiSel then
                    -- Restore visual + fire callbacks to sync hub variables
                    task.defer(function()
                        CurLabel.Text = getDisplayText()
                        BuildList()
                        -- Fire callback per item so hub's selectedHerb etc get populated
                        for _, v in ipairs(selected) do
                            pcall(cfg2.Callback, v)
                        end
                    end)
                else
                    task.defer(function() pcall(cfg2.Callback, selected) end)
                end
            end
            return {
                Refresh = function(_, newOpts, newCurrent)
                    opts = newOpts
                    if newCurrent then
                        if multiSel then selected = type(newCurrent)=="table" and newCurrent or {}
                        else selected = newCurrent end
                        CurLabel.Text = getDisplayText()
                    end
                    BuildList()
                end,
                GetValue = function() return selected end,
            }
        end
