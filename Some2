            -- Rows container
            local Rows=New("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,LayoutOrder=3,Parent=f})
            New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,4),Parent=Rows})

            -- Banner label (bottom highlight line)
            local Banner=New("TextLabel",{
                Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,Text="",TextColor3=Color3.fromRGB(80,255,120),
                Font=Enum.Font.GothamBold,TextSize=11,TextWrapped=true,
                TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=4,Visible=false,Parent=f,
            })

            RegisterElement(cfg2.Name or "StatusPanel", f)

            local _rows={}

            local function BuildRow(key, rc)
                local row=New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Parent=Rows})
                New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,5),Parent=row})
                local icoLbl=nil
                if rc.Icon then icoLbl=New("ImageLabel",{Size=UDim2.fromOffset(13,13),BackgroundTransparency=1,Image=GetIcon(rc.Icon),ImageColor3=T2.TextDim,Parent=row}) end
                New("TextLabel",{Size=UDim2.fromOffset(0,18),AutomaticSize=Enum.AutomaticSize.X,BackgroundTransparency=1,Text=rc.Label or "",TextColor3=T2.TextDim,Font=Enum.Font.Gotham,TextSize=11,Parent=row})
                local vLbl=New("TextLabel",{Size=UDim2.fromOffset(0,18),AutomaticSize=Enum.AutomaticSize.X,BackgroundTransparency=1,Text=tostring(rc.Value or ""),TextColor3=rc.Color or T2.Accent,Font=Enum.Font.GothamBold,TextSize=11,Parent=row})
                _rows[key]={frame=row,vLbl=vLbl,icoLbl=icoLbl}
            end

            local SP={}
            function SP:AddRow(key,rc) if not _rows[key] then BuildRow(key,rc or {}) else self:SetRow(key,rc) end end
            function SP:SetRow(key,rc)
                local r=_rows[key]; if not r then BuildRow(key,rc or {}); return end
                if rc.Value~=nil then r.vLbl.Text=tostring(rc.Value) end
                if rc.Color then r.vLbl.TextColor3=rc.Color end
                if rc.Icon and r.icoLbl then r.icoLbl.Image=GetIcon(rc.Icon) end
            end
            function SP:SetValue(key,val,col)
                local r=_rows[key]; if not r then return end
                r.vLbl.Text=tostring(val)
                if col then r.vLbl.TextColor3=col end
            end
            function SP:SetBanner(text,col)
                if text and text~="" then Banner.Text="✓ "..text; Banner.TextColor3=col or Color3.fromRGB(80,255,120); Banner.Visible=true
                else Banner.Visible=false end
            end
            function SP:SetTitle(text) TitleLbl.Text=(text or ""):upper() end
            function SP:Clear()
                for _,r in pairs(_rows) do pcall(function() r.frame:Destroy() end) end
                _rows={}; Banner.Visible=false
            end
            return SP
        end

