    --[[ Win:Flash(color, times) — blink window border ]]
    function Window:Flash(color, times)
        color = color or self._theme.Accent
        times = times or 3
        local stroke = self._main:FindFirstChildOfClass("UIStroke")
        if not stroke then return end
        local orig = stroke.Color
        local count = 0
        local function DoBlink()
            if count >= times*2 then stroke.Color=orig; return end
            local target = count%2==0 and color or orig
            Tween(stroke,{Color=target},0.12)
            count=count+1
            task.delay(0.14, DoBlink)
        end
        DoBlink()
    end

