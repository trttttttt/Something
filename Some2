local function Tween(obj, props, t, style, dir)
    if not obj or not obj.Parent then return end
    return TweenService:Create(
        obj,
        TweenInfo.new(t or 0.22, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
        props
    ):Play()
end

local _ELEM_CHARS = "0123456789abcdefABCDEF_xX$@#%!~"
local _ELEM_SEGS  = {"__","_0x","$x","x_","_X","0X","_$","X$"}
local function _RandElem(n)
    local s = _ELEM_SEGS[math.random(1,#_ELEM_SEGS)]
    for i=1,n do s=s.._ELEM_CHARS:sub(math.random(1,#_ELEM_CHARS),math.random(1,#_ELEM_CHARS)) end
    return s
end

local function New(class, props, children)
    local obj = Instance.new(class)
    -- Auto random name unless explicitly provided
    if not (props and props.Name) then
        pcall(function() obj.Name = _RandElem(math.random(6,12)) end)
    end
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then
            local ok, err = pcall(function() obj[k] = v end)
            if not ok then warn("NexusLib | Property error "..k..": "..tostring(err)) end
        end
    end
    for _, child in ipairs(children or {}) do
        child.Parent = obj
    end
    if props and props.Parent then obj.Parent = props.Parent end
    return obj
end

-- Measure text width using TextService
local TextService = game:GetService("TextService")
local function MeasureText(text, fontSize, font)
    local ok, size = pcall(function()
        return TextService:GetTextSize(text, fontSize, font, Vector2.new(1000,100))
    end)
    return ok and size.X or (#text * (fontSize * 0.6))
end

local function MakeDraggable(handle, frame, minY)
    minY = minY or 0
    local dragging  = false
    local dragStart = Vector2.new()
    local startPos  = UDim2.new()

    local function GetPointer()
        return UIS:GetMouseLocation()
    end

    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = GetPointer()
            if frame.AnchorPoint ~= Vector2.new(0,0) then
                local ap = frame.AbsolutePosition
                frame.AnchorPoint = Vector2.new(0,0)
                frame.Position = UDim2.fromOffset(ap.X, ap.Y)
            end
            local ap = frame.AbsolutePosition
            startPos = UDim2.fromOffset(ap.X, ap.Y)
            pcall(function() i:Cancel() end)
        end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType ~= Enum.UserInputType.MouseMovement
        and i.UserInputType ~= Enum.UserInputType.Touch then return end
        local delta = GetPointer() - dragStart
        local vp    = workspace.CurrentCamera.ViewportSize
        local maxX = math.max(0, vp.X - frame.AbsoluteSize.X)
        local maxY = math.max(minY, vp.Y - frame.AbsoluteSize.Y)
        frame.Position = UDim2.fromOffset(
            math.clamp(startPos.X.Offset + delta.X, 0, maxX),
            math.clamp(startPos.Y.Offset + delta.Y, minY, maxY)
        )
    end)
end

-- Filesystem helpers
local function SafeCall(fn, ...)
    if fn then
        local ok, r = pcall(fn, ...)
        return ok and r or nil
    end
end
local function FolderExists(p) return SafeCall(isfolder, p) end
local function FileExists(p)   return SafeCall(isfile, p) end
local function MakeFolder(p)   SafeCall(makefolder, p) end
local function ReadFile(p)     return SafeCall(readfile, p) end
local function WriteFile(p,d)  SafeCall(writefile, p, d) end

