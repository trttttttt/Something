    -- Random name — susah detect, lain setiap kali load
    -- Garbage name generator — long mixed symbols/hex, unreadable
    local _CHARS = "0123456789abcdefABCDEF_xX$@#%!~"
    local function RandStr(n)
        local s = ""
        for i = 1, n do s = s .. _CHARS:sub(math.random(1,#_CHARS),math.random(1,#_CHARS)) end
        return s
    end
    local _SEGS = {"__","_0x","$x","x_","_X","0X","_$","X$","$_","0_"}
    local function RandGuiName()
        -- e.g.  __0xA3f$x_9B!X$_#2Ec@_x7_$X
        local out = _SEGS[math.random(1,#_SEGS)]
        local parts = math.random(4,7)
        for i=1,parts do
            out = out .. RandStr(math.random(3,6)) .. _SEGS[math.random(1,#_SEGS)]
        end
        return out
    end
    -- Same for inner elements — shorter but still garbage
    local function RandElemName()
        return _SEGS[math.random(1,#_SEGS)] .. RandStr(math.random(5,10))
