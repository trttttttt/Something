})

Misc:CreateInput({
    Name = "Spam Message",
    PlaceholderText = "Enter message...",
    Flag = "SpamMsg",
    Callback = function(v) end,
})

Misc:CreateButton({
    Name = "Send Chat Message",
    Icon = "send",
    Callback = function()
        local msg = tostring(Nexus.Flags["SpamMsg"] or "Hello!")
        pcall(function()
            game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(msg, "All")
        end)
    end,
})

Misc:CreateSection("Server")

Misc:CreateButton({
    Name = "Copy Server ID",
    Icon = "copy",
    Callback = function()
        local id = tostring(game.JobId)
        pcall(function() setclipboard(id) end)
        Win:Notify({Title="Copied!", Content="Server ID: "..id, Duration=3, Icon="check"})
    end,
})

Misc:CreateButton({
    Name = "Hop Server",
    Icon = "refresh",
    Callback = function()
        Win:Notify({Title="Server Hop", Content="Finding new server...", Duration=2, Icon="wifi"})
        pcall(function()
            local TS = game:GetService("TeleportService")
            local result = TS:GetSortedGameInstances(game.PlaceId, 10)
            for _, s in ipairs(result) do
                if s.JobId ~= game.JobId and s.CurrentPlayers < s.MaxPlayers then
                    TS:TeleportToPlaceInstance(game.PlaceId, s.JobId)
                    return
                end
            end
        end)
    end,
})

