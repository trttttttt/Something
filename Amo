-- ══════════════════════════════════════════════════
local Visual = Win:CreateTab("Visual", "star")

Visual:CreateSection("World Visuals")

Visual:CreateToggle({
    Name = "Fullbright",
    Description = "Max brightness in all environments",
    CurrentValue = false,
    Flag = "Fullbright",
    Callback = function(v)
        pcall(function()
            local Lighting = game:GetService("Lighting")
            Lighting.Brightness = v and 2 or 1
            Lighting.ClockTime = v and 14 or 14
            Lighting.FogEnd = v and 100000 or 100000
            Lighting.GlobalShadows = not v
        end)
    end,
})

Visual:CreateToggle({
    Name = "Remove Fog",
    Description = "Removes all atmospheric fog",
    CurrentValue = false,
    Flag = "RemoveFog",
    Callback = function(v)
        pcall(function()
            game:GetService("Lighting").FogEnd = v and 999999 or 100000
        end)
    end,
})

Visual:CreateSlider({
    Name = "Field of View",
    Range = {10, 120},
    Increment = 1,
    CurrentValue = 70,
    Suffix = "°",
    Flag = "FOV",
    Callback = function(v)
        pcall(function()
            workspace.CurrentCamera.FieldOfView = v
        end)
    end,
})

Visual:CreateSection("Character Visuals")

Visual:CreateToggle({
    Name = "Hide Local Character",
    Description = "Makes your character invisible",
    CurrentValue = false,
    Flag = "HideChar",
    Callback = function(v)
        pcall(function()
            local lp = game.Players.LocalPlayer
            if lp and lp.Character then
                for _, p in ipairs(lp.Character:GetDescendants()) do
                    if p:IsA("BasePart") or p:IsA("Decal") then
                        p.LocalTransparencyModifier = v and 1 or 0
                    end
                end
            end
        end)
    end,
})

Visual:CreateColorPicker({
    Name = "Chat Color",
    Color = Color3.fromRGB(255, 255, 255),
    Flag = "ChatColor",
    Callback = function(c) end,
})

Visual:CreateSection("Camera")

Visual:CreateToggle({
