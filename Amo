-- ══════════════════════════════════════════════════
local Teleport = Win:CreateTab("Teleport", "map")

Teleport:CreateSection("Saved Locations")

Teleport:CreateButton({
    Name = "Teleport to Spawn",
    Icon = "home",
    Callback = function()
        local lp = game.Players.LocalPlayer
        pcall(function()
            local spawn = workspace:FindFirstChildOfClass("SpawnLocation")
            if spawn and lp.Character then
                lp.Character:SetPrimaryPartCFrame(spawn.CFrame + Vector3.new(0,5,0))
            end
        end)
    end,
})

Teleport:CreateButton({
    Name = "Teleport to Player",
    Icon = "users",
    Callback = function()
        Win:Notify({Title="Teleport", Content="Select a player in Target list first.", Duration=3, Icon="info"})
    end,
})

Teleport:CreateDropdown({
    Name = "Target Player",
    Icon = "user",
    Options = (function()
        local names = {}
        for _, p in ipairs(game.Players:GetPlayers()) do
            table.insert(names, p.Name)
        end
        return names
    end)(),
    Flag = "TeleportTarget",
    Callback = function(v) end,
})

Teleport:CreateSection("Custom Teleport")

Teleport:CreateInput({
    Name = "X Position",
    PlaceholderText = "0",
    Flag = "TpX",
    Callback = function(v) end,
})

Teleport:CreateInput({
    Name = "Y Position",
    PlaceholderText = "0",
    Flag = "TpY",
    Callback = function(v) end,
})

Teleport:CreateInput({
    Name = "Z Position",
    PlaceholderText = "0",
    Flag = "TpZ",
    Callback = function(v) end,
})

Teleport:CreateButton({
    Name = "Teleport to Coords",
    Icon = "compass",
    Callback = function()
        local lp = game.Players.LocalPlayer
        local x = tonumber(Nexus.Flags["TpX"]) or 0
        local y = tonumber(Nexus.Flags["TpY"]) or 0
        local z = tonumber(Nexus.Flags["TpZ"]) or 0
        pcall(function()
            if lp.Character then
                lp.Character:SetPrimaryPartCFrame(CFrame.new(x, y, z))
            end
        end)
    end,
})

